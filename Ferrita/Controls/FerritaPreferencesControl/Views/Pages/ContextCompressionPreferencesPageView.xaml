<UserControl x:Class="Ferrita.Controls.FerritaPreferencesControl.Views.Pages.ContextCompressionPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Ferrita.Controls.FerritaPreferencesControl.ViewModels.Pages"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ContextCompressionPreferencesPageViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="720"
             d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Ferrita;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFF4FAFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PreferenceValueStyle" TargetType="TextBlock" BasedOn="{StaticResource PreferenceMetaStyle}">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,16,20">
            <TextBlock Text="{DynamicResource ContextCompression.Page.Title}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="MinCompaction"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <CheckBox Grid.Row="0"
                          Grid.Column="1"
                          IsChecked="{Binding MinCompactionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Content="{DynamicResource ContextCompression.MinCompaction.Content}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding MinCompactionBehaviorText}"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="MaxCompaction"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <StackPanel Grid.Row="4"
                            Grid.Column="1">
                    <CheckBox IsChecked="{Binding MaxCompactionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Content="{DynamicResource ContextCompression.MaxCompaction.Content}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="{DynamicResource ContextCompression.MaxCompaction.Hint}"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </StackPanel>

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Text="LifeCycle"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <StackPanel Grid.Row="6"
                            Grid.Column="1">
                    <CheckBox IsChecked="{Binding LifeCycleEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Content="{DynamicResource ContextCompression.LifeCycle.Content}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="{DynamicResource ContextCompression.LifeCycle.Hint}"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </StackPanel>

                <Grid Grid.Row="8"
                      Grid.ColumnSpan="2">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LifeCycleEnabled}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="{DynamicResource ContextCompression.LifeCycleRatio.Label}"
                               Style="{StaticResource PreferenceLabelStyle}"/>
                    <Grid Grid.Row="0"
                          Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Minimum="10"
                                Maximum="500"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                HorizontalAlignment="Stretch"
                                Value="{Binding LifeCycleRatioPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding LifeCycleRatioDisplayText}"
                                   Style="{StaticResource PreferenceValueStyle}"/>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="{DynamicResource ContextCompression.LifeCycleRatio.Hint}"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </Grid>

                <TextBlock Grid.Row="10"
                           Grid.Column="0"
                           Text="{DynamicResource ContextCompression.RnnOptimization.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <StackPanel Grid.Row="10"
                            Grid.Column="1">
                    <CheckBox IsChecked="{Binding RnnOptimizedCompactionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                               Content="{DynamicResource ContextCompression.RnnOptimization.Content}"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="{DynamicResource ContextCompression.RnnOptimization.Hint}"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </StackPanel>
            </Grid>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="{DynamicResource Common.ConfigurationStatus}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{DynamicResource Common.ConfigurationFile}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding ConfigurationFilePath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="{DynamicResource Common.RecentStatus}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource PreferenceValueStyle}"/>
            </Grid>

            <StackPanel Margin="0,16,0,0"
                        Orientation="Horizontal">
                <Button MinWidth="132"
                        Content="{DynamicResource Common.OpenConfigurationDirectory}"
                        Command="{Binding OpenConfigurationDirectoryCommand}"/>
            </StackPanel>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="{DynamicResource Common.Instructions}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <TextBlock Margin="0,12,0,0"
                       Text="{DynamicResource ContextCompression.Instruction.1}"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{DynamicResource ContextCompression.Instruction.2}"
                       Style="{StaticResource PreferenceMetaStyle}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
