<UserControl x:Class="Ferrita.Controls.FerritaPreferencesControl.Views.Pages.OpenSourceLicensesPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Ferrita.Controls.FerritaPreferencesControl.ViewModels.Pages"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:OpenSourceLicensesPreferencesPageViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="640"
             d:DesignWidth="860">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Ferrita;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="LicenseNameTextStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="LicenseBodyTextBoxStyle" TargetType="TextBox">
                <Setter Property="Margin" Value="0,10,0,0"/>
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="MinHeight" Value="96"/>
                <Setter Property="MaxHeight" Value="260"/>
                <Setter Property="AcceptsReturn" Value="True"/>
                <Setter Property="IsReadOnly" Value="True"/>
                <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="VerticalScrollBarVisibility" Value="Disabled"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
                <Setter Property="FontFamily" Value="Consolas"/>
                <Setter Property="FontSize" Value="11.5"/>
                <Setter Property="VerticalContentAlignment" Value="Top"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,24,20">
            <TextBlock Text="{Binding Title}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>
            <TextBlock Margin="0,10,0,0"
                       Text="{Binding Description}"
                       Style="{StaticResource PreferenceMetaStyle}"/>

            <ItemsControl Margin="0,18,0,0"
                          ItemsSource="{Binding LicenseSections}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type viewModels:OpenSourceLicenseSection}">
                        <Border Margin="0,0,0,18"
                                Padding="14"
                                Background="#1823384D"
                                BorderBrush="#45BBDDF2"
                                BorderThickness="1"
                                CornerRadius="6">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Title}"
                                               Style="{StaticResource PreferenceSectionTitleStyle}"
                                               TextWrapping="Wrap"/>

                                    <Border Grid.Column="1"
                                            Margin="12,0,0,0"
                                            Padding="8,3"
                                            Background="#263F6E88"
                                            BorderBrush="#557FD8FF"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding LicenseName}"
                                                   Style="{StaticResource LicenseNameTextStyle}"/>
                                    </Border>
                                </Grid>

                                <TextBlock Margin="0,8,0,0"
                                           Text="{Binding Note}"
                                           Style="{StaticResource PreferenceMetaStyle}"/>

                                <TextBox Text="{Binding LicenseText, Mode=OneWay}"
                                         Style="{StaticResource LicenseBodyTextBoxStyle}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
