<UserControl x:Class="Ferrita.Controls.FerritaPreferencesControl.Views.Pages.SearchPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Ferrita.Controls.FerritaPreferencesControl.ViewModels.Pages"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SearchPreferencesPageViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="640"
             d:DesignWidth="860">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Ferrita;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFF4FAFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PreferenceValueStyle" TargetType="TextBlock" BasedOn="{StaticResource PreferenceMetaStyle}">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,16,20">
            <!-- 标题和说明 -->
            <TextBlock Text="{Binding Title}"
                        Style="{StaticResource PreferenceSectionTitleStyle}"/>
            <TextBlock Margin="0,4,0,12"
                       Text="{Binding Description}"
                       Style="{StaticResource PreferenceMetaStyle}"/>

            <!-- 主选择 API -->
            <Grid Margin="0,4,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{DynamicResource Search.Api.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding SearchApis}"
                          SelectedValue="{Binding SelectedApi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="Type"
                          DisplayMemberPath="DisplayName"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{DynamicResource Search.Api.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>
            </Grid>

            <!-- Brave Search 配置段 -->
            <StackPanel Visibility="{Binding IsBraveSearchSelected, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="#20FFFFFF" Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource Search.Brave.Title}" Style="{StaticResource PreferenceSectionTitleStyle}" Margin="0,0,0,12"/>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Search.Brave.ApiKey.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBox Text="{Binding BraveSearchApiKey, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Brave.ApiKey.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Search.Brave.Country.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBox Text="{Binding BraveSearchCountry, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Brave.Country.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Search.Brave.Language.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="4" Grid.Column="1">
                        <TextBox Text="{Binding BraveSearchLanguage, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Brave.Language.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Search.Brave.SafeSearch.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="6" Grid.Column="1">
                        <ComboBox ItemsSource="{Binding BraveSearchSafeSearchOptions}" SelectedItem="{Binding BraveSearchSafeSearch, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Brave.SafeSearch.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource Search.Brave.Count.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="8" Grid.Column="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="64"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" HorizontalAlignment="Stretch" Value="{Binding BraveSearchCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding BraveSearchCount}" Style="{StaticResource PreferenceValueStyle}"/>
                        </Grid>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Brave.Count.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource Search.Brave.Freshness.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="10" Grid.Column="1">
                        <ComboBox ItemsSource="{Binding BraveSearchFreshnessOptions}" SelectedItem="{Binding BraveSearchFreshness, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Brave.Freshness.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Tavily Search 配置段 -->
            <StackPanel Visibility="{Binding IsTavilySelected, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="#20FFFFFF" Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource Search.Tavily.Title}" Style="{StaticResource PreferenceSectionTitleStyle}" Margin="0,0,0,12"/>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Search.Tavily.ApiKey.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBox Text="{Binding TavilyApiKey, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Tavily.ApiKey.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Search.Tavily.SearchDepth.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <ComboBox ItemsSource="{Binding TavilySearchDepthOptions}" SelectedItem="{Binding TavilySearchDepth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Tavily.SearchDepth.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Search.Tavily.IncludeAnswer.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="4" Grid.Column="1">
                        <CheckBox IsChecked="{Binding TavilyIncludeAnswer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Content="{DynamicResource Search.Tavily.IncludeAnswer.Content}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Tavily.IncludeAnswer.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Search.Tavily.Topic.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="6" Grid.Column="1">
                        <ComboBox ItemsSource="{Binding TavilyTopicOptions}" SelectedItem="{Binding TavilyTopic, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Tavily.Topic.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource Search.Tavily.MaxResults.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="8" Grid.Column="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="64"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="20" TickFrequency="1" IsSnapToTickEnabled="True" HorizontalAlignment="Stretch" Value="{Binding TavilyMaxResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding TavilyMaxResults}" Style="{StaticResource PreferenceValueStyle}"/>
                        </Grid>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Tavily.MaxResults.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource Search.Tavily.IncludeImages.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="10" Grid.Column="1">
                        <CheckBox IsChecked="{Binding TavilyIncludeImages, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Content="{DynamicResource Search.Tavily.IncludeImages.Content}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Tavily.IncludeImages.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="12" Grid.Column="0" Text="{DynamicResource Search.Tavily.IncludeRawContent.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="12" Grid.Column="1">
                        <CheckBox IsChecked="{Binding TavilyIncludeRawContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Content="{DynamicResource Search.Tavily.IncludeRawContent.Content}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Tavily.IncludeRawContent.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- Vertex AI Search 配置段 -->
            <StackPanel Visibility="{Binding IsVertexAiSearchSelected, Converter={StaticResource BoolToVis}}">
                <Border Height="1" Background="#20FFFFFF" Margin="0,0,0,12"/>
                <TextBlock Text="{DynamicResource Search.Vertex.Title}" Style="{StaticResource PreferenceSectionTitleStyle}" Margin="0,0,0,12"/>
                
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Search.Vertex.ProjectId.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBox Text="{Binding VertexAiProjectId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Vertex.ProjectId.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource Search.Vertex.Location.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="2" Grid.Column="1">
                        <TextBox Text="{Binding VertexAiLocation, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Vertex.Location.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{DynamicResource Search.Vertex.DataStoreId.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="4" Grid.Column="1">
                        <TextBox Text="{Binding VertexAiDataStoreId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Vertex.DataStoreId.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="{DynamicResource Search.Vertex.CredentialsJson.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="6" Grid.Column="1">
                        <TextBox AcceptsReturn="True" Height="80" VerticalScrollBarVisibility="Auto" Text="{Binding VertexAiCredentialsJson, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Vertex.CredentialsJson.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="{DynamicResource Search.Vertex.ApiKey.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="8" Grid.Column="1">
                        <TextBox Text="{Binding VertexAiApiKey, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Vertex.ApiKey.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="{DynamicResource Search.Vertex.MaxResults.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="10" Grid.Column="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="64"/>
                            </Grid.ColumnDefinitions>
                            <Slider Grid.Column="0" Minimum="1" Maximum="100" TickFrequency="1" IsSnapToTickEnabled="True" HorizontalAlignment="Stretch" Value="{Binding VertexAiMaxResults, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center" Text="{Binding VertexAiMaxResults}" Style="{StaticResource PreferenceValueStyle}"/>
                        </Grid>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Vertex.MaxResults.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>

                    <TextBlock Grid.Row="12" Grid.Column="0" Text="{DynamicResource Search.Vertex.SearchModel.Label}" Style="{StaticResource PreferenceLabelStyle}"/>
                    <StackPanel Grid.Row="12" Grid.Column="1">
                        <ComboBox ItemsSource="{Binding VertexAiSearchModelOptions}" SelectedItem="{Binding VertexAiSearchModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Margin="0,6,0,0" Text="{DynamicResource Search.Vertex.SearchModel.Hint}" Style="{StaticResource PreferenceMetaStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>

            <!-- 底部分隔线 -->
            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <!-- 配置文件状态 -->
            <TextBlock Margin="0,18,0,0"
                        Text="{DynamicResource Common.ConfigurationStatus}"
                        Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{DynamicResource Common.ConfigurationFile}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding ConfigurationFilePath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="{DynamicResource Common.RecentStatus}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource PreferenceValueStyle}"/>
            </Grid>

            <!-- 操作按钮 -->
            <StackPanel Margin="0,16,0,0"
                         Orientation="Horizontal">
                <Button MinWidth="132"
                        Content="{DynamicResource Common.OpenConfigurationDirectory}"
                        Command="{Binding OpenConfigurationDirectoryCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
