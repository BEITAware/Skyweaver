<UserControl x:Class="Ferrita.Controls.ChatSessionControl.Views.PlanItemCheckInvocationCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Ferrita.Controls.ChatSessionControl.Views"
             mc:Ignorable="d" 
             d:DesignHeight="38" d:DesignWidth="300"
             VerticalAlignment="Top"
             HorizontalAlignment="Left">
    <Border MinWidth="220"
            MaxWidth="450"
            Height="38"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="{DynamicResource MediaResourceCardBackgroundBrush}"
            BorderBrush="#6793F2FF"
            BorderThickness="1"
            CornerRadius="6">
        <Grid>
            <!-- 水印图 -->
            <Image Source="pack://application:,,,/Ferrita;component/Resources/DocumentCardBackgroundSheen.png"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Opacity="0.12"
                   Stretch="None"
                   IsHitTestVisible="False">
                <Image.RenderTransform>
                    <MatrixTransform Matrix="0.25,-0.06,0.06,0.25,-0.00064,2"/>
                </Image.RenderTransform>
            </Image>

            <!-- 顶部微光高光，填充整个 Border 空间，CornerRadius 与外框微调匹配 -->
            <Border Background="{DynamicResource MediaResourceCardTopSheenBrush}"
                    CornerRadius="5"
                    Margin="1"
                    IsHitTestVisible="False"/>

            <!-- 对角线反射高光，填充整个 Border 空间，CornerRadius 与外框微调匹配 -->
            <Border Background="{DynamicResource MediaResourceCardHighlightBrush}"
                    Opacity="0.8"
                    CornerRadius="5"
                    Margin="1"
                    IsHitTestVisible="False"/>

            <!-- 内容层：在此处应用 Margin，避免高光背景层因 Padding 被截断 -->
            <Grid VerticalAlignment="Center" Margin="10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 图标：圆底打勾图标 -->
                <Grid Width="18" Height="18" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <!-- 玻璃感底座 -->
                    <Border Background="#22FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="9"/>
                    <!-- 绿色的勾 -->
                    <Path Data="M 4,9 L 7,12 L 14,5" 
                          Stroke="#FF7BF1A8" 
                          StrokeThickness="1.8" 
                          StrokeStartLineCap="Round" 
                          StrokeEndLineCap="Round" 
                          StrokeLineJoin="Round"
                          HorizontalAlignment="Center" 
                          VerticalAlignment="Center"
                          Width="10" Height="8"
                          Stretch="Uniform"/>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="{Binding PlanNameDisplay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="#FFAAD7FF"
                               FontWeight="Normal"
                               FontSize="9"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding ItemNameDisplay, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               Foreground="#FFF6FEFF"
                               FontWeight="Bold"
                               FontSize="11"
                               Margin="0,0,0,0"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
