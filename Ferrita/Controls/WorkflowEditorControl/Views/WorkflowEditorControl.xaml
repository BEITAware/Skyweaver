<UserControl x:Class="Ferrita.Controls.WorkflowEditorControl.Views.WorkflowEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Ferrita.Controls.WorkflowEditorControl.Models"
             xmlns:viewModels="clr-namespace:Ferrita.Controls.WorkflowEditorControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:WorkflowEditorControlViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="620"
             d:DesignWidth="920"
             Focusable="True"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display">
    <UserControl.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="WorkflowSurfaceBaseBrush" Color="#1F3449"/>

            <DrawingBrush x:Key="WorkflowSurfaceMinorGridBrush"
                          TileMode="Tile"
                          Viewport="0,0,1,4"
                          ViewportUnits="Absolute"
                          Stretch="None">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <!-- 基础色条纹 -->
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,1"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Brush>
                                <SolidColorBrush Color="#1F3449"/>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                        <!-- 深色条纹 -->
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,1,1,1"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Brush>
                                <SolidColorBrush Color="#010303"/>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <SolidColorBrush x:Key="WorkflowSurfaceMajorGridBrush" Color="Transparent"/>

            <SolidColorBrush x:Key="WorkflowSurfaceGlowBrush" Color="Transparent"/>

            <LinearGradientBrush x:Key="WorkflowNodeBodyBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#F3162738" Offset="0"/>
                <GradientStop Color="#ED0D1825" Offset="0.56"/>
                <GradientStop Color="#F3071018" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowNodeHeaderBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#F0738CA4" Offset="0"/>
                <GradientStop Color="#D52E4E6E" Offset="0.62"/>
                <GradientStop Color="#DD162A40" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowNodeFooterBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#FF132030" Offset="0"/>
                <GradientStop Color="#FF0C141E" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowPanelBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#F21A2B3E" Offset="0"/>
                <GradientStop Color="#F10D1722" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowPanelHeaderBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#E36A8AA9" Offset="0"/>
                <GradientStop Color="#C52F4F6E" Offset="0.66"/>
                <GradientStop Color="#C41B3044" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="WorkflowNodeTextBrush" Color="#FFF5FBFF"/>
            <SolidColorBrush x:Key="WorkflowNodeMutedTextBrush" Color="#D8E8F4FF"/>
            <SolidColorBrush x:Key="WorkflowNodeFooterTextBrush" Color="#CCE5F5FF"/>
            <SolidColorBrush x:Key="WorkflowNodeDividerBrush" Color="#35516A82"/>
            <SolidColorBrush x:Key="WorkflowPortGuideBrush" Color="#45698299"/>

            <Style x:Key="WorkflowNodeCardStyle" TargetType="Border">
                <Setter Property="Width" Value="{Binding Width}"/>
                <Setter Property="Height" Value="180"/>
                <Setter Property="MinHeight" Value="180"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="BorderThickness" Value="1.8"/>
                <Setter Property="Opacity" Value="0.95"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="BorderBrush">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#C0FFFFFF" Offset="0"/>
                            <GradientStop Color="#80FFFFFF" Offset="0.5"/>
                            <GradientStop Color="#40000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#60000000"
                                          Direction="315"
                                          ShadowDepth="6"
                                          BlurRadius="12"
                                          Opacity="0.8"/>
                    </Setter.Value>
                </Setter>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#4A90E2" Offset="0"/>
                            <GradientStop Color="#4A90E2" Offset="0.4"/>
                            <GradientStop Color="#F8FCFF" Offset="0.6"/>
                            <GradientStop Color="#FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsInputOutputNode}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4A90E2" Offset="0"/>
                                    <GradientStop Color="#4A90E2" Offset="0.4"/>
                                    <GradientStop Color="#F8FCFF" Offset="0.6"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsAgentNode}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#00ACC1" Offset="0"/>
                                    <GradientStop Color="#00ACC1" Offset="0.4"/>
                                    <GradientStop Color="#F8FCFF" Offset="0.6"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicNode}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#4CAF50" Offset="0"/>
                                    <GradientStop Color="#4CAF50" Offset="0.4"/>
                                    <GradientStop Color="#F8FCFF" Offset="0.6"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicExecutionNode}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#8E24AA" Offset="0"/>
                                    <GradientStop Color="#8E24AA" Offset="0.4"/>
                                    <GradientStop Color="#F8FCFF" Offset="0.6"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsNextLogicExecutionNode}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#E65100" Offset="0"/>
                                    <GradientStop Color="#E65100" Offset="0.4"/>
                                    <GradientStop Color="#F8FCFF" Offset="0.6"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsContextInjectionNode}" Value="True">
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#0097A7" Offset="0"/>
                                    <GradientStop Color="#0097A7" Offset="0.4"/>
                                    <GradientStop Color="#F0FCFF" Offset="0.6"/>
                                    <GradientStop Color="#FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Opacity" Value="1.0"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowNodeSelectionFrameStyle" TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Style>

            <Style x:Key="WorkflowNodeAccentBandStyle" TargetType="Border">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Style>

            <Style x:Key="WorkflowNodeKindBadgeStyle" TargetType="Border">
                <Setter Property="Padding" Value="6,2"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#40FFFFFF"/>
                <Setter Property="Background" Value="#20000000"/>
                <Setter Property="CornerRadius" Value="8"/>
            </Style>

            <Style x:Key="WorkflowNodePortsPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
            </Style>

            <Style x:Key="WorkflowPortAnchorStyle" TargetType="Ellipse">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="14"/>
                <Setter Property="Margin" Value="2,6,2,6"/>
                <Setter Property="Fill">
                    <Setter.Value>
                        <RadialGradientBrush>
                            <GradientStop Color="#FFFFFF" Offset="0"/>
                            <GradientStop Color="#F0F8FF" Offset="0.3"/>
                            <GradientStop Color="#E0E8F0" Offset="0.7"/>
                            <GradientStop Color="#C0D0E0" Offset="1"/>
                        </RadialGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Stroke">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#8090A0" Offset="0"/>
                            <GradientStop Color="#606070" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="StrokeThickness" Value="1.2"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="IsHitTestVisible" Value="True"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#40000000"
                                        Direction="315"
                                        ShadowDepth="2"
                                        BlurRadius="4"
                                        Opacity="0.7"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsXmlFieldPort}" Value="True">
                        <Setter Property="Fill">
                            <Setter.Value>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#FFF2C67F" Offset="0.5"/>
                                    <GradientStop Color="#FFB06F28" Offset="1"/>
                                </RadialGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsFlexiblePort}" Value="True">
                        <Setter Property="Fill">
                            <Setter.Value>
                                <RadialGradientBrush>
                                    <GradientStop Color="#FFFFFF" Offset="0"/>
                                    <GradientStop Color="#FFB9E1CF" Offset="0.5"/>
                                    <GradientStop Color="#FF4E886D" Offset="1"/>
                                </RadialGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#80000000"
                                                Direction="315"
                                                ShadowDepth="3"
                                                BlurRadius="6"
                                                Opacity="0.9"/>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="StrokeThickness" Value="1.8"/>
                        <Setter Property="Width" Value="16"/>
                        <Setter Property="Height" Value="16"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- Removed unused port glyph styles to match Tunnel-Next 1:1 -->

            <Style x:Key="WorkflowConnectionShadowPathStyle" TargetType="Path">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Style>

            <Style x:Key="WorkflowConnectionBasePathStyle" TargetType="Path">
                <Setter Property="StrokeThickness" Value="4"/>
                <Setter Property="StrokeStartLineCap" Value="Round"/>
                <Setter Property="StrokeEndLineCap" Value="Round"/>
                <Setter Property="Opacity" Value="0.9"/>
                <Setter Property="Stroke">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FF4A90E2" Offset="0"/>
                            <GradientStop Color="#C84A90E2" Offset="0.5"/>
                            <GradientStop Color="#FF4A90E2" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#64000000" Direction="315" ShadowDepth="2" BlurRadius="4" Opacity="0.6"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsXmlConnection}" Value="True">
                        <Setter Property="Stroke">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFFFA500" Offset="0"/>
                                    <GradientStop Color="#C8FFA500" Offset="0.5"/>
                                    <GradientStop Color="#FFFFA500" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowConnectionHighlightPathStyle" TargetType="Path">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Style>

            <Style x:Key="WorkflowConnectionMarkerStyle" TargetType="Rectangle">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Style>

            <Style x:Key="WorkflowConnectionSourceMarkerStyle"
                   TargetType="Rectangle"
                   BasedOn="{StaticResource WorkflowConnectionMarkerStyle}">
                <Setter Property="Width" Value="6"/>
                <Setter Property="Height" Value="6"/>
            </Style>

            <Style x:Key="WorkflowConnectionTargetMarkerStyle"
                   TargetType="Rectangle"
                   BasedOn="{StaticResource WorkflowConnectionMarkerStyle}">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Height" Value="8"/>
            </Style>

            <Style x:Key="ConfigurationListViewStyle"
                   TargetType="ListView"
                   BasedOn="{StaticResource AeroListViewStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="6"/>
            </Style>

            <Style x:Key="ConfigurationListViewItemStyle"
                   TargetType="ListViewItem"
                   BasedOn="{StaticResource AeroListViewItemStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid>
                                <Border x:Name="HoverOverlay"
                                        Background="{StaticResource MenuItemHoverBrush}"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <Border x:Name="SelectedOverlay"
                                        Background="{StaticResource MenuItemClickedBrush}"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" TargetName="HoverOverlay" Value="0.2"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Opacity" TargetName="SelectedOverlay" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GlassCardBorderStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource ChatSessionHeaderBorderStyle}">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="12,10"/>
            </Style>

            <Style x:Key="CapsuleBorderStyle"
                   TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="MinWidth" Value="58"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="Margin" Value="0,0,6,6"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

                <Border Grid.Row="0"
                BorderBrush="#33000000"
                BorderThickness="0,0,0,1"
                Background="#08000000">
            <Grid MinHeight="36" Margin="10,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="{Binding Title}"
                           Foreground="White" FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="AddNodeMenuButton"
                            Style="{DynamicResource RibbonButtonStyle}"
                            ToolTip="添加节点"
                            Click="AddNodeMenuButton_Click"
                            Padding="8,4" Margin="0,0,8,0">
                        <Button.ContextMenu>
                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="&#20195;&#29702;&#33410;&#28857;"
                                                          ItemsSource="{Binding AvailableAgents}"
                                                          ToolTip="&#24748;&#20572;&#20197;&#36873;&#25321;&#20855;&#20307;&#20195;&#29702;">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="AI"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF2FCFF"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="{x:Type MenuItem}"
                                                               BasedOn="{StaticResource AnimatedMenuItemStyle}">
                                                            <Setter Property="Header"
                                                                    Value="{Binding DisplayText}"/>
                                                            <Setter Property="InputGestureText"
                                                                    Value="{Binding PortTypeSummaryText}"/>
                                                            <Setter Property="ToolTip"
                                                                    Value="{Binding MenuDescription}"/>
                                                            <Setter Property="Command"
                                                                    Value="{Binding DataContext.AddAgentNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <Setter Property="CommandParameter"
                                                                    Value="{Binding}"/>
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="&#36923;&#36753;&#19982;"
                                                          Command="{Binding AddLogicAndNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="AND"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#36923;&#36753;&#25110;"
                                                          Command="{Binding AddLogicOrNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="OR"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#36923;&#36753;&#24322;&#25110;"
                                                          Command="{Binding AddLogicXorNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="XOR"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#36923;&#36753;&#38750;"
                                                          Command="{Binding AddLogicNotNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="NOT"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="&#36923;&#36753;&#25191;&#34892;"
                                                          Command="{Binding AddLogicExecutionNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="RUN"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFE9FDFF"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#20165;&#19979;&#19968;&#20010;&#36923;&#36753;&#25191;&#34892;"
                                                          Command="{Binding AddNextLogicExecutionNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="N+1"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFE9FDEB"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="&#27880;&#20837;&#19978;&#19979;&#25991;"
                                                          Command="{Binding AddContextInjectionNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="CTX"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFD0F0FF"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                        </Button.ContextMenu>
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Resources/add_node.png" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="添加节点" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource RibbonButtonStyle}"
                            ToolTip="删除选中节点"
                            Command="{Binding DeleteSelectedNodeCommand}"
                            Padding="8,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Resources/delete_node.png" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="删除节点" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource RibbonButtonStyle}"
                            ToolTip="保存"
                            Command="{Binding SaveCommand}"
                            Padding="8,4" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Resources/save.png" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="保存" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource RibbonButtonStyle}"
                            ToolTip="打开目录"
                            Command="{Binding OpenConfigurationDirectoryCommand}"
                            Padding="8,4">
                        <StackPanel Orientation="Horizontal">
                            <Image Source="pack://application:,,,/Resources/WorkFolder.png" Width="16" Height="16" Margin="0,0,4,0"/>
                            <TextBlock Text="打开目录" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="1"
                Background="#18000000"
                BorderBrush="#33000000"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#36830;&#25509;&#29366;&#24577;"
                               Margin="0,0,10,0"
                               Foreground="#88FFFFFF"/>
                    <TextBlock Text="{Binding PendingConnectionText}"
                               Foreground="#D7F3FF"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="#FFE9FFD0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="200"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="2"
                    Margin="8,0,8,8"
                    BorderBrush="#5B89AAC1"
                    BorderThickness="1"
                    Background="#18000000">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="Both"
                          CanContentScroll="False">
                <Grid x:Name="EditorSurface"
                      Width="{Binding CanvasWidth}"
                      Height="{Binding CanvasHeight}"
                      MouseLeftButtonDown="SurfaceBackground_MouseLeftButtonDown">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding SurfaceScale}"
                                        ScaleY="{Binding SurfaceScale}"/>
                    </Grid.LayoutTransform>

                    <Grid Panel.ZIndex="0"
                          IsHitTestVisible="False">
                        <Border Background="{StaticResource WorkflowSurfaceBaseBrush}"/>
                        <Border Background="{StaticResource WorkflowSurfaceGlowBrush}"
                                Opacity="0.9"/>
                        <Border Background="{StaticResource WorkflowSurfaceMinorGridBrush}"
                                Opacity="0.95"/>
                        <Border Background="{StaticResource WorkflowSurfaceMajorGridBrush}"
                                Opacity="0.95"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Connections}"
                                  IsHitTestVisible="False"
                                  Panel.ZIndex="1">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SessionFlowConnectionModel}">
                                <Canvas Width="{Binding ElementName=EditorSurface, Path=ActualWidth}"
                                        Height="{Binding ElementName=EditorSurface, Path=ActualHeight}">
                                    <Path Data="{Binding PathData}"
                                          Style="{StaticResource WorkflowConnectionShadowPathStyle}"/>
                                    <Path Data="{Binding PathData}"
                                          Style="{StaticResource WorkflowConnectionBasePathStyle}"/>
                                    <Path Data="{Binding PathData}"
                                          Style="{StaticResource WorkflowConnectionHighlightPathStyle}"/>

                                    <Rectangle Style="{StaticResource WorkflowConnectionSourceMarkerStyle}"
                                               Canvas.Left="{Binding SourceX}"
                                               Canvas.Top="{Binding SourceY}">
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform X="-3"
                                                                Y="-3"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>

                                    <Rectangle Style="{StaticResource WorkflowConnectionTargetMarkerStyle}"
                                               Canvas.Left="{Binding TargetX}"
                                               Canvas.Top="{Binding TargetY}">
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform X="-4"
                                                                Y="-4"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Nodes}"
                                  Panel.ZIndex="2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SessionFlowNodeModel}">
                                <Grid ClipToBounds="False">
                                    <Grid.RenderTransform>
                                        <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                                    </Grid.RenderTransform>
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                             From="0.3" To="1.0" Duration="0:0:0.45">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <BackEase Amplitude="0.75" EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                             From="0.3" To="1.0" Duration="0:0:0.45">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <BackEase Amplitude="0.75" EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="0.0" To="1.0" Duration="0:0:0.3"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>

                                    <!-- 选中与高亮外框发光效果 -->
                                    <Border Margin="-3"
                                            CornerRadius="14"
                                            BorderThickness="2.2"
                                            Background="Transparent"
                                            IsHitTestVisible="False"
                                            Panel.ZIndex="5">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#C000E5FF"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0" Opacity="0.95"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="BorderBrush" Value="#FFFFFFFF"/>
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect Color="#FF00FF88" BlurRadius="18" ShadowDepth="0" Opacity="0.95"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Border Style="{StaticResource WorkflowNodeCardStyle}"
                                            MouseLeftButtonDown="NodeCard_MouseLeftButtonDown"
                                            MouseLeftButtonUp="NodeCard_MouseLeftButtonUp"
                                            MouseMove="NodeCard_MouseMove">
                                        <Grid ClipToBounds="True">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="38"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 图层 1：全局高光磨砂玻璃层 - 完美移植 Tunnel Aero 质感 -->
                                            <Border Grid.RowSpan="3"
                                                    CornerRadius="10"
                                                    BorderThickness="0"
                                                    Opacity="0.75"
                                                    IsHitTestVisible="False"
                                                    Panel.ZIndex="1">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,0.5">
                                                        <GradientStop Color="#C0FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#90FFFFFF" Offset="0.25"/>
                                                        <GradientStop Color="#60FFFFFF" Offset="0.5"/>
                                                        <GradientStop Color="#30FFFFFF" Offset="0.75"/>
                                                        <GradientStop Color="Transparent" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="1.5" KernelType="Gaussian"/>
                                                </Border.Effect>
                                            </Border>

                                            <!-- 图层 2：标题栏精致高斯模糊磨砂层 -->
                                            <Border Grid.Row="0"
                                                    CornerRadius="10,10,0,0"
                                                    IsHitTestVisible="False"
                                                    Panel.ZIndex="2">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#80FFFFFF" Offset="0"/>
                                                        <GradientStop Color="#50FFFFFF" Offset="0.5"/>
                                                        <GradientStop Color="#20FFFFFF" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Effect>
                                                    <BlurEffect Radius="0.5" KernelType="Gaussian"/>
                                                </Border.Effect>
                                            </Border>

                                            <!-- 图层 3：业务逻辑内容容器 (放置于最顶层，ZIndex=3) -->
                                            <Grid Grid.RowSpan="3" Panel.ZIndex="3">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="38"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Header -->
                                                <Border Grid.Row="0"
                                                        CornerRadius="10,10,0,0"
                                                        Padding="8,5"
                                                        Margin="0">
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="White"
                                                               FontWeight="SemiBold"
                                                               FontSize="12"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Effect>
                                                            <DropShadowEffect Color="#80000000"
                                                                              Direction="270"
                                                                              ShadowDepth="1.5"
                                                                              BlurRadius="3"
                                                                              Opacity="0.9"/>
                                                        </TextBlock.Effect>
                                                    </TextBlock>
                                                </Border>

                                                <!-- Ports -->
                                                <Grid Grid.Row="1" Margin="14,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Inputs -->
                                                    <ItemsControl Grid.Column="0"
                                                                  ItemsSource="{Binding InputPorts}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,2">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type models:SessionFlowPortModel}">
                                                                <Ellipse Style="{StaticResource WorkflowPortAnchorStyle}"
                                                                         ToolTip="{Binding Name}"
                                                                         MouseLeftButtonDown="PortAnchor_MouseLeftButtonDown"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <Grid Grid.Column="1" Margin="4,0">
                                                        <!-- Central content placeholder -->
                                                    </Grid>

                                                    <!-- Outputs -->
                                                    <ItemsControl Grid.Column="2"
                                                                  ItemsSource="{Binding OutputPorts}"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,2">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type models:SessionFlowPortModel}">
                                                                <Ellipse Style="{StaticResource WorkflowPortAnchorStyle}"
                                                                         ToolTip="{Binding Name}"
                                                                         MouseLeftButtonDown="PortAnchor_MouseLeftButtonDown"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>

                                                <!-- Footer -->
                                                <Border Grid.Row="2"
                                                        Background="Transparent"
                                                        BorderBrush="#10000000"
                                                        BorderThickness="0,1,0,0"
                                                        Padding="10,5">
                                                    <TextBlock Text="{Binding PortSummaryText}"
                                                               Foreground="#FF4E5F70"
                                                               FontFamily="{DynamicResource AeroFontFamily}"
                                                               FontSize="{DynamicResource AeroSmallFontSize}"
                                                               FontWeight="SemiBold"/>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </Grid>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1"
                      HorizontalAlignment="Stretch"
                      Style="{DynamicResource AeroVerticalSplitterStyle}"
                      Background="Transparent"/>

        <Border Grid.Column="0"
                Margin="8,0,0,8"
                BorderBrush="#5B89AAC1"
                BorderThickness="1"
                Background="{DynamicResource DocumentTabBackgroundBrush}">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,12">
                    <TextBlock Text="{DynamicResource WorkflowEditor.GraphLibrary.Title}"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#D7EDFF"
                               Text="{Binding NodeGraphLibrarySummaryText}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                    <Button Command="{Binding CreateNodeGraphCommand}" ToolTip="{DynamicResource Common.Create}" Margin="0,0,4,0" Padding="4">
                        <Image Source="pack://application:,,,/Resources/add_node.png" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding OpenSelectedNodeGraphCommand}" ToolTip="{DynamicResource Common.Open}" Margin="0,0,4,0" Padding="4">
                        <Image Source="pack://application:,,,/Resources/add_node.png" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding SaveCommand}" ToolTip="{DynamicResource Common.Save}" Margin="0,0,4,0" Padding="4">
                        <Image Source="pack://application:,,,/Resources/save.png" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding RenameSelectedNodeGraphCommand}" ToolTip="{DynamicResource Common.Rename}" Margin="0,0,4,0" Padding="4">
                        <Image Source="pack://application:,,,/Resources/add_node.png" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding DeleteSelectedNodeGraphCommand}" ToolTip="{DynamicResource Common.Delete}" Margin="0,0,4,0" Padding="4">
                        <Image Source="pack://application:,,,/Resources/delete_node.png" Width="16" Height="16"/>
                    </Button>
                    <Button Command="{Binding RefreshNodeGraphLibraryCommand}" ToolTip="{DynamicResource Common.Refresh}" Margin="0,0,4,0" Padding="4">
                        <Image Source="pack://application:,,,/Resources/add_node.png" Width="16" Height="16"/>
                    </Button>
                </StackPanel>

                <Border Grid.Row="2"
                        CornerRadius="2"
                        BorderThickness="1"
                        Padding="4"
                        SnapsToDevicePixels="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.10059,1.65236"
                                             EndPoint="2.53982,1.65236"
                                             Opacity="0.5">
                            <LinearGradientBrush.RelativeTransform>
                                <TransformGroup>
                                    <SkewTransform CenterX="0.10059"
                                                   CenterY="1.65236"
                                                   AngleX="-59.7491"
                                                   AngleY="0"/>
                                    <RotateTransform CenterX="0.10059"
                                                     CenterY="1.65236"
                                                     Angle="-70.8836"/>
                                </TransformGroup>
                            </LinearGradientBrush.RelativeTransform>
                            <GradientStop Color="#3BFFFFFF" Offset="0"/>
                            <GradientStop Color="#1DFFFFFF" Offset="0.0766283"/>
                            <GradientStop Color="#07FFFFFF" Offset="0.109195"/>
                            <GradientStop Color="#04FFFFFF" Offset="0.298851"/>
                            <GradientStop Color="#3AFFFFFF" Offset="0.327586"/>
                            <GradientStop Color="#1AFFFFFF" Offset="0.465517"/>
                            <GradientStop Color="#14FFFFFF" Offset="0.591954"/>
                            <GradientStop Color="#05FFFFFF" Offset="0.758621"/>
                            <GradientStop Color="#44FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#40000000"/>
                    </Border.BorderBrush>

                    <ListView x:Name="NodeGraphListView"
                              ItemsSource="{Binding NodeGraphs}"
                              SelectedItem="{Binding SelectedNodeGraph}"
                              MouseDoubleClick="NodeGraphListView_MouseDoubleClick"
                              Style="{StaticResource ConfigurationListViewStyle}"
                              ItemContainerStyle="{StaticResource ConfigurationListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SessionFlowGraphListItemModel}">
                                <Border Style="{StaticResource GlassCardBorderStyle}" Padding="8,4" Margin="0,0,0,4">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Width="16" Height="16" Source="pack://application:,,,/Resources/Nodegraph.png" Margin="0,0,8,0"/>
                                        <TextBlock Text="{Binding Name}" FontSize="13" VerticalAlignment="Center" Foreground="#D9FFFFFF"/>
                                        <Border Margin="8,0,0,0" Padding="4,1" Background="#33000000" CornerRadius="4" Visibility="{Binding IsCurrent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <TextBlock FontSize="10" Foreground="#FFF3FCFF" Text="{DynamicResource WorkflowEditor.GraphLibrary.CurrentOpen}" VerticalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,12,0,0"
                        Style="{StaticResource GlassCardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Foreground="#D9FFFFFF"
                                       Text="{DynamicResource WorkflowEditor.GraphLibrary.Directory}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#D9FFFFFF"
                                       Text="{Binding ConfigurationDirectoryPath}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FFD3F6FF"
                                       Text="{DynamicResource WorkflowEditor.GraphLibrary.CurrentFile}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#FFD3F6FF"
                                       Text="{Binding PersistenceFilePath}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="132"
                                Margin="12,0,0,0"
                                Command="{Binding OpenConfigurationDirectoryCommand}"
                                Content="{DynamicResource WorkflowEditor.GraphLibrary.OpenDirectory}"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="3"
                      HorizontalAlignment="Stretch"
                      Style="{DynamicResource AeroVerticalSplitterStyle}"
                      Background="Transparent"
                      Visibility="Visible"/>

        <Border Grid.Column="4"
                Width="330"
                Margin="0,0,8,8"
                Visibility="Visible"
                BorderBrush="#739AB8CD"
                BorderThickness="1"
                Background="{StaticResource WorkflowPanelBrush}">
                        <Grid>
                            <Border Height="1"
                                    VerticalAlignment="Top"
                                    Background="#55FFFFFF"
                                    IsHitTestVisible="False"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{StaticResource WorkflowPanelHeaderBrush}"
                                        BorderBrush="#324A6378"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,6">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Style="{DynamicResource SmallWindowButtonStyle}"
                                                Content="&#x00D7;"
                                                Command="{Binding ClearSelectionCommand}"/>
                                        <TextBlock Text="{Binding InspectorTitle}"
                                                   Foreground="{StaticResource WorkflowNodeTextBrush}"
                                                   FontFamily="{DynamicResource AeroFontFamily}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <StackPanel Grid.Row="1"
                                            Margin="10">
                                    <TextBlock Text="{Binding SelectedNodeKindHint}"
                                               TextWrapping="Wrap"
                                               Foreground="#D8EFFBFF"/>

                                    <StackPanel Margin="0,10,0,0"
                                                Visibility="{Binding IsSelectedNodeAgent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <CheckBox Content="&#26159;&#21542;&#20026;&#38544;&#34255;&#20195;&#29702;"
                                                  IsChecked="{Binding SelectedNode.IsHiddenAgent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,10,0,0"
                                                Visibility="{Binding IsSelectedNodeLogicExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="&#26032;&#22686;&#36879;&#20256;&#36755;&#20837;"
                                                   Foreground="#D8EFFBFF"/>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,6,0,0">
                                            <Button Style="{DynamicResource RibbonButtonStyle}"
                                                    Padding="8,3"
                                                    Margin="0,0,6,0"
                                                    Command="{Binding AddExecutionNaturalLanguageInputCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="10"
                                                             Height="10"
                                                             Margin="0,0,6,0"
                                                             VerticalAlignment="Center"
                                                             Stroke="#FFF2FCFF"
                                                             StrokeThickness="1">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush MappingMode="RelativeToBoundingBox"
                                                                                 Center="0.35,0.35"
                                                                                 GradientOrigin="0.35,0.35">
                                                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#FF7EE3FF" Offset="0.36"/>
                                                                <GradientStop Color="#FF22BFE9" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="&#33258;&#28982;&#35821;&#35328;"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Style="{DynamicResource RibbonButtonStyle}"
                                                    Padding="8,3"
                                                    Command="{Binding AddExecutionXmlInputCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Rectangle Width="10"
                                                               Height="10"
                                                               Margin="0,0,6,0"
                                                               VerticalAlignment="Center"
                                                               Stroke="#FFFFF3D8"
                                                               StrokeThickness="1"
                                                               RenderTransformOrigin="0.5,0.5">
                                                        <Rectangle.Fill>
                                                            <RadialGradientBrush MappingMode="RelativeToBoundingBox"
                                                                                 Center="0.35,0.35"
                                                                                 GradientOrigin="0.35,0.35">
                                                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#FFF3D28D" Offset="0.34"/>
                                                                <GradientStop Color="#FFBE8731" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Rectangle.Fill>
                                                        <Rectangle.RenderTransform>
                                                            <RotateTransform Angle="45"/>
                                                        </Rectangle.RenderTransform>
                                                    </Rectangle>
                                                    <TextBlock Text="{DynamicResource WorkflowEditor.XmlField}"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 注入上下文节点设置面板 -->
                                    <StackPanel Margin="0,10,0,0"
                                                Visibility="{Binding IsSelectedNodeContextInjection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="角色"
                                                   Foreground="#D8EFFBFF"
                                                   Margin="0,0,0,4"/>
                                        <ComboBox ItemsSource="{Binding AvailableContextInjectionRoles}"
                                                  SelectedItem="{Binding SelectedNode.ContextInjectionRole, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Margin="0,0,0,10"/>
                                        <TextBlock Text="内容"
                                                   Foreground="#D8EFFBFF"
                                                   Margin="0,0,0,4"/>
                                        <TextBox Text="{Binding SelectedNode.ContextInjectionContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"
                                                 MinHeight="80"
                                                 MaxHeight="200"
                                                 VerticalScrollBarVisibility="Auto"/>
                                    </StackPanel>

                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="#B3E5F6FF"
                                               TextWrapping="Wrap"
                                               Text="{Binding PersistenceFilePath}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
        </Grid>
    </Grid>
</UserControl>
