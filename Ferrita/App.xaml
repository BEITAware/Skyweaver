<Application x:Class="Ferrita.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Ferrita"
             xmlns:converters="clr-namespace:Ferrita.Converters"
             Startup="Application_Startup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Ferrita;component/Resources/AppResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- 通用转换器 -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:BoolToSelectionBrushConverter x:Key="BoolToSelectionBrushConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
