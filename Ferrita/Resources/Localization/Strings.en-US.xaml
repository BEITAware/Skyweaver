    <system:String x:Key="Memory.Enable.Label">Enable Memory</system:String>
    <system:String x:Key="Memory.Enable.Hint">Enable Ferrita memory mechanism: agents can remember your past conversation content. Memory is not 100% reliable.</system:String>
    <system:String x:Key="Memory.ShareScope.Label">Memory Sharing Scope</system:String>
    <system:String x:Key="Memory.ShareScope.Hint">Select the sharing scope of memory data across sessions/agents:
- SessionFlow: Only shared within the current session flow.
- Agent: Shared across all session flows of the same agent.
- Application: Globally shared across all agents and sessions in the entire application.</system:String>
    <system:String x:Key="Memory.ShareScope.SessionFlow">Session Flow</system:String>
    <system:String x:Key="Memory.ShareScope.Agent">Agent</system:String>
    <system:String x:Key="Memory.ShareScope.Application">Application</system:String>
    <system:String x:Key="Memory.RetrievalCount.Label">Memory Retrieval Count</system:String>
    <system:String x:Key="Memory.RetrievalCount.Hint">Set the number of historical memories to retrieve from the memory store each time.</system:String>
    <system:String x:Key="Memory.Status.MemoryEnabledSaved">Enable Memory setting saved.</system:String>
    <system:String x:Key="Memory.Status.ShareScopeSaved">Memory sharing scope saved.</system:String>
