    <system:String x:Key="LateralFileSystem.Section.Constraints">Constraints</system:String>
    <system:String x:Key="LateralFileSystem.Instruction.1">1. All virtualization roots must live under the working root directory.</system:String>
    <system:String x:Key="LateralFileSystem.Instruction.2">2. LateralFileSystemTree.xml is not created during configuration; the backend creates it after the first Lateral File System node is created.</system:String>
