    <system:String x:Key="Directories.Page.Title">Directory Locations</system:String>
    <system:String x:Key="Directories.Page.Description">Configure where Ferrita stores sessions, configuration, debug files, and session flows.</system:String>
    <system:String x:Key="Directories.Page.Hint">Directory settings are written immediately to Directories.xml in the default Configuration directory.</system:String>
    <system:String x:Key="Directories.ChatSessions.Label">Chat Session Directory</system:String>
    <system:String x:Key="Directories.ChatSessions.Hint">Sets where ChatSessions are saved. The default is under user folder/Ferrita/ChatSessions.</system:String>
    <system:String x:Key="Directories.ConfigurationFiles.Label">Configuration Directory</system:String>
    <system:String x:Key="Directories.ConfigurationFiles.Hint">Sets where Configuration files are saved. Directories.xml always remains in user folder/Ferrita/Configuration.</system:String>
    <system:String x:Key="Directories.Debug.Label">Debug Directory</system:String>
    <system:String x:Key="Directories.Debug.Hint">Sets where Debug files are saved. The default is under user folder/Ferrita/Debug.</system:String>
    <system:String x:Key="Directories.SessionFlows.Label">Session Flow Directory</system:String>
    <system:String x:Key="Directories.SessionFlows.Hint">Sets where session flow nodegraphs are saved. The default is under user folder/Ferrita/Nodegraphs.</system:String>
    <system:String x:Key="Directories.AerialCity.Label">AerialCity Directory</system:String>
    <system:String x:Key="Directories.AerialCity.Hint">Sets where AerialCity RAG databases and mapping files are saved. The default is under user folder/Ferrita/AerialCity.</system:String>
    <system:String x:Key="Directories.Knowledge.Label">Knowledge Directory</system:String>
    <system:String x:Key="Directories.Knowledge.Hint">Sets where Knowledge bases are saved. The default is under user folder/Ferrita/Knowledge.</system:String>
