    <system:String x:Key="ContextCompression.Page.Title">Compression</system:String>
    <system:String x:Key="ContextCompression.Page.Description">Configure switches for context compression and context lifecycle retention.</system:String>
    <system:String x:Key="ContextCompression.Page.Hint">Changes are written to ContextManagement.xml immediately.</system:String>
    <system:String x:Key="ContextCompression.MinCompaction.Content">Compress stale tool calls in the background when context nears its limit.</system:String>
    <system:String x:Key="ContextCompression.MinCompaction.EnabledText">Stale tool calls are compressed in the background after context reaches 80%.</system:String>
    <system:String x:Key="ContextCompression.MinCompaction.DisabledText">MinCompaction is currently off.</system:String>
    <system:String x:Key="ContextCompression.MaxCompaction.Content">Enable MaxCompaction</system:String>
    <system:String x:Key="ContextCompression.MaxCompaction.Hint">When the context window reaches its limit and MinCompaction cannot work, use full compression for session context.</system:String>
    <system:String x:Key="ContextCompression.LifeCycle.Content">Enable LifeCycle</system:String>
    <system:String x:Key="ContextCompression.LifeCycle.Hint">Certain tool call results receive lifecycle limits. After a number of session turns they are invalidated from context and written to disk. Agents can retrieve them; once retrieved, LifeCycle no longer applies to that result.</system:String>
    <system:String x:Key="ContextCompression.LifeCycleRatio.Label">LifeCycle Ratio</system:String>
    <system:String x:Key="ContextCompression.LifeCycleRatio.Hint">Adjust the effective lifecycle length used by LifeCycle. Results are rounded up.</system:String>
    <system:String x:Key="ContextCompression.RnnOptimization.Label">RNN Optimization</system:String>
    <system:String x:Key="ContextCompression.RnnOptimization.Content">Enable RNN-optimized compression</system:String>
    <system:String x:Key="ContextCompression.RnnOptimization.Hint">Only enable this for RNN language models such as RWKV or Manba. When enabled, context limits are removed and more important results and content are moved later so they keep stronger influence on linear attention. Extrapolation is required for unlimited context.</system:String>
    <system:String x:Key="ContextCompression.Status.MinCompactionSaved">MinCompaction setting saved.</system:String>
    <system:String x:Key="ContextCompression.Status.MaxCompactionSaved">MaxCompaction setting saved.</system:String>
    <system:String x:Key="ContextCompression.Status.LifeCycleSaved">LifeCycle setting saved.</system:String>
    <system:String x:Key="ContextCompression.Status.LifeCycleRatioSaved">LifeCycle ratio saved.</system:String>
    <system:String x:Key="ContextCompression.Status.RnnOptimizationSaved">RNN-optimized compression setting saved.</system:String>
    <system:String x:Key="ContextCompression.Instruction.1">1. Settings on this page are written immediately to ContextManagement.xml in the current configuration directory.</system:String>
    <system:String x:Key="ContextCompression.Instruction.2">2. Except for MinCompaction, current options only persist configuration; runtime behavior is not wired yet.</system:String>

    <system:String x:Key="Memory.Page.Title">Memory</system:String>
    <system:String x:Key="Memory.Page.Description">Configure the Ferrita memory mechanism, allowing the agent to remember and share past session content.</system:String>
