<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 颜色资源 -->
    <SolidColorBrush x:Key="WorkAreaBackgroundBrush" Color="#FF1A1F28"/>
    <SolidColorBrush x:Key="WorkAreaBorderBrush" Color="#FF1A1F28"/>
    <SolidColorBrush x:Key="LightTextBrush" Color="White"/>
    <SolidColorBrush x:Key="StatusActiveBrush" Color="#FF00FF00"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="DarkBorderBrush" Color="#FF000000"/>
    <SolidColorBrush x:Key="TextBrush" Color="#E0E0E0"/>

    <!-- 布局资源 -->
    <Thickness x:Key="ZeroThickness">0</Thickness>
    <Thickness x:Key="StandardMargin">5</Thickness>
    <Thickness x:Key="SmallMargin">2</Thickness>
    <Thickness x:Key="HeaderPadding">8,5</Thickness>
    <Thickness x:Key="ContentPadding">8,4</Thickness>
    <Thickness x:Key="ToolMargin">0,2,0,2</Thickness>
    <Thickness x:Key="IconMargin">0,0,4,0</Thickness>
    <Thickness x:Key="ButtonSpacing">0,0,5,0</Thickness>
    <Thickness x:Key="TabControlMargin">2,0,2,0</Thickness>
    
    <!-- 工作区域样式 -->
    <Style x:Key="WorkAreaStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource AeroBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource AeroBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    
    <!-- Tab页内容边框样式 -->
    <Style x:Key="TabContentBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource RibbonContentBackgroundBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
    </Style>
    
    <!-- 带遮罩的Tab页内容容器 -->
    <Style x:Key="RibbonContentContainerStyle" TargetType="Grid">
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    
    <!-- 元数据查看器样式 -->
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="Margin" Value="0,10,0,5"/>
        <Setter Property="Foreground" Value="#2C3E50"/>
    </Style>

    <Style x:Key="InfoLabelStyle" TargetType="TextBlock">
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Foreground" Value="#34495E"/>
    </Style>

    <Style x:Key="InfoValueStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Foreground" Value="#7F8C8D"/>
    </Style>

    <Style x:Key="TreeViewStyle" TargetType="TreeView">
        <Setter Property="Background" Value="#FAFAFA"/>
        <Setter Property="BorderBrush" Value="#BDC3C7"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="ButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5,0"/>
        <Setter Property="Background" Value="#3498DB"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2980B9"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 资源库面板样式（来自参考实现，统一并入当前应用样式集） -->
    <CornerRadius x:Key="StandardCornerRadius">4</CornerRadius>
    
    <DrawingBrush x:Key="SessionHistoryItemActivatedBrush" Stretch="Fill">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <DrawingGroup.Children>
                    <GeometryDrawing Geometry="F1 M 3,0L 887.53,0C 889.187,0 890.53,1.34326 890.53,3L 890.53,173.001C 890.53,174.658 889.187,176.001 887.53,176.001L 3,176.001C 1.34326,176.001 0,174.658 0,173.001L 0,3C 0,1.34326 1.34326,0 3,0 Z ">
                        <GeometryDrawing.Pen>
                            <Pen Thickness="1" LineJoin="Round" Brush="#7F7E8DB3"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Brush>
                            <LinearGradientBrush StartPoint="0.5,-0.659304" EndPoint="0.5,3.43202">
                                <LinearGradientBrush.GradientStops>
                                    <GradientStop Color="#FF445E74" Offset="0.139847"/>
                                    <GradientStop Color="#C12A394C" Offset="0.277778"/>
                                    <GradientStop Color="#C324334A" Offset="0.327586"/>
                                    <GradientStop Color="#FF334B62" Offset="0.496169"/>
                                </LinearGradientBrush.GradientStops>
                            </LinearGradientBrush>
                        </GeometryDrawing.Brush>
                    </GeometryDrawing>
                    <GeometryDrawing Geometry="F1 M 3,0L 887.53,0C 889.187,0 890.53,1.34326 890.53,3L 890.53,173.001C 890.53,174.658 889.187,176.001 887.53,176.001L 3,176.001C 1.34326,176.001 0.000244141,174.658 0.000244141,173.001L 0.000244141,3C 0.000244141,1.34326 1.34326,0 3,0 Z ">
                        <GeometryDrawing.Pen>
                            <Pen Thickness="1" LineJoin="Round" Brush="#7F7E8DB3"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Brush>
                            <RadialGradientBrush RadiusX="2.19327" RadiusY="0.886419" Center="0.499999,1.44886" GradientOrigin="0.499999,1.44886">
                                <RadialGradientBrush.GradientStops>
                                    <GradientStop Color="#CF49EAFF" Offset="0.210728"/>
                                    <GradientStop Color="#0034637B" Offset="0.522988"/>
                                </RadialGradientBrush.GradientStops>
                                <RadialGradientBrush.RelativeTransform>
                                    <TransformGroup>
                                        <RotateTransform CenterX="0.499999" CenterY="1.44886" Angle="-90"/>
                                    </TransformGroup>
                                </RadialGradientBrush.RelativeTransform>
                            </RadialGradientBrush>
                        </GeometryDrawing.Brush>
                    </GeometryDrawing>
                </DrawingGroup.Children>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <RadialGradientBrush x:Key="ResourceObjectIdleBrush" RadiusX="4.37757" RadiusY="6.21475" Center="-0.707033,-0.303034" GradientOrigin="-0.707033,-0.303034">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#6BDDFFFD" Offset="0.0811639"/>
            <GradientStop Color="#3A000000" Offset="0.243492"/>
            <GradientStop Color="#907FCEFF" Offset="0.500766"/>
            <GradientStop Color="#FF000000" Offset="0.586524"/>
            <GradientStop Color="#FF0099FF" Offset="0.828484"/>
        </RadialGradientBrush.GradientStops>
        <RadialGradientBrush.RelativeTransform>
            <TransformGroup>
                <RotateTransform CenterX="-0.707033" CenterY="-0.303034" Angle="-90"/>
            </TransformGroup>
        </RadialGradientBrush.RelativeTransform>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="ResourceObjectHoverBrush" RadiusX="4.37757" RadiusY="6.21475" Center="-0.50849,0.0296108" GradientOrigin="-0.50849,0.0296108">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#7800F3FF" Offset="0.0597243"/>
            <GradientStop Color="#2B000000" Offset="0.234303"/>
            <GradientStop Color="#FFA5DBFF" Offset="0.372129"/>
            <GradientStop Color="#FF0099FF" Offset="0.577335"/>
        </RadialGradientBrush.GradientStops>
        <RadialGradientBrush.RelativeTransform>
            <TransformGroup>
                <RotateTransform CenterX="-0.50849" CenterY="0.0296108" Angle="-90"/>
            </TransformGroup>
        </RadialGradientBrush.RelativeTransform>
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="ResourceObjectClickedBrush" RadiusX="4.37757" RadiusY="6.21474" Center="-0.0897255,-0.0568296" GradientOrigin="-0.0897255,-0.0568296">
        <RadialGradientBrush.GradientStops>
            <GradientStop Color="#FC00F3FF" Offset="0"/>
            <GradientStop Color="#28000000" Offset="0.169985"/>
            <GradientStop Color="#EBA5DBFF" Offset="0.304747"/>
            <GradientStop Color="#FF0099FF" Offset="0.577335"/>
        </RadialGradientBrush.GradientStops>
        <RadialGradientBrush.RelativeTransform>
            <TransformGroup>
                <RotateTransform CenterX="-0.0897255" CenterY="-0.0568296" Angle="-90"/>
            </TransformGroup>
        </RadialGradientBrush.RelativeTransform>
    </RadialGradientBrush>

    <Style x:Key="ResourceToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Arial"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <ContentPresenter Name="contentPresenter"
                                          Focusable="False"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ResourcePanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource Layer_2}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Margin" Value="2"/>
    </Style>

    <Style x:Key="ResourceGroupHeaderStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource PrimaryForeground}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Arial"/>
        <Setter Property="Margin" Value="8,8,8,4"/>
    </Style>

    <Style x:Key="ResourceItemStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ResourceObjectIdleBrush}"/>
        <Setter Property="BorderBrush" Value="#FF000000"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="3" Opacity="0.4"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource ResourceObjectHoverBrush}"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="5" Opacity="0.7"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                <BeginStoryboard>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background" Duration="0:0:0">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{StaticResource ResourceObjectClickedBrush}"/>
                        </ObjectAnimationUsingKeyFrames>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Effect" Duration="0:0:0">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                <DiscreteObjectKeyFrame.Value>
                                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.9"/>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                <BeginStoryboard>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background" Duration="0:0:0">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{StaticResource ResourceObjectHoverBrush}"/>
                        </ObjectAnimationUsingKeyFrames>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Effect" Duration="0:0:0">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                <DiscreteObjectKeyFrame.Value>
                                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="5" Opacity="0.7"/>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Background" Duration="0:0:0">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="{StaticResource ResourceObjectIdleBrush}"/>
                        </ObjectAnimationUsingKeyFrames>
                        <ObjectAnimationUsingKeyFrames Storyboard.TargetProperty="Effect" Duration="0:0:0">
                            <DiscreteObjectKeyFrame KeyTime="0:0:0">
                                <DiscreteObjectKeyFrame.Value>
                                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="3" Opacity="0.4"/>
                                </DiscreteObjectKeyFrame.Value>
                            </DiscreteObjectKeyFrame>
                        </ObjectAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SessionHistoryItemStyle" TargetType="ListBoxItem">
        <Setter Property="Background" Value="{StaticResource ResourceObjectIdleBrush}"/>
        <Setter Property="BorderBrush" Value="#FF000000"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Grid>
                        <!-- 默认/Hover 状态使用的 Border -->
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{DynamicResource StandardCornerRadius}">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="3" Opacity="0.4"/>
                            </Border.Effect>
                        </Border>

                        <!-- Activated 状态使用的组合 Border -->
                        <Border x:Name="ActivatedBg"
                                Background="{DynamicResource SessionHistoryItemActivatedBrush}"
                                CornerRadius="{DynamicResource StandardCornerRadius}"
                                Visibility="Collapsed">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="6" Opacity="0.9"/>
                            </Border.Effect>
                        </Border>

                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource ResourceObjectHoverBrush}"/>
                            <Setter TargetName="Bd" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" BlurRadius="5" Opacity="0.7"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="ActivatedBg" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <DataTemplate x:Key="ResourceItemTemplate">
        <Border Style="{StaticResource ResourceItemStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="32" Height="32" CornerRadius="3" Margin="0,0,8,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FF3A4250" Offset="0"/>
                            <GradientStop Color="#FF2A3240" Offset="0.5"/>
                            <GradientStop Color="#FF1A1F28" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Direction="270" ShadowDepth="1" BlurRadius="1" Opacity="0.4"/>
                    </Border.Effect>
                    <Image Source="{Binding DisplayIconPath}" Stretch="Uniform" Margin="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="12" FontFamily="Segoe UI, Microsoft YaHei UI, Arial" Foreground="{DynamicResource PrimaryForeground}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding ResourceTypeDisplayName}" FontSize="10" FontFamily="Segoe UI, Microsoft YaHei UI, Arial" Foreground="{DynamicResource SecondaryForeground}" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding FormattedFileSize}" FontSize="9" FontFamily="Segoe UI, Microsoft YaHei UI, Arial" Foreground="{DynamicResource SecondaryForeground}"/>
                </StackPanel>

                <Border Grid.Column="2" Width="10" Height="10" CornerRadius="5" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <RadialGradientBrush>
                                        <GradientStop Color="#FF66FF66" Offset="0"/>
                                        <GradientStop Color="#FF44CC44" Offset="1"/>
                                    </RadialGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect Color="#FF44CC44" Direction="270" ShadowDepth="1" BlurRadius="2" Opacity="0.8"/>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </Border>
    </DataTemplate>
</ResourceDictionary> 