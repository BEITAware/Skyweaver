<Window x:Class="Ferrita.Windows.CreateScheduledTaskDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ScheduledTaskDialog.Title}"
        Width="700"
        Height="780"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Ferrita;component/Resources/Ferrita.ico">
    <Window.Resources>
        <!-- Plasma 背景 DrawingBrush 定义 -->
        <DrawingBrush x:Key="PlasmaBackgroundBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 1,0.999878L 400.999,0.999878L 400.999,223L 1,223L 1,0.999878 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="2" LineJoin="Round" Brush="#FF2A7288"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Brush>
                                <RadialGradientBrush RadiusX="0.9594" RadiusY="1.23497" Center="0.500009,-0.0053194" GradientOrigin="0.500009,-0.0053194">
                                    <RadialGradientBrush.GradientStops>
                                        <GradientStop Color="#FF306F83" Offset="0"/>
                                        <GradientStop Color="#FF091023" Offset="0.992337"/>
                                    </RadialGradientBrush.GradientStops>
                                </RadialGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- Aero ListBox 边框与内阴影样式 -->
        <Style x:Key="AeroListBoxStyle" TargetType="ListBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#35000000"/>
            <Setter Property="BorderBrush" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Grid>
                            <!-- 背景圆角边框 -->
                            <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            
                            <!-- 顶部内阴影 -->
                            <Border CornerRadius="6,6,0,0" Height="12" VerticalAlignment="Top" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#50000000" Offset="0"/>
                                        <GradientStop Color="#20000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 左侧内阴影 -->
                            <Border CornerRadius="6,0,0,6" Width="8" HorizontalAlignment="Left" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#30000000" Offset="0"/>
                                        <GradientStop Color="#15000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 右侧内阴影 -->
                            <Border CornerRadius="0,6,6,0" Width="8" HorizontalAlignment="Right" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                                        <GradientStop Color="#30000000" Offset="0"/>
                                        <GradientStop Color="#15000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 底部内阴影 -->
                            <Border CornerRadius="0,0,6,6" Height="8" VerticalAlignment="Bottom" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                        <GradientStop Color="#25000000" Offset="0"/>
                                        <GradientStop Color="#08000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <ScrollViewer Margin="6" Focusable="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aero ListBoxItem 样式 -->
        <Style x:Key="AeroListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Margin="0,0,0,4">
                            <!-- 悬停状态背景 -->
                            <Border x:Name="HoverBackground" Opacity="0" CornerRadius="3" BorderThickness="1">
                                <Border.BorderBrush>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#FF5984AD" Offset="0"/>
                                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#374588BD" Offset="0"/>
                                        <GradientStop Color="#081AD5FF" Offset="0.69"/>
                                        <GradientStop Color="#1FFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 选中状态背景 -->
                            <Border x:Name="SelectedBackground" Opacity="0" CornerRadius="3" BorderThickness="1">
                                <Border.BorderBrush>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#FF5984AD" Offset="0"/>
                                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#A34588BD" Offset="0"/>
                                        <GradientStop Color="#111AD5FF" Offset="0.69"/>
                                        <GradientStop Color="#31FFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 内容呈现器 -->
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SelectedBackground" Property="Opacity" Value="1"/>
                                <Setter TargetName="HoverBackground" Property="Opacity" Value="0"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 晶莹剔透玻璃背景层 -->
        <DrawingBrush x:Key="SoftGlassSliceBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Geometry="F1 M 0,0 L 1000,0 L 1000,1000 L 0,1000 Z">
                        <GeometryDrawing.Brush>
                            <LinearGradientBrush StartPoint="0.1,0.1" EndPoint="0.9,0.9">
                                <GradientStop Color="#25FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.3"/>
                                <GradientStop Color="#02FFFFFF" Offset="0.7"/>
                                <GradientStop Color="#18FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </GeometryDrawing.Brush>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="GlassBorderStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#40FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Background" Value="#1A000000"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style x:Key="HeaderLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFA3D8FF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="NormalTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- CheckBox Preferences Style -->
        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid Width="16" Height="16" VerticalAlignment="Center">
                                <Border x:Name="Background" CornerRadius="2" BorderThickness="1">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0.5,-1.45" EndPoint="0.5,1.73">
                                            <GradientStop Color="#CCD9E7F4" Offset="0"/>
                                            <GradientStop Color="#CC7CBEEA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,-1.46" EndPoint="0.5,1.74">
                                            <GradientStop Color="#CC9CB3C8" Offset="0.473"/>
                                            <GradientStop Color="#CC3A576E" Offset="0.593"/>
                                            <GradientStop Color="#CC162D41" Offset="0.623"/>
                                            <GradientStop Color="#CC4C87AF" Offset="0.798"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Border x:Name="HoverBackground" Opacity="0" CornerRadius="2" BorderThickness="1">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0.5,-1.45" EndPoint="0.5,1.73">
                                            <GradientStop Color="#FFE9F7FF" Offset="0"/>
                                            <GradientStop Color="#FF8CCEFA" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,-1.46" EndPoint="0.5,1.74">
                                            <GradientStop Color="#FFACC3D8" Offset="0.473"/>
                                            <GradientStop Color="#FF4A677E" Offset="0.593"/>
                                            <GradientStop Color="#FF263D51" Offset="0.623"/>
                                            <GradientStop Color="#FF5C97BF" Offset="0.798"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <Path x:Name="CheckMark"
                                      Data="M 2,7 L 6,11 L 13,3"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Opacity="0"
                                      Margin="0,-1,0,0">
                                    <Path.Stroke>
                                        <RadialGradientBrush RadiusX="1.15" RadiusY="1.15" Center="0.5,1.15" GradientOrigin="0.5,1.15">
                                            <GradientStop Color="#FF8AE0FF" Offset="0.093"/>
                                            <GradientStop Color="#FF35A6E6" Offset="0.645"/>
                                            <GradientStop Color="#FF4DA6E4" Offset="0.712"/>
                                            <GradientStop Color="#FFAED3F4" Offset="0.942"/>
                                        </RadialGradientBrush>
                                    </Path.Stroke>
                                    <Path.Effect>
                                        <DropShadowEffect Color="#22657C" BlurRadius="2" ShadowDepth="0" Opacity="0.8" Direction="315"/>
                                    </Path.Effect>
                                </Path>

                                <Border x:Name="IndeterminateMark" Width="8" Height="8" CornerRadius="1" Opacity="0">
                                    <Border.Background>
                                        <RadialGradientBrush RadiusX="1.15" RadiusY="1.15" Center="0.5,1.15" GradientOrigin="0.5,1.15">
                                            <GradientStop Color="#FF8AE0FF" Offset="0.093"/>
                                            <GradientStop Color="#FF35A6E6" Offset="0.645"/>
                                            <GradientStop Color="#FF4DA6E4" Offset="0.712"/>
                                            <GradientStop Color="#FFAED3F4" Offset="0.942"/>
                                        </RadialGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#22657C" BlurRadius="2" ShadowDepth="0" Opacity="0.8" Direction="315"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>

                            <ContentPresenter Grid.Column="1"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="2" ShadowDepth="1" Opacity="0.5"/>
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CheckMark" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="CheckMark" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="{x:Null}">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateMark" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="IndeterminateMark" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- 背景画笔 -->
        <Rectangle Fill="{StaticResource PlasmaBackgroundBrush}"/>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,16">
                <TextBlock Text="{DynamicResource ScheduledTaskDialog.Header.Title}" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="{DynamicResource ScheduledTaskDialog.Header.Description}" FontSize="11" Foreground="#A0FFFFFF" Margin="0,4,0,0"/>
            </StackPanel>

            <!-- 主配置区域 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,10,0">
                <StackPanel>
                    <!-- 任务基本信息 -->
                    <Border Style="{StaticResource GlassBorderStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="12"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 任务名称 -->
                            <StackPanel Grid.Row="0" Grid.Column="0">
                                <TextBlock Text="{DynamicResource ScheduledTaskDialog.TaskName.Label}" Style="{StaticResource HeaderLabelStyle}"/>
                                <TextBox x:Name="TaskNameTextBox" Height="28" VerticalContentAlignment="Center" Background="#30000000" BorderBrush="#50FFFFFF" Foreground="White" CaretBrush="White"/>
                            </StackPanel>

                            <!-- 会话流绑定 -->
                            <StackPanel Grid.Row="0" Grid.Column="2">
                                <TextBlock Text="{DynamicResource ScheduledTaskDialog.SessionFlow.Label}" Style="{StaticResource HeaderLabelStyle}"/>
                                <ComboBox x:Name="SessionFlowComboBox" Height="28" Background="#30000000" Foreground="Black" BorderBrush="#50FFFFFF" DisplayMemberPath="Name" SelectedValuePath="FilePath"/>
                            </StackPanel>

                            <!-- 自动批准需确认的工具调用 -->
                            <CheckBox x:Name="AutoApproveToolsCheckBox" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Content="{DynamicResource ScheduledTaskDialog.AutoApproveTools}" Foreground="White" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 任务提示词内容 -->
                    <Border Style="{StaticResource GlassBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ScheduledTaskDialog.Prompt.Label}" Style="{StaticResource HeaderLabelStyle}"/>
                            <TextBox x:Name="PromptTextBox" Height="90" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Background="#30000000" BorderBrush="#50FFFFFF" Foreground="White" CaretBrush="White" Padding="6"/>
                        </StackPanel>
                    </Border>

                    <!-- 触发器设置 -->
                    <Border Style="{StaticResource GlassBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="100"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{DynamicResource ScheduledTaskDialog.TriggersConfig.Label}" Style="{StaticResource HeaderLabelStyle}"/>

                            <!-- 触发器列表 -->
                            <Border Grid.Row="1" Style="{StaticResource GlassBorderStyle}" Padding="2" Margin="0,4,0,4">
                                <ListBox x:Name="TriggersListBox" Style="{StaticResource AeroListBoxStyle}" ItemContainerStyle="{StaticResource AeroListBoxItemStyle}" SelectionChanged="TriggersListBox_SelectionChanged">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DisplayText}" Foreground="White" FontSize="11" Margin="4,2"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>

                            <!-- 按钮区 -->
                            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,4,0,12">
                                <Button x:Name="AddTriggerButton" Content="{DynamicResource ScheduledTaskDialog.AddTrigger}" Width="96" Height="28" VerticalContentAlignment="Center" Padding="0" Margin="0,0,8,0" Style="{DynamicResource ResourceToolbarButtonStyle}" Click="AddTriggerButton_Click"/>
                                <Button x:Name="DeleteTriggerButton" Content="{DynamicResource ScheduledTaskDialog.DeleteTrigger}" Width="96" Height="28" VerticalContentAlignment="Center" Padding="0" Style="{DynamicResource ResourceToolbarButtonStyle}" Click="DeleteTriggerButton_Click"/>
                            </StackPanel>

                            <!-- 触发参数 -->
                            <Grid Grid.Row="3" x:Name="TriggerDetailGrid" Margin="0,4,0,0" IsEnabled="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource ScheduledTaskDialog.TriggerType.Label}" Foreground="#E0FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="TriggerTypeComboBox" Height="26" SelectionChanged="TriggerTypeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.TriggerType.Daily}" Tag="Daily"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.TriggerType.Weekly}" Tag="Weekly"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.TriggerType.Monthly}" Tag="Monthly"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.TriggerType.Yearly}" Tag="Yearly"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.TriggerType.Custom}" Tag="Custom"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- 触发参数（根据类型动态展示） -->
                                <Border Grid.Column="2" BorderThickness="1,0,0,0" BorderBrush="#30FFFFFF" Padding="12,0,0,0">
                                    <Grid>
                                        <!-- 每年参数 -->
                                        <Grid x:Name="YearlyParamsGrid" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="65"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="65"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{DynamicResource ScheduledTaskDialog.Label.Month}" Style="{StaticResource NormalTextStyle}" Margin="0,0,6,0"/>
                                            <ComboBox Grid.Column="1" x:Name="YearlyMonthComboBox" Height="26" SelectionChanged="YearlyParam_SelectionChanged"/>
                                            <TextBlock Grid.Column="2" Text="{DynamicResource ScheduledTaskDialog.Label.Day}" Style="{StaticResource NormalTextStyle}" Margin="10,0,6,0"/>
                                            <ComboBox Grid.Column="3" x:Name="YearlyDayComboBox" Height="26" SelectionChanged="YearlyParam_SelectionChanged"/>
                                            <TextBlock Grid.Column="4" Text="{DynamicResource ScheduledTaskDialog.Label.Time}" Style="{StaticResource NormalTextStyle}" Margin="10,0,6,0"/>
                                            <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ComboBox x:Name="YearlyHourComboBox" Width="42" Height="26" SelectionChanged="YearlyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="YearlyMinuteComboBox" Width="42" Height="26" SelectionChanged="YearlyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="YearlySecondComboBox" Width="42" Height="26" SelectionChanged="YearlyParam_SelectionChanged"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 每月参数 -->
                                        <Grid x:Name="MonthlyParamsGrid" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="65"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{DynamicResource ScheduledTaskDialog.Label.Day}" Style="{StaticResource NormalTextStyle}" Margin="0,0,6,0"/>
                                            <ComboBox Grid.Column="1" x:Name="MonthlyDayComboBox" Height="26" SelectionChanged="MonthlyParam_SelectionChanged"/>
                                            <TextBlock Grid.Column="2" Text="{DynamicResource ScheduledTaskDialog.Label.Time}" Style="{StaticResource NormalTextStyle}" Margin="10,0,6,0"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ComboBox x:Name="MonthlyHourComboBox" Width="42" Height="26" SelectionChanged="MonthlyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="MonthlyMinuteComboBox" Width="42" Height="26" SelectionChanged="MonthlyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="MonthlySecondComboBox" Width="42" Height="26" SelectionChanged="MonthlyParam_SelectionChanged"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 每周参数 -->
                                        <Grid x:Name="WeeklyParamsGrid" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{DynamicResource ScheduledTaskDialog.Label.DayOfWeek}" Style="{StaticResource NormalTextStyle}" Margin="0,0,6,0"/>
                                            <ComboBox Grid.Column="1" x:Name="WeeklyDayOfWeekComboBox" Height="26" SelectionChanged="WeeklyParam_SelectionChanged">
                                                <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.DayOfWeek.Monday}" Tag="Monday"/>
                                                <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.DayOfWeek.Tuesday}" Tag="Tuesday"/>
                                                <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.DayOfWeek.Wednesday}" Tag="Wednesday"/>
                                                <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.DayOfWeek.Thursday}" Tag="Thursday"/>
                                                <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.DayOfWeek.Friday}" Tag="Friday"/>
                                                <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.DayOfWeek.Saturday}" Tag="Saturday"/>
                                                <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.DayOfWeek.Sunday}" Tag="Sunday"/>
                                            </ComboBox>
                                            <TextBlock Grid.Column="2" Text="{DynamicResource ScheduledTaskDialog.Label.Time}" Style="{StaticResource NormalTextStyle}" Margin="10,0,6,0"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ComboBox x:Name="WeeklyHourComboBox" Width="42" Height="26" SelectionChanged="WeeklyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="WeeklyMinuteComboBox" Width="42" Height="26" SelectionChanged="WeeklyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="WeeklySecondComboBox" Width="42" Height="26" SelectionChanged="WeeklyParam_SelectionChanged"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 每天参数 -->
                                        <Grid x:Name="DailyParamsGrid" Visibility="Collapsed">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{DynamicResource ScheduledTaskDialog.Label.TriggerTime}" Style="{StaticResource NormalTextStyle}" Margin="0,0,8,0"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ComboBox x:Name="DailyHourComboBox" Width="42" Height="26" SelectionChanged="DailyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="DailyMinuteComboBox" Width="42" Height="26" SelectionChanged="DailyParam_SelectionChanged"/>
                                                <TextBlock Text=":" Style="{StaticResource NormalTextStyle}" Margin="2,0"/>
                                                <ComboBox x:Name="DailySecondComboBox" Width="42" Height="26" SelectionChanged="DailyParam_SelectionChanged"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 自定义/留空 -->
                                        <Grid x:Name="CustomParamsGrid" Visibility="Collapsed">
                                            <TextBlock Text="{DynamicResource ScheduledTaskDialog.Label.NoExtraParams}" Foreground="#70FFFFFF" FontSize="11" VerticalAlignment="Center" FontStyle="Italic"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>



                    <!-- 动作设置（开始前/结束后） -->
                    <Border Style="{StaticResource GlassBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ScheduledTaskDialog.ActionsConfig.Label}" Style="{StaticResource HeaderLabelStyle}"/>
                            
                            <!-- 任务开始前 -->
                            <Grid Margin="0,4,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource ScheduledTaskDialog.PreAction.Label}" Foreground="#E0FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PreActionTypeComboBox" Height="26" SelectionChanged="PreActionTypeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.None}" Tag="None"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.Powershell}" Tag="Powershell"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.Shutdown}" Tag="Shutdown"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.Restart}" Tag="Restart"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" x:Name="PreActionScriptPanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource ScheduledTaskDialog.PowershellScript.Label}" Foreground="#E0FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="PreActionScriptTextBox" Height="26" VerticalContentAlignment="Center" Background="#30000000" BorderBrush="#50FFFFFF" Foreground="White" CaretBrush="White"/>
                                </StackPanel>
                            </Grid>

                            <!-- 任务结束后 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{DynamicResource ScheduledTaskDialog.PostAction.Label}" Foreground="#E0FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="PostActionTypeComboBox" Height="26" SelectionChanged="PostActionTypeComboBox_SelectionChanged">
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.None}" Tag="None"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.Powershell}" Tag="Powershell"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.Shutdown}" Tag="Shutdown"/>
                                        <ComboBoxItem Content="{DynamicResource ScheduledTaskDialog.ActionType.Restart}" Tag="Restart"/>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel Grid.Column="2" x:Name="PostActionScriptPanel" Visibility="Collapsed">
                                    <TextBlock Text="{DynamicResource ScheduledTaskDialog.PowershellScript.Label}" Foreground="#E0FFFFFF" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBox x:Name="PostActionScriptTextBox" Height="26" VerticalContentAlignment="Center" Background="#30000000" BorderBrush="#50FFFFFF" Foreground="White" CaretBrush="White"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 底部按钮区 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button x:Name="ConfirmButton" Width="92" Height="30" Margin="0,0,8,0" IsDefault="True" Click="ConfirmButton_Click" Content="{DynamicResource Common.Confirm}" Style="{DynamicResource ResourceToolbarButtonStyle}"/>
                <Button Width="92" Height="30" IsCancel="True" Content="{DynamicResource Common.Cancel}" Style="{DynamicResource ResourceToolbarButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
