<Window x:Class="Ferrita.Windows.FerritaGroundingEngineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Ferrita.ViewModels"
        mc:Ignorable="d"
        Title="Ferrita Grounding Engine"
        Height="950" 
        Width="1600"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 背景暗色蓝绿渐变笔刷 (完美还原草稿 Layer_15) -->
        <RadialGradientBrush x:Key="WindowBackgroundBrush" RadiusX="0.9594" RadiusY="1.23497" Center="0.5,-0.005" GradientOrigin="0.5,-0.005">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#FF306F83" Offset="0"/>
                <GradientStop Color="#FF091023" Offset="0.992"/>
            </RadialGradientBrush.GradientStops>
        </RadialGradientBrush>

        <!-- 聊天消息块渐变描边笔刷 (完美还原草稿 Path 描边) -->
        <LinearGradientBrush x:Key="ChatMessageBorderBrush" StartPoint="0.5,0" EndPoint="0.5,1">
            <LinearGradientBrush.GradientStops>
                <GradientStop Color="#FF6A92AA" Offset="0"/>
                <GradientStop Color="#FF2E6986" Offset="1"/>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <!-- 聊天消息块内部微透高光填充笔刷 (完美还原草稿 Path 填充) -->
        <LinearGradientBrush x:Key="ChatMessageBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1">
            <LinearGradientBrush.GradientStops>
                <GradientStop Color="#5BFFFFFF" Offset="0"/>
                <GradientStop Color="#00FFFFFF" Offset="0.178"/>
                <GradientStop Color="#00000000" Offset="0.208"/>
                <GradientStop Color="#09070E11" Offset="0.798"/>
                <GradientStop Color="#952582AA" Offset="1"/>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <!-- 事实块描边笔刷 (完美还原草稿 Path_1/3/5 描边) -->
        <RadialGradientBrush x:Key="FactBorderBrush" RadiusX="1.73" RadiusY="1.74" Center="0.5,0.012" GradientOrigin="0.5,0.012">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#00FFFFFF" Offset="0"/>
                <GradientStop Color="#FFFFFFFF" Offset="1"/>
            </RadialGradientBrush.GradientStops>
        </RadialGradientBrush>

        <!-- 绿色事实块微透背景 (完美还原草稿 Path_5 填充) -->
        <RadialGradientBrush x:Key="FactGreenBackgroundBrush" RadiusX="1.74" RadiusY="1.752" Center="0.5,0.008" GradientOrigin="0.5,0.008">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#3037FF62" Offset="0"/>
                <GradientStop Color="#00FFFFFF" Offset="0.298"/>
                <GradientStop Color="#1AFFFFFF" Offset="0.54"/>
                <GradientStop Color="#FFFFFFFF" Offset="1"/>
            </RadialGradientBrush.GradientStops>
        </RadialGradientBrush>

        <!-- 黄色事实块微透背景 (完美还原草稿 Path_3 填充) -->
        <RadialGradientBrush x:Key="FactYellowBackgroundBrush" RadiusX="1.74" RadiusY="1.752" Center="0.5,0.008" GradientOrigin="0.5,0.008">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#40FFE600" Offset="0"/>
                <GradientStop Color="#00FFFFFF" Offset="0.306"/>
                <GradientStop Color="#1AFFFFFF" Offset="0.54"/>
                <GradientStop Color="#FFFFFFFF" Offset="1"/>
            </RadialGradientBrush.GradientStops>
        </RadialGradientBrush>

        <!-- 红色事实块微透背景 (完美还原草稿 Path_1 填充) -->
        <RadialGradientBrush x:Key="FactRedBackgroundBrush" RadiusX="1.74" RadiusY="1.752" Center="0.5,0.008" GradientOrigin="0.5,0.008">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#4BFF4747" Offset="0"/>
                <GradientStop Color="#00FFFFFF" Offset="0.385"/>
                <GradientStop Color="#1AFFFFFF" Offset="0.534"/>
                <GradientStop Color="#FFFFFFFF" Offset="1"/>
            </RadialGradientBrush.GradientStops>
        </RadialGradientBrush>

        <!-- 右侧长条装饰描边 (还原草稿 Path_4 描边) -->
        <LinearGradientBrush x:Key="SidebarDecorBorderBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <LinearGradientBrush.GradientStops>
                <GradientStop Color="#A7FFFFFF" Offset="0"/>
                <GradientStop Color="#2DFFFFFF" Offset="1"/>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <!-- 右侧长条装饰背景 (还原草稿 Path_4 填充) -->
        <LinearGradientBrush x:Key="SidebarDecorBackgroundBrush" StartPoint="0,0.5" EndPoint="1,0.5">
            <LinearGradientBrush.GradientStops>
                <GradientStop Color="#7DFFFFFF" Offset="0"/>
                <GradientStop Color="#1A000000" Offset="0.467"/>
                <GradientStop Color="#1FFFFFFF" Offset="1"/>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <!-- 磨砂玻璃反射 DrawingBrush -->
        <DrawingBrush x:Key="WindowSoftGlassBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 0,0L 1000,0L 1000,200L 0,200L 0,0 Z ">
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                                    <LinearGradientBrush.GradientStops>
                                        <GradientStop Color="#12FFFFFF" Offset="0"/>
                                        <GradientStop Color="#06FFFFFF" Offset="0.2"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                                        <GradientStop Color="#10FFFFFF" Offset="0.55"/>
                                        <GradientStop Color="#02FFFFFF" Offset="0.8"/>
                                        <GradientStop Color="#18FFFFFF" Offset="1"/>
                                    </LinearGradientBrush.GradientStops>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- 聊天气泡外阴影效果 -->
        <DropShadowEffect x:Key="BubbleDropShadow" Color="#FF2E6986" BlurRadius="12" ShadowDepth="0" Opacity="0.3"/>

        <!-- 事实气泡根据状态改变背景和发光颜色的 Style -->
        <Style x:Key="FactBubbleBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="{StaticResource FactBorderBrush}"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Verified}">
                    <Setter Property="Background" Value="{StaticResource FactGreenBackgroundBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FF37FF62" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Unverified}">
                    <Setter Property="Background" Value="{StaticResource FactYellowBackgroundBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FFFFE600" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Contradicted}">
                    <Setter Property="Background" Value="{StaticResource FactRedBackgroundBrush}"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FFFF4747" BlurRadius="20" ShadowDepth="0" Opacity="0.35"/>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 高科技发光按钮模板 -->
        <ControlTemplate x:Key="TechButtonTemplate" TargetType="Button">
            <Border x:Name="BtnBorder" 
                    Background="#2080D0FF" 
                    BorderBrush="#60FFFFFF" 
                    BorderThickness="1.5" 
                    CornerRadius="8" 
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="BtnBorder" Property="Background" Value="#5080D0FF"/>
                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#FFFFFFFF"/>
                    <Setter TargetName="BtnBorder" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#FF80D0FF" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="BtnBorder" Property="Background" Value="#8080D0FF"/>
                    <Setter TargetName="BtnBorder" Property="BorderBrush" Value="#80FFFFFF"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Window.Resources>

    <Grid x:Name="RootLayout">
        <!-- 窗口外框和深色径向渐变背景 -->
        <Border CornerRadius="20" 
                BorderThickness="2.5" 
                BorderBrush="#FF2A7288" 
                Background="{StaticResource WindowBackgroundBrush}" 
                ClipToBounds="True">
            <Grid>
                <!-- 1. Aero 极光霓虹模糊发光圈 (右上) -->
                <Ellipse Width="650" Height="500" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-180,-120,0" Fill="#202B5BC2" IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="110"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- 2. Aero 极光霓虹模糊发光圈 (左下) -->
                <Ellipse Width="600" Height="450" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-120,0,0,-150" Fill="#157638B5" IsHitTestVisible="False">
                    <Ellipse.Effect>
                        <BlurEffect Radius="90"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- 3. 全息网格背景层 -->
                <Border CornerRadius="18" Opacity="0.15" IsHitTestVisible="False">
                    <Border.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,10,10" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Canvas Width="10" Height="10" Background="Transparent">
                                    <Ellipse Width="1.5" Height="1.5" Fill="#FFFFFFFF" Canvas.Left="0" Canvas.Top="0"/>
                                    <Ellipse Width="1.5" Height="1.5" Fill="#FFFFFFFF" Canvas.Left="5" Canvas.Top="5"/>
                                </Canvas>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>

                <!-- 4. 玻璃对角线反光层 -->
                <Border CornerRadius="18" Background="{StaticResource WindowSoftGlassBrush}" IsHitTestVisible="False" Opacity="0.4"/>

                <!-- 主干布局 -->
                <Grid Margin="30">
                    <Grid.RowDefinitions>
                        <!-- 标题栏和系统按钮 -->
                        <RowDefinition Height="Auto"/>
                        <!-- 主体内容 -->
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 顶部标题栏 -->
                    <Grid Grid.Row="0" Margin="10,0,10,25" MouseLeftButtonDown="Header_MouseLeftButtonDown" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 精致的 Ferrita 标题 (完美还原草稿) -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock VerticalAlignment="Center">
                                <Run FontFamily="微软雅黑" FontSize="38" Text="Ferrita " Foreground="#FFFFFFFF" FontWeight="Bold"/>
                                <Run FontFamily="微软雅黑 Light" FontSize="38" Text="Grounding Engine" Foreground="#FFA7D0E0"/>
                            </TextBlock>

                        </StackPanel>

                        <!-- 右上角控制按钮 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 最小化 -->
                            <Button Width="32" Height="32" 
                                    Margin="0,0,10,0"
                                    Click="MinimizeButton_Click"
                                    ToolTip="最小化">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Width="28" Height="28" Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="14">
                                            <Path Data="M 6,14 L 22,14" Stroke="#FFFFFFFF" StrokeThickness="2" SnapsToDevicePixels="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#40FFFFFF"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#80FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <!-- 关闭 -->
                            <Button Width="32" Height="32" 
                                    Click="CloseButton_Click"
                                    ToolTip="关闭">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Border" Width="28" Height="28" Background="#15FFFFFF" BorderBrush="#30FFFFFF" BorderThickness="1" CornerRadius="14">
                                            <Path Data="M 8,8 L 20,20 M 20,8 L 8,20" Stroke="#FFFFFFFF" StrokeThickness="2" SnapsToDevicePixels="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#FFD83B3B"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#FFFF8080"/>
                                                <Setter TargetName="Border" Property="Effect">
                                                    <Setter.Value>
                                                        <DropShadowEffect Color="#FFD83B3B" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- 主体内容区域：划分为左侧的消息事实流与右侧控制板 -->
                    <Grid Grid.Row="1" Margin="10,0,10,10">
                        <Grid.ColumnDefinitions>
                            <!-- 配对内容流 -->
                            <ColumnDefinition Width="*"/>
                            <!-- 间隔 -->
                            <ColumnDefinition Width="35"/>
                            <!-- 右侧控制与说明区 -->
                            <ColumnDefinition Width="420"/>
                        </Grid.ColumnDefinitions>

                        <!-- 左侧：滚动配对聊天事实流 -->
                        <ScrollViewer Grid.Column="0" 
                                      VerticalScrollBarVisibility="Auto" 
                                      HorizontalScrollBarVisibility="Disabled"
                                      Padding="0,0,15,0">
                            <ItemsControl ItemsSource="{Binding GroundingPairs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,15,0,15">
                                            <Grid.ColumnDefinitions>
                                                <!-- 聊天消息块 -->
                                                <ColumnDefinition Width="2.5*"/>
                                                <!-- 中间连线 -->
                                                <ColumnDefinition Width="50"/>
                                                <!-- 事实检验块 -->
                                                <ColumnDefinition Width="1.5*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 左侧聊天块 -->
                                            <Border Grid.Column="0" 
                                                    BorderThickness="2.2" 
                                                    BorderBrush="{StaticResource ChatMessageBorderBrush}" 
                                                    Background="{StaticResource ChatMessageBackgroundBrush}" 
                                                    CornerRadius="16" 
                                                    Padding="20"
                                                    Effect="{StaticResource BubbleDropShadow}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- 头部信息 -->
                                                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                                        <Ellipse Width="24" Height="24" Fill="#3080D0FF" Stroke="#9080D0FF" StrokeThickness="1" DockPanel.Dock="Left" Margin="0,0,8,0">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect Color="#FF80D0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                        <TextBlock Text="AI 智能体助手" Foreground="#FFA0E5FF" FontFamily="微软雅黑" FontWeight="Bold" VerticalAlignment="Center" FontSize="14"/>
                                                        <TextBlock Text="{Binding Timestamp}" Foreground="#60FFFFFF" FontFamily="Consolas" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12"/>
                                                    </DockPanel>
                                                    <!-- 聊天消息文本 -->
                                                    <TextBlock Grid.Row="1" 
                                                               Text="{Binding ChatMessage}" 
                                                               Foreground="#FFFFFFFF" 
                                                               FontSize="15" 
                                                               LineHeight="22" 
                                                               TextWrapping="Wrap" 
                                                               FontFamily="微软雅黑"/>
                                                </Grid>
                                            </Border>

                                            <!-- 中间连接饰线 (包含左右指向的小箭头，连接两个框，尽显精致) -->
                                            <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <!-- 一条微微发光的横线 -->
                                                <Line X1="0" Y1="0" X2="30" Y2="0" Stroke="#8080D0FF" StrokeThickness="1.5" StrokeDashArray="3,3">
                                                    <Line.Effect>
                                                        <DropShadowEffect Color="#FF80D0FF" BlurRadius="5" ShadowDepth="0" Opacity="0.5"/>
                                                    </Line.Effect>
                                                </Line>
                                                <Polygon Points="26,-4 32,0 26,4" Fill="#FFA0E5FF" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <!-- 右侧事实校验块 -->
                                            <Border Grid.Column="2" 
                                                    Style="{StaticResource FactBubbleBorderStyle}"
                                                    Padding="20">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- 事实头部与状态 -->
                                                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                                        <ContentControl DockPanel.Dock="Left" Margin="0,0,5,0" VerticalAlignment="Center">
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Verified}">
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Text="🛡️" Margin="0,0,4,0" FontSize="14"/>
                                                                                        <TextBlock Text="已证实" Foreground="#FF47FF7D" FontWeight="Bold" FontSize="13" FontFamily="微软雅黑"/>
                                                                                    </StackPanel>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Unverified}">
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Text="⚠️" Margin="0,0,4,0" FontSize="14"/>
                                                                                        <TextBlock Text="未证实" Foreground="#FFFFE600" FontWeight="Bold" FontSize="13" FontFamily="微软雅黑"/>
                                                                                    </StackPanel>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Contradicted}">
                                                                            <Setter Property="Content">
                                                                                <Setter.Value>
                                                                                    <StackPanel Orientation="Horizontal">
                                                                                        <TextBlock Text="❌" Margin="0,0,4,0" FontSize="14"/>
                                                                                        <TextBlock Text="冲突" Foreground="#FFFF4747" FontWeight="Bold" FontSize="13" FontFamily="微软雅黑"/>
                                                                                    </StackPanel>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                        <TextBlock Text="{Binding Source, StringFormat='来源: {0}'}" Foreground="#80FFFFFF" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                    </DockPanel>

                                                    <!-- 事实描述文本 -->
                                                    <TextBlock Grid.Row="1" 
                                                               Text="{Binding FactMessage}" 
                                                               Foreground="#FFFFFFFF" 
                                                               FontSize="14" 
                                                               LineHeight="20" 
                                                               TextWrapping="Wrap" 
                                                               FontFamily="微软雅黑"
                                                               Margin="0,0,0,12"/>

                                                    <!-- 置信度显示 -->
                                                    <Grid Grid.Row="2">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                                            <TextBlock Text="校验可信度" Foreground="#60FFFFFF" FontSize="11" FontFamily="微软雅黑"/>
                                                            <TextBlock Text="{Binding Confidence, StringFormat={}{0:P0}}" Foreground="#FFFFFFFF" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                                        </DockPanel>
                                                        <!-- 自适应精细进度条 -->
                                                        <ProgressBar Grid.Row="1" Height="3" Minimum="0" Maximum="1" Value="{Binding Confidence}" Background="#15FFFFFF" BorderThickness="0">
                                                            <ProgressBar.Style>
                                                                <Style TargetType="ProgressBar">
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Verified}">
                                                                            <Setter Property="Foreground" Value="#FF47FF7D"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Unverified}">
                                                                            <Setter Property="Foreground" Value="#FFFFE600"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding Severity}" Value="{x:Static vm:FactSeverity.Contradicted}">
                                                                            <Setter Property="Foreground" Value="#FFFF4747"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ProgressBar.Style>
                                                        </ProgressBar>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 右侧：控制板以及草稿中的装饰长条 -->
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <!-- 控制板内容 -->
                                <ColumnDefinition Width="*"/>
                                <!-- 最右侧的炫彩高光竖条 (完美还原草稿 Path_4) -->
                                <ColumnDefinition Width="35"/>
                            </Grid.ColumnDefinitions>

                            <!-- 控制板 -->
                            <Grid Grid.Column="0">
                                <Grid.RowDefinitions>
                                    <!-- 简介说明 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- 调试面板 -->
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 简介说明 -->
                                <Border Grid.Row="0" 
                                        BorderThickness="1" 
                                        BorderBrush="#30FFFFFF" 
                                        Background="#15000000" 
                                        CornerRadius="12" 
                                        Padding="15" 
                                        Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="关于 GROUNDING 进度" Foreground="#FFA0E5FF" FontWeight="Bold" FontSize="13" Margin="0,0,0,8" FontFamily="微软雅黑"/>
                                        <TextBlock Text="实时展示后台正在执行的事实比对与校验任务队列，您可以查看当前步骤与进度百分比。" 
                                                   Foreground="#A0FFFFFF" FontSize="12" TextWrapping="Wrap" LineHeight="18" FontFamily="微软雅黑"/>
                                    </StackPanel>
                                </Border>

                                <!-- 未完成 Grounding 进度面板 -->
                                <Border Grid.Row="1" 
                                        BorderThickness="1" 
                                        BorderBrush="#4080D0FF" 
                                        Background="#180F1D32" 
                                        CornerRadius="16" 
                                        Padding="20">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 面板头部 -->
                                        <TextBlock Grid.Row="0" Text="PENDING TASKS / Grounding 进度" Foreground="#FFA0E5FF" FontWeight="Bold" FontSize="13" Margin="0,0,0,15" FontFamily="微软雅黑"/>

                                        <!-- 未完成的 Grounding 列表视图 -->
                                        <ListBox Grid.Row="1"
                                                 ItemsSource="{Binding PendingGroundings}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Background" Value="Transparent"/>
                                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="ItemBorder"
                                                                        Background="#12FFFFFF"
                                                                        BorderBrush="#25FFFFFF"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Padding="15,12"
                                                                        Margin="0,0,0,10"
                                                                        SnapsToDevicePixels="True">
                                                                    <VisualStateManager.VisualStateGroups>
                                                                        <VisualStateGroup x:Name="CommonStates">
                                                                            <VisualState x:Name="Normal" />
                                                                            <VisualState x:Name="MouseOver">
                                                                                <Storyboard>
                                                                                    <ColorAnimation Storyboard.TargetName="ItemBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#25FFFFFF" Duration="0:0:0.15"/>
                                                                                    <ColorAnimation Storyboard.TargetName="ItemBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#55FFFFFF" Duration="0:0:0.15"/>
                                                                                </Storyboard>
                                                                            </VisualState>
                                                                        </VisualStateGroup>
                                                                        <VisualStateGroup x:Name="SelectionStates">
                                                                            <VisualState x:Name="Unselected" />
                                                                            <VisualState x:Name="Selected">
                                                                                <Storyboard>
                                                                                    <ColorAnimation Storyboard.TargetName="ItemBorder" Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" To="#35FFFFFF" Duration="0:0:0.15"/>
                                                                                    <ColorAnimation Storyboard.TargetName="ItemBorder" Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)" To="#9000C3FF" Duration="0:0:0.15"/>
                                                                                </Storyboard>
                                                                            </VisualState>
                                                                        </VisualStateGroup>
                                                                    </VisualStateManager.VisualStateGroups>
                                                                    <ContentPresenter />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>
                                                        
                                                        <!-- 任务名称和剩余时间 -->
                                                        <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                                            <TextBlock Text="{Binding TaskName}" Foreground="White" FontSize="13" FontWeight="Bold" DockPanel.Dock="Left" TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding EtaText}" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Right" DockPanel.Dock="Right" FontFamily="Consolas"/>
                                                        </DockPanel>
                                                        
                                                        <!-- 当前状态 -->
                                                        <TextBlock Grid.Row="1" Text="{Binding StatusText}" Foreground="#FFA0E5FF" FontSize="11.5" Margin="0,0,0,8" FontFamily="微软雅黑"/>
                                                        
                                                        <!-- 进度条和百分比 -->
                                                        <Grid Grid.Row="2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="45"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ProgressBar Height="4" Minimum="0" Maximum="1" Value="{Binding Progress}" Foreground="#FF00C3FF" Background="#15FFFFFF" BorderThickness="0" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding Progress, StringFormat={}{0:P0}}" Foreground="White" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas"/>
                                                        </Grid>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- 最右侧的炫彩高光竖条 (完美还原草稿 Path_4) -->
                            <Grid Grid.Column="1" HorizontalAlignment="Right" Margin="15,0,0,0">
                                <Border Width="16" 
                                        BorderThickness="1" 
                                        BorderBrush="{StaticResource SidebarDecorBorderBrush}" 
                                        Background="{StaticResource SidebarDecorBackgroundBrush}" 
                                        CornerRadius="8" 
                                        Height="Auto" 
                                        VerticalAlignment="Stretch">
                                    <Border.Effect>
                                        <!-- 高科技呼吸辉光效果 -->
                                        <DropShadowEffect Color="#80FFFFFF" BlurRadius="8" ShadowDepth="0" Opacity="0.5"/>
                                    </Border.Effect>
                                    <!-- 内部点缀一个小高亮块，可视为状态呼吸指示器 -->
                                    <Border Width="8" Height="24" CornerRadius="4" Background="#FF00C3FF" Margin="0,15,0,0" VerticalAlignment="Top">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#FF00C3FF" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                                        </Border.Effect>
                                    </Border>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
