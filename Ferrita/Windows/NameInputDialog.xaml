<Window x:Class="Ferrita.Windows.NameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource NameInput.Title}"
        Width="440"
        Height="210"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Ferrita;component/Resources/Ferrita.ico"
        Background="{DynamicResource Layer_1}">
    <Border Padding="16"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Background="{DynamicResource Layer_1}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="PromptTextBlock"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12"
                       Text="{DynamicResource NameInput.Prompt}"/>

            <TextBlock Grid.Row="1"
                       Text="{DynamicResource NameInput.Label}"
                       Margin="0,0,0,6"/>

            <TextBox x:Name="ValueTextBox"
                     Grid.Row="2"
                     Height="30"
                     VerticalContentAlignment="Center"
                     Margin="0,0,0,12"/>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="ConfirmButton"
                        Width="92"
                        Height="30"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="ConfirmButton_Click"
                        Content="{DynamicResource Common.Confirm}"/>
                <Button Width="92"
                        Height="30"
                        IsCancel="True"
                        Content="{DynamicResource Common.Cancel}"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
