<Window x:Class="Ferrita.Windows.ToolConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource ToolConfirmation.Title}"
        Width="740"
        SizeToContent="Height"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Icon="/Ferrita;component/Resources/Ferrita.ico">
    <Window.Background>
        <SolidColorBrush Color="#FF111326"/>
    </Window.Background>

    <Window.Resources>
        <LinearGradientBrush x:Key="DialogBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF191D3A" Offset="0"/>
            <GradientStop Color="#FF231B40" Offset="0.52"/>
            <GradientStop Color="#FF0B0B19" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShellBorderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#AAFFFFFF" Offset="0"/>
            <GradientStop Color="#45FFFFFF" Offset="0.36"/>
            <GradientStop Color="#669B8CCF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#E722173A" Offset="0"/>
            <GradientStop Color="#D61E1532" Offset="0.44"/>
            <GradientStop Color="#CC0F1123" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ContentFrameBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#4E314B77" Offset="0"/>
            <GradientStop Color="#35223349" Offset="0.5"/>
            <GradientStop Color="#28111A2B" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="{StaticResource DialogBackgroundBrush}"/>

        <Ellipse Width="540"
                 Height="360"
                 Margin="-180,-120,0,0"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Fill="#304153C2">
            <Ellipse.Effect>
                <BlurEffect Radius="120"/>
            </Ellipse.Effect>
        </Ellipse>

        <Ellipse Width="620"
                 Height="420"
                 Margin="0,0,-220,-160"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Fill="#1E7638B5">
            <Ellipse.Effect>
                <BlurEffect Radius="140"/>
            </Ellipse.Effect>
        </Ellipse>

        <Rectangle Opacity="0.45">
            <Rectangle.Fill>
                <VisualBrush TileMode="Tile" Viewport="0,0,6,6" ViewportUnits="Absolute">
                    <VisualBrush.Visual>
                        <Canvas Width="6" Height="6" Background="Transparent">
                            <Ellipse Width="1.4" Height="1.4" Fill="#15FFFFFF" Canvas.Left="0" Canvas.Top="0"/>
                            <Ellipse Width="1.4" Height="1.4" Fill="#15FFFFFF" Canvas.Left="3" Canvas.Top="3"/>
                        </Canvas>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Grid Margin="20">
            <Border CornerRadius="18"
                    Background="{StaticResource ShellBackgroundBrush}"
                    BorderBrush="{StaticResource ShellBorderBrush}"
                    BorderThickness="1.2">
                <Grid>
                    <Border Margin="1"
                            Height="88"
                            VerticalAlignment="Top"
                            CornerRadius="17,17,10,10"
                            Opacity="0.72"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#43FFFFFF" Offset="0"/>
                                <GradientStop Color="#18FFFFFF" Offset="0.58"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <Border Margin="1"
                            Height="28"
                            VerticalAlignment="Bottom"
                            CornerRadius="0,0,17,17"
                            Opacity="0.9"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <RadialGradientBrush RadiusX="0.9" RadiusY="1.7" Center="0.5,1" GradientOrigin="0.5,1">
                                <GradientStop Color="#3AA585FF" Offset="0"/>
                                <GradientStop Color="#00A585FF" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <Grid Margin="24,18">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="300"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <TextBlock Text="{DynamicResource ToolConfirmation.Title}"
                                       FontFamily="{DynamicResource AeroFontFamily}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"/>
                            <TextBlock x:Name="PromptTextBlock"
                                       Margin="0,10,0,0"
                                       FontFamily="{DynamicResource AeroFontFamily}"
                                       FontSize="13"
                                       Foreground="#F2F7FFFF"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="MetadataTextBlock"
                                       Margin="0,8,0,0"
                                       FontFamily="{DynamicResource AeroFontFamily}"
                                       FontSize="12"
                                       Foreground="#D4DDF8FF"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Grid.Row="2"
                                CornerRadius="14"
                                Background="{StaticResource ContentFrameBrush}"
                                BorderBrush="#6E86AEE2"
                                BorderThickness="1">
                            <Grid>
                                <Border Margin="1"
                                        CornerRadius="13"
                                        Opacity="0.45"
                                        IsHitTestVisible="False">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#34FFFFFF" Offset="0"/>
                                            <GradientStop Color="#10FFFFFF" Offset="0.35"/>
                                            <GradientStop Color="#00FFFFFF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>

                                <ScrollViewer Padding="18,16"
                                              VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="False">
                                    <StackPanel>
                                        <ContentControl x:Name="InvocationPreviewHost"
                                                        HorizontalContentAlignment="Stretch"/>

                                        <Border x:Name="InvocationXmlSection"
                                                Margin="0,14,0,0"
                                                Padding="14,12"
                                                CornerRadius="12"
                                                Background="#2C101A2D"
                                                BorderBrush="#5E7DA7DA"
                                                BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="{DynamicResource ToolConfirmation.FullInvocationXml}"
                                                           FontFamily="{DynamicResource AeroFontFamily}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFF3F8FF"/>
                                                <TextBlock x:Name="InvocationXmlTextBlock"
                                                           Margin="0,8,0,0"
                                                           FontFamily="Consolas, Microsoft YaHei UI"
                                                           FontSize="12.5"
                                                           Foreground="#FFF7FBFF"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="4"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <Button Width="118"
                                    Height="34"
                                    Margin="0,0,10,0"
                                    IsDefault="True"
                                    Click="ApproveButton_Click"
                                    Content="{DynamicResource ToolConfirmation.AllowExecution}"/>
                            <Button Width="96"
                                    Height="34"
                                    IsCancel="True"
                                    Click="RejectButton_Click"
                                    Content="{DynamicResource Common.Cancel}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
