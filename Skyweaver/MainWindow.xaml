<Window x:Class="Skyweaver.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:Skyweaver.Controls"
        xmlns:local="clr-namespace:Skyweaver"
        xmlns:documentWorkspace="clr-namespace:Skyweaver.Panels.DocumentWorkspace.Views"
        xmlns:liveTasks="clr-namespace:Skyweaver.Panels.LiveTasks.Views"
        xmlns:multiFunctionArea="clr-namespace:Skyweaver.Panels.MultiFunctionArea.Views"
        xmlns:sessionList="clr-namespace:Skyweaver.Panels.SessionList.Views"
        xmlns:notifications="clr-namespace:Skyweaver.Services.Notifications"
        xmlns:session="clr-namespace:Skyweaver.PageControls.Session.Views"
        xmlns:desk="clr-namespace:Skyweaver.PageControls.Desk.Views"
        xmlns:marvelous="clr-namespace:Skyweaver.PageControls.Marvelous.Views"
        xmlns:tiles="clr-namespace:Skyweaver.PageControls.Tiles.Views"
        xmlns:sessionVm="clr-namespace:Skyweaver.PageControls.Session.ViewModels"
        xmlns:deskVm="clr-namespace:Skyweaver.PageControls.Desk.ViewModels"
        xmlns:marvelousVm="clr-namespace:Skyweaver.PageControls.Marvelous.ViewModels"
        xmlns:tilesVm="clr-namespace:Skyweaver.PageControls.Tiles.ViewModels"
        mc:Ignorable="d"
        Title="{DynamicResource MainWindow.Title}" Height="720" Width="1280"
        MinHeight="576" MinWidth="1024"
        WindowState="Maximized"
        Icon="/Skyweaver;component/Resources/Skyweaver.ico" Background="#FF1A1F28">

    <Window.Resources>
        <DataTemplate DataType="{x:Type sessionVm:SessionPageViewModel}">
            <session:SessionPageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type deskVm:DeskPageViewModel}">
            <desk:DeskPageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type marvelousVm:MarvelousPageViewModel}">
            <marvelous:MarvelousPageView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type tilesVm:TilesPageViewModel}">
            <tiles:TilesPageView/>
        </DataTemplate>
    </Window.Resources>

    <!-- 任务栏图标信息 -->
    <Window.TaskbarItemInfo>
        <TaskbarItemInfo/>
    </Window.TaskbarItemInfo>

    <DockPanel>
        <!-- Ribbon区域 -->

        <!-- Ribbon区域 -->
        <Border DockPanel.Dock="Top"
                BorderBrush="{DynamicResource DarkBorderBrush}"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1.38187" StartPoint="0.5,-0.381866">
                    <GradientStop Color="#FF2E4A6C" Offset="0.325"/>
                    <GradientStop Color="#FF1D2E54" Offset="0.237"/>
                    <GradientStop Color="#FE070714" Offset="0.325"/>
                    <GradientStop Color="#FF162F67" Offset="0.562"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="120"/>
                </Grid.RowDefinitions>

                <!-- 保留原快速访问工具栏占位，维持 Ribbon 标签头的原始位置。 -->
                <Border Grid.Row="0"
                        Height="22"
                        Margin="{DynamicResource ContentPadding}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        Background="Transparent"/>

                <!-- Ribbon 标签页控件 -->
                <TabControl x:Name="RibbonTabControl" SelectionChanged="RibbonTabControl_SelectionChanged"
                             Grid.Row="1"
                             Background="{DynamicResource ToolbarBackgroundBrush}"
                             BorderThickness="{DynamicResource ZeroThickness}"
                             Height="120"
                             Margin="{DynamicResource TabControlMargin}"
                             SelectedIndex="{Binding SelectedPageIndex, Mode=TwoWay}">
                    <TabControl.Resources>
                        <Style TargetType="{x:Type TabItem}" BasedOn="{StaticResource RibbonTabStyle}"/>
                    </TabControl.Resources>
                    <TabControl.Template>
                        <ControlTemplate TargetType="{x:Type TabControl}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Tab标签头面板 -->
                                <TabPanel x:Name="HeaderPanel"
                                          Panel.ZIndex="1"
                                          IsItemsHost="True"
                                          Background="Transparent"
                                          Grid.Row="0"/>

                                <!-- Tab内容区域 -->
                                <Border x:Name="ContentPanel"
                                        Grid.Row="1"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        ClipToBounds="True">
                                    <Grid x:Name="TransitionGrid">
                                        <!-- 用于展示源页面的镜像，播放滑出动画 -->
                                        <Border x:Name="OldContentVisualHost"
                                                Visibility="Collapsed"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TranslateTransform X="0" Y="0"/>
                                            </Border.RenderTransform>
                                        </Border>

                                        <!-- 用于展示目标页面的真实内容，播放滑入动画 -->
                                        <ContentPresenter x:Name="PART_SelectedContentHost"
                                                          ContentSource="SelectedContent"
                                                          Margin="{TemplateBinding Padding}"
                                                          RenderTransformOrigin="0.5,0.5">
                                            <ContentPresenter.RenderTransform>
                                                <TranslateTransform X="0" Y="0"/>
                                            </ContentPresenter.RenderTransform>
                                        </ContentPresenter>
                                    </Grid>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </TabControl.Template>

                    <!-- 会话标签页 (状态和视图合二为一) -->
                    <TabItem Header="{DynamicResource MainWindow.Ribbon.SessionTab}">
                        <Grid>
                            <!-- 背景层 -->
                            <Border Style="{DynamicResource TabContentBorderStyle}"/>
                            <!-- 遮罩层 -->
                            <Border Background="{DynamicResource RibbonContentCoverMaskBrush}" Padding="0"/>

                            <!-- 内容层 -->
                            <StackPanel Orientation="Horizontal" Margin="8,4">
                                <!-- 状态组 -->
                                <GroupBox Header="{DynamicResource MainWindow.Ribbon.StatusTab}" Style="{DynamicResource RibbonGroupStyle}" Padding="4,2,14,2">
                                    <local:VfdClockControl Width="368"
                                                           Height="56"
                                                           HorizontalAlignment="Left"
                                                           VerticalAlignment="Center"/>
                                </GroupBox>

                                <!-- 缩放组 -->
                                <GroupBox Header="{DynamicResource MainWindow.Ribbon.ZoomGroup}" Style="{DynamicResource RibbonGroupStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Style="{DynamicResource RibbonLargeButtonStyle}"
                                                ToolTip="{DynamicResource MainWindow.Ribbon.ZoomFit.ToolTip}"
                                                Command="{Binding ZoomFitCommand}">
                                            <StackPanel>
                                                <Image Source="pack://application:,,,/Resources/zoom_fit.png" Width="32" Height="32" Margin="0,2,0,2"
                                                       RenderOptions.BitmapScalingMode="HighQuality" UseLayoutRounding="True"/>
                                                <TextBlock Text="{DynamicResource MainWindow.Ribbon.ZoomFit}" HorizontalAlignment="Center" FontSize="10"/>
                                            </StackPanel>
                                        </Button>
                                        <StackPanel>
                                            <Button Style="{DynamicResource RibbonButtonStyle}"
                                                    ToolTip="{DynamicResource MainWindow.Ribbon.ZoomIn.ToolTip}"
                                                    Command="{Binding ZoomInCommand}"
                                                    Margin="0,0,0,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="pack://application:,,,/Resources/zoom_in.png" Width="16" Height="16" Margin="0,0,4,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" UseLayoutRounding="True"/>
                                                    <TextBlock Text="{DynamicResource MainWindow.Ribbon.ZoomIn}" FontSize="10"/>
                                                </StackPanel>
                                            </Button>
                                            <Button Style="{DynamicResource RibbonButtonStyle}"
                                                    ToolTip="{DynamicResource MainWindow.Ribbon.ZoomOut.ToolTip}"
                                                    Command="{Binding ZoomOutCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Image Source="pack://application:,,,/Resources/zoom_out.png" Width="16" Height="16" Margin="0,0,4,0"
                                                           RenderOptions.BitmapScalingMode="HighQuality" UseLayoutRounding="True"/>
                                                    <TextBlock Text="{DynamicResource MainWindow.Ribbon.ZoomOut}" FontSize="10"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>

                                <!-- 显示选项组 -->
                                <GroupBox Header="{DynamicResource MainWindow.Ribbon.DisplayGroup}" Style="{DynamicResource RibbonGroupStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel>
                                            <CheckBox Content="{DynamicResource MainWindow.Ribbon.ShowGrid}" FontSize="10" Margin="4,2"/>
                                            <CheckBox Content="{DynamicResource MainWindow.Ribbon.ShowRuler}" FontSize="10" Margin="4,2"/>
                                            <CheckBox Content="{DynamicResource MainWindow.Ribbon.ShowConnections}" FontSize="10" Margin="4,2"/>
                                        </StackPanel>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- Desk 标签页 -->
                    <TabItem Header="{DynamicResource MainWindow.Ribbon.DeskTab}">
                        <Grid>
                            <Border Style="{DynamicResource TabContentBorderStyle}"/>
                            <Border Background="{DynamicResource RibbonContentCoverMaskBrush}" Padding="0"/>
                            <StackPanel Orientation="Horizontal" Margin="8,4">
                                <GroupBox Header="Desk 控制项" Style="{DynamicResource RibbonGroupStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Desk 页面占位 Ribbon 元素" Foreground="#94A3B8" FontSize="11" Margin="8,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- Marvelous 标签页 -->
                    <TabItem Header="{DynamicResource MainWindow.Ribbon.MarvelousTab}">
                        <Grid>
                            <Border Style="{DynamicResource TabContentBorderStyle}"/>
                            <Border Background="{DynamicResource RibbonContentCoverMaskBrush}" Padding="0"/>
                            <StackPanel Orientation="Horizontal" Margin="8,4">
                                <GroupBox Header="Marvelous 控制项" Style="{DynamicResource RibbonGroupStyle}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="Marvelous 页面占位 Ribbon 元素" Foreground="#D8B4FE" FontSize="11" Margin="8,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </Grid>
                    </TabItem>

                    <!-- Tiles 标签页 -->
                    <TabItem Header="{DynamicResource MainWindow.Ribbon.TilesTab}">
                        <Grid>
                            <Border Style="{DynamicResource TabContentBorderStyle}"/>
                            <Border Background="{DynamicResource RibbonContentCoverMaskBrush}" Padding="0"/>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Border>

        <!-- 状态栏 -->
        <StatusBar DockPanel.Dock="Bottom" Style="{DynamicResource AeroStatusBarStyle}" Height="27">
            <!-- Start -->
            <StatusBar.Resources>
                <!-- 常驻通知项的模板 -->
                <DataTemplate DataType="{x:Type notifications:PermanentNotificationItem}">
                    <Border Background="#1A202C" BorderBrush="#3D4B66" BorderThickness="1" CornerRadius="4" Padding="6,2" Margin="4,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 状态圆点 (带呼吸灯/变色效果) -->
                            <Ellipse Width="8" Height="8" Margin="2,0,6,0" VerticalAlignment="Center">
                                <Ellipse.Fill>
                                    <SolidColorBrush x:Name="DotBrush" Color="#00E676"/>
                                </Ellipse.Fill>
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Progress}" Value="{x:Null}">
                                                <DataTrigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <ColorAnimation Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                                                            From="#00E676" To="#00B0FF" Duration="0:0:1.5" AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            
                            <TextBlock Text="{Binding Message}" Foreground="#E2E8F0" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            
                            <!-- 进度显示 -->
                            <ContentControl Content="{Binding}" VerticalAlignment="Center">
                                <ContentControl.Style>
                                    <Style TargetType="ContentControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Progress}" Value="{x:Null}">
                                                <Setter Property="ContentTemplate">
                                                    <Setter.Value>
                                                        <DataTemplate>
                                                            <ProgressBar IsIndeterminate="True" 
                                                                         Width="50" Height="4" Margin="0,0,4,0" VerticalAlignment="Center"
                                                                         Background="#2D3748" BorderThickness="0">
                                                                <ProgressBar.Foreground>
                                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                        <GradientStop Color="#A0AEC0" Offset="0"/>
                                                                        <GradientStop Color="#E2E8F0" Offset="1"/>
                                                                    </LinearGradientBrush>
                                                                </ProgressBar.Foreground>
                                                            </ProgressBar>
                                                        </DataTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                        <Setter Property="ContentTemplate">
                                            <Setter.Value>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ProgressBar Value="{Binding Progress, Mode=OneWay}" Minimum="0" Maximum="100" 
                                                                     Width="50" Height="4" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                     Background="#2D3748" BorderThickness="0">
                                                            <ProgressBar.Foreground>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Color="#00F2FE" Offset="0"/>
                                                                    <GradientStop Color="#4FACFE" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </ProgressBar.Foreground>
                                                        </ProgressBar>
                                                        <TextBlock Text="{Binding Progress, StringFormat={}{0:0}%}" Foreground="#38BDF8" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContentControl.Style>
                            </ContentControl>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </StatusBar.Resources>

            <!-- 右侧常驻通知区域 -->
            <StatusBarItem DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                <ItemsControl ItemsSource="{Binding NotificationService.ActivePermanentNotifications}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </StatusBarItem>

            <!-- 左侧一过性通知区域 -->
            <StatusBarItem HorizontalAlignment="Left" VerticalAlignment="Center">
                <StatusBarItem.Style>
                    <Style TargetType="StatusBarItem" BasedOn="{StaticResource AeroStatusBarItemStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding NotificationService.CurrentTransientMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding NotificationService.CurrentTransientMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StatusBarItem.Style>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M11,10H13V18H11V10M11,6H13V8H11V6Z" 
                          Fill="#38BDF8" Width="14" Height="14" Stretch="Uniform" Margin="4,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding NotificationService.CurrentTransientMessage, NotifyOnTargetUpdated=True}" 
                               Foreground="#E2E8F0" FontSize="11" VerticalAlignment="Center">
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0.0" To="1.0" Duration="0:0:0.4"/>
                                        <DoubleAnimation Storyboard.TargetProperty="(RenderTransform).(TranslateTransform.X)"
                                                         From="-15" To="0" Duration="0:0:0.35">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                        <TextBlock.RenderTransform>
                            <TranslateTransform X="0"/>
                        </TextBlock.RenderTransform>
                    </TextBlock>
                </StackPanel>
            </StatusBarItem>









        </StatusBar>

        <!-- 主工作区域 -->
        <Grid>
            <controls:CachedPageContentControl x:Name="MainPageContentHost"
                                               PageContent="{Binding CurrentPageViewModel}"/>
            <ContentControl x:Name="PageWarmupHost"
                            Width="1280"
                            Height="720"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Opacity="0.001"
                            IsHitTestVisible="False"
                            Focusable="False"
                            Visibility="Collapsed"
                            Panel.ZIndex="10"/>
        </Grid>
    </DockPanel>
</Window>
