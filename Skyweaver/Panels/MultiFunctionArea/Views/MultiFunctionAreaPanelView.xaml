<UserControl x:Class="Skyweaver.Panels.MultiFunctionArea.Views.MultiFunctionAreaPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:Skyweaver.Panels.MultiFunctionArea.Converters"
             xmlns:models="clr-namespace:Skyweaver.Panels.MultiFunctionArea.Models"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="420">
    <UserControl.Resources>
        <converters:TabDefinitionAvailabilityMultiConverter x:Key="TabDefinitionAvailabilityConverter"/>

        <Style x:Key="WorkspaceDocumentTabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border"
                                BorderBrush="#FF000000"
                                BorderThickness="1"
                                CornerRadius="3,3,0,0"
                                Margin="0,0,2,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.499993,0" EndPoint="0.499993,1">
                                    <GradientStop Color="#FF435A69" Offset="0"/>
                                    <GradientStop Color="#FF374D5A" Offset="0.517625"/>
                                    <GradientStop Color="#FE334853" Offset="0.528757"/>
                                    <GradientStop Color="#FF324551" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="0"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  ContentSource="Header"
                                                  Margin="{TemplateBinding Padding}"/>

                                <Button x:Name="CloseButton"
                                        Grid.Column="1"
                                        Width="16"
                                        Height="16"
                                        Margin="4,0,4,0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Content="×"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="White"
                                        Cursor="Hand"
                                        Visibility="Hidden"
                                        Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="Transparent" CornerRadius="2">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"
                                                                              Margin="0,-2,0,0"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Foreground" Value="Red"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)" To="#FF5A7085" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)" To="#FF4C6370" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[2].(GradientStop.Color)" To="#FE485E69" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[3].(GradientStop.Color)" To="#FF475B67" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)" To="#FF435A69" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)" To="#FF374D5A" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[2].(GradientStop.Color)" To="#FE334853" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[3].(GradientStop.Color)" To="#FF324551" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CloseButton" Property="Visibility" Value="Visible"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)" To="#28FFFFFF" Duration="0:0:0.3"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)" To="#35CEEEFF" Duration="0:0:0.3"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[2].(GradientStop.Color)" To="#652D4957" Duration="0:0:0.3"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[3].(GradientStop.Color)" To="#FF6FD4D1" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[0].(GradientStop.Color)" To="#FF435A69" Duration="0:0:0.3"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[1].(GradientStop.Color)" To="#FF374D5A" Duration="0:0:0.3"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[2].(GradientStop.Color)" To="#FE334853" Duration="0:0:0.3"/>
                                            <ColorAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(Border.Background).(LinearGradientBrush.GradientStops)[3].(GradientStop.Color)" To="#FF324551" Duration="0:0:0.3"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="CloseButton" Property="Visibility" Value="Visible"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate DataType="{x:Type models:MultiFunctionTabDefinition}">
            <Grid Width="320">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="42"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="30"
                        Height="30"
                        Margin="4,0,8,0"
                        VerticalAlignment="Center"
                        CornerRadius="6"
                        Background="#22000000">
                    <Image Source="{Binding IconPath}" Stretch="Uniform" Margin="4"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="0,2,0,2">
                    <TextBlock Text="{Binding Title}"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Margin="0,4,0,0"
                               Text="{Binding Description}"
                               FontSize="11"
                               Foreground="#CCFFFFFF"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Border Style="{DynamicResource WorkAreaStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource ToolbarBackgroundBrush}"
                    BorderBrush="{DynamicResource TransparentBrush}"
                    BorderThickness="0"
                    Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{DynamicResource MultiFunctionArea.Title}"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="{DynamicResource LightTextBrush}"
                               FontFamily="{DynamicResource AeroFontFamily}"
                               FontSize="{DynamicResource AeroFontSize}"/>

                    <Button x:Name="CreateTabButton"
                            Grid.Column="1"
                            Style="{DynamicResource SmallRibbonButtonStyle}"
                            Width="88"
                            Height="24"
                            ToolTip="{DynamicResource MultiFunctionArea.CreateTab}"
                            Click="CreateTabButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{DynamicResource MultiFunctionArea.CreateTab}" FontSize="10"/>
                            <TextBlock Text=" ▼" FontSize="8" Margin="2,0,0,0" VerticalAlignment="Bottom"/>
                        </StackPanel>
                        <Button.ContextMenu>
                            <ContextMenu Style="{DynamicResource AnimatedContextMenuStyle}"
                                         DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                         ItemsSource="{Binding AvailableTabDefinitions}"
                                          Placement="Bottom">
                                <ContextMenu.ItemContainerStyle>
                                    <Style TargetType="MenuItem" BasedOn="{StaticResource AnimatedMenuItemStyle}">
                                        <Setter Property="Command" Value="{Binding DataContext.CreateTabCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                        <Setter Property="CommandParameter" Value="{Binding TypeKey}"/>
                                        <Setter Property="IsEnabled">
                                            <Setter.Value>
                                                <MultiBinding Converter="{StaticResource TabDefinitionAvailabilityConverter}">
                                                    <Binding/>
                                                    <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=ContextMenu}"/>
                                                </MultiBinding>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ContextMenu.ItemContainerStyle>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                </Grid>
            </Border>

            <TabControl Grid.Row="1"
                        Background="{DynamicResource DocumentTabBackgroundBrush}"
                        BorderThickness="0"
                        ItemsSource="{Binding OpenedTabs}"
                        SelectedItem="{Binding ActiveTab, Mode=TwoWay}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource WorkspaceDocumentTabItemStyle}"/>
                </TabControl.Resources>
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" ToolTip="{Binding Subtitle}">
                            <Border Width="18"
                                    Height="18"
                                    Margin="0,0,6,0"
                                    CornerRadius="3"
                                    Background="#22000000">
                                <Image Source="{Binding IconPath}" Stretch="Uniform" Margin="3"/>
                            </Border>
                            <TextBlock Text="{Binding Title}"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <Grid>
                            <Border Visibility="{Binding ContentViewModel, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}">
                                <Border.Background>
                                    <ImageBrush ImageSource="pack://application:,,,/Resources/aurora.png" Stretch="Fill"/>
                                </Border.Background>
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#B0000000" Offset="0"/>
                                            <GradientStop Color="#90000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="24" Foreground="White" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding Subtitle}" FontSize="13" Foreground="#FFDDEFFF" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                        <TextBlock Text="{Binding PlaceholderText}" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Border>
                            <ContentControl Content="{Binding ContentViewModel}"/>
                        </Grid>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>
        </Grid>
    </Border>
</UserControl>
