<UserControl x:Class="Skyweaver.Panels.SessionList.Views.SessionListPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="320">
    <Border Style="{DynamicResource WorkAreaStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource ToolbarBackgroundBrush}"
                    BorderBrush="{DynamicResource TransparentBrush}"
                    BorderThickness="0"
                    Padding="8,5">
                <TextBlock Text="{DynamicResource SessionList.Title}"
                           FontWeight="Bold"
                           Foreground="{DynamicResource LightTextBrush}"
                           FontFamily="{DynamicResource AeroFontFamily}"
                           FontSize="{DynamicResource AeroFontSize}"/>
            </Border>

            <Border Grid.Row="1"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF2A3240" Offset="0"/>
                        <GradientStop Color="#FF1A1F28" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1.15*"/>
                        <ColumnDefinition Width="1.15*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            ToolTip="{DynamicResource SessionList.Create.ToolTip}"
                            Style="{StaticResource ResourceToolbarButtonStyle}"
                            Height="32"
                            Margin="0,0,6,0"
                            HorizontalContentAlignment="Stretch"
                            Command="{Binding CreateSessionCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="pack://application:,,,/Resources/NewNodeGraphAlt.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{DynamicResource SessionList.Create}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource PrimaryForeground}"/>
                        </Grid>
                    </Button>

                    <Button Grid.Column="1"
                            ToolTip="{DynamicResource SessionList.Delete.ToolTip}"
                            Style="{StaticResource ResourceToolbarButtonStyle}"
                            Height="32"
                            Margin="3,0"
                            HorizontalContentAlignment="Stretch"
                            Command="{Binding DeleteSessionCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="pack://application:,,,/Resources/delete_node.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{DynamicResource SessionList.Delete}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource PrimaryForeground}"/>
                        </Grid>
                    </Button>

                    <Button Grid.Column="2"
                            ToolTip="{DynamicResource SessionList.Search.ToolTip}"
                            Style="{StaticResource ResourceToolbarButtonStyle}"
                            Height="32"
                            Margin="6,0,0,0"
                            HorizontalContentAlignment="Stretch"
                            Command="{Binding SearchSessionCommand}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="pack://application:,,,/Resources/Refresh.png"
                                   Width="16"
                                   Height="16"
                                   Margin="0,0,4,0"
                                   VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{DynamicResource SessionList.Search}"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{DynamicResource PrimaryForeground}"/>
                        </Grid>
                    </Button>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="8,6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF1A1F28" Offset="0"/>
                        <GradientStop Color="#FF141924" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <TextBox x:Name="SearchTitleTextBox"
                             Height="24"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryForeground}"
                               IsHitTestVisible="False"
                               Text="{DynamicResource SessionList.SearchPlaceholder}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Text, ElementName=SearchTitleTextBox}" Value=""/>
                                            <Condition Binding="{Binding IsKeyboardFocusWithin, ElementName=SearchTitleTextBox}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Row="3" Style="{DynamicResource ResourcePanelStyle}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FF141924" Offset="0"/>
                        <GradientStop Color="#FF0F1419" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <ListBox Margin="4"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{DynamicResource SessionHistoryItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Background="Transparent">
                                <Grid.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.OpenSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="3" Margin="0,0,8,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FF3A4250" Offset="0"/>
                                            <GradientStop Color="#FF2A3240" Offset="0.5"/>
                                            <GradientStop Color="#FF1A1F28" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Image Source="{Binding IconPath}" Stretch="Uniform" Margin="4"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="Medium"
                                               FontSize="12"
                                               FontFamily="Segoe UI, Microsoft YaHei UI, Arial"
                                               Foreground="{DynamicResource PrimaryForeground}"/>
                                    <TextBlock Text="{Binding TimeLabel}"
                                               FontSize="10"
                                               FontFamily="Segoe UI, Microsoft YaHei UI, Arial"
                                               Foreground="{DynamicResource SecondaryForeground}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Border>
</UserControl>
