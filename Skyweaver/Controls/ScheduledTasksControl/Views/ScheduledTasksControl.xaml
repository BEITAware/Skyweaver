<UserControl x:Class="Skyweaver.Controls.ScheduledTasksControl.Views.ScheduledTasksControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:Skyweaver.Controls.ScheduledTasksControl.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- Plasma 背景 DrawingBrush 定义 -->
        <DrawingBrush x:Key="PlasmaBackgroundBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 1,0.999878L 400.999,0.999878L 400.999,223L 1,223L 1,0.999878 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="2" LineJoin="Round" Brush="#FF2A7288"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Brush>
                                <RadialGradientBrush RadiusX="0.9594" RadiusY="1.23497" Center="0.500009,-0.0053194" GradientOrigin="0.500009,-0.0053194">
                                    <RadialGradientBrush.GradientStops>
                                        <GradientStop Color="#FF306F83" Offset="0"/>
                                        <GradientStop Color="#FF091023" Offset="0.992337"/>
                                    </RadialGradientBrush.GradientStops>
                                </RadialGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- IdleDateBG 画刷集成 -->
        <DrawingBrush x:Key="IdleDateBGPaint" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 0.252197,0.283936L 74.6287,0.283936L 74.6287,63.1609L 0.252197,63.1609L 0.252197,0.283936 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="1" LineJoin="Round" Brush="#FF000000"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Brush>
                                <RadialGradientBrush RadiusX="2.15219" RadiusY="1.68352" Center="0.499961,0.992731" GradientOrigin="0.499961,0.992731">
                                    <RadialGradientBrush.GradientStops>
                                        <GradientStop Color="#29FFFFFF" Offset="0"/>
                                        <GradientStop Color="#00000004" Offset="0.380334"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.41744"/>
                                        <GradientStop Color="#5EFFFFFF" Offset="0.769944"/>
                                        <GradientStop Color="#4AFFFFFF" Offset="0.892393"/>
                                    </RadialGradientBrush.GradientStops>
                                </RadialGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <!-- SelectedDateBG 画刷集成 -->
        <DrawingBrush x:Key="SelectedDateBGPaint" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 2,-0.000244141L 24.8135,-0.000244141C 25.9182,-0.000244141 26.8137,0.894775 26.8137,1.99976L 26.8137,24.0413C 26.8137,25.1458 25.9182,26.0413 24.8135,26.0413L 2,26.0413C 0.895264,26.0413 0,25.1458 0,24.0413L 0,1.99976C 0,0.894775 0.895264,-0.000244141 2,-0.000244141 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="1" LineJoin="Round" Brush="#FFA0ABB9"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0.499995,-1.84559" EndPoint="0.499995,2.84557">
                                    <LinearGradientBrush.GradientStops>
                                        <GradientStop Color="#99C5CCDD" Offset="0.323124"/>
                                        <GradientStop Color="#99A0AECA" Offset="0.356815"/>
                                        <GradientStop Color="#7528536E" Offset="0.482389"/>
                                        <GradientStop Color="#A401263F" Offset="0.494637"/>
                                        <GradientStop Color="#A6286D89" Offset="0.620214"/>
                                    </LinearGradientBrush.GradientStops>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>


        <!-- Aero ListBox/ListView 边框与内阴影样式 -->
        <Style x:Key="AeroListBoxStyle" TargetType="ListBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#35000000"/>
            <Setter Property="BorderBrush" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Grid>
                            <!-- 背景圆角边框 -->
                            <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            
                            <!-- 顶部内阴影 -->
                            <Border CornerRadius="6,6,0,0" Height="12" VerticalAlignment="Top" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#50000000" Offset="0"/>
                                        <GradientStop Color="#20000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 左侧内阴影 -->
                            <Border CornerRadius="6,0,0,6" Width="8" HorizontalAlignment="Left" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#30000000" Offset="0"/>
                                        <GradientStop Color="#15000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 右侧内阴影 -->
                            <Border CornerRadius="0,6,6,0" Width="8" HorizontalAlignment="Right" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="1,0" EndPoint="0,0">
                                        <GradientStop Color="#30000000" Offset="0"/>
                                        <GradientStop Color="#15000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 底部内阴影 -->
                            <Border CornerRadius="0,0,6,6" Height="8" VerticalAlignment="Bottom" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,1" EndPoint="0,0">
                                        <GradientStop Color="#25000000" Offset="0"/>
                                        <GradientStop Color="#08000000" Offset="0.5"/>
                                        <GradientStop Color="#00000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <ScrollViewer Margin="6" Focusable="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Aero ListViewItem 样式 -->
        <Style x:Key="AeroListViewItemStyle" TargetType="ListViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid Margin="0,0,0,3">
                            <!-- 悬停状态背景 -->
                            <Border x:Name="HoverBackground" Opacity="0" CornerRadius="3" BorderThickness="1">
                                <Border.BorderBrush>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#FF5984AD" Offset="0"/>
                                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#374588BD" Offset="0"/>
                                        <GradientStop Color="#081AD5FF" Offset="0.69"/>
                                        <GradientStop Color="#1FFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 选中状态背景 -->
                            <Border x:Name="SelectedBackground" Opacity="0" CornerRadius="3" BorderThickness="1">
                                <Border.BorderBrush>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#FF5984AD" Offset="0"/>
                                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#A34588BD" Offset="0"/>
                                        <GradientStop Color="#111AD5FF" Offset="0.69"/>
                                        <GradientStop Color="#31FFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 列内容展示 -->
                            <GridViewRowPresenter Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SelectedBackground" Property="Opacity" Value="1"/>
                                <Setter TargetName="HoverBackground" Property="Opacity" Value="0"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 晶莹剔透发光画笔 -->
        <LinearGradientBrush x:Key="AeroGlassBorderBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#50FFFFFF" Offset="0"/>
            <GradientStop Color="#15FFFFFF" Offset="0.5"/>
            <GradientStop Color="#30FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#15000000"/>
            <Setter Property="BorderBrush" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <Style x:Key="DetailsLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFA2D6FF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>

        <Style x:Key="DetailsValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Aero ListBoxItem 样式 -->
        <Style x:Key="AeroListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid Margin="0,0,0,4">
                            <!-- 悬停状态背景 -->
                            <Border x:Name="HoverBackground" Opacity="0" CornerRadius="3" BorderThickness="1">
                                <Border.BorderBrush>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#FF5984AD" Offset="0"/>
                                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#374588BD" Offset="0"/>
                                        <GradientStop Color="#081AD5FF" Offset="0.69"/>
                                        <GradientStop Color="#1FFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 选中状态背景 -->
                            <Border x:Name="SelectedBackground" Opacity="0" CornerRadius="3" BorderThickness="1">
                                <Border.BorderBrush>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#FF5984AD" Offset="0"/>
                                        <GradientStop Color="#FFFFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.BorderBrush>
                                <Border.Background>
                                    <RadialGradientBrush RadiusX="1.18" RadiusY="1.1" Center="0.5,-0.2" GradientOrigin="0.5,-0.2">
                                        <GradientStop Color="#A34588BD" Offset="0"/>
                                        <GradientStop Color="#111AD5FF" Offset="0.69"/>
                                        <GradientStop Color="#31FFFFFF" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>
                            
                            <!-- 内容呈现器 -->
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedBackground" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SelectedBackground" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SelectedBackground" Property="Opacity" Value="1"/>
                                <Setter TargetName="HoverBackground" Property="Opacity" Value="0"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 任务胶囊边框样式 -->
        <Style x:Key="CapsuleBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource PlasmaBackgroundBrush}">
        <Grid Margin="16">
            <Grid.RowDefinitions>
                <!-- 工具栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 计划任务列表 (上半部分) -->
                <RowDefinition Height="*"/>
                <!-- 分割线 -->
                <RowDefinition Height="12"/>
                <!-- 日历与详情 (下半部分) -->
                <RowDefinition Height="1.2*"/>
            </Grid.RowDefinitions>

            <!-- 1. 工具栏 -->
            <Border Grid.Row="0" BorderThickness="0,0,0,1" BorderBrush="#20FFFFFF" Padding="0,0,0,12" Margin="0,0,0,12">
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="新建任务..." Width="100" Height="28" Margin="0,0,8,0" Style="{DynamicResource ResourceToolbarButtonStyle}" Click="NewTask_Click"/>
                        <Button Content="编辑任务" Width="80" Height="28" Margin="0,0,8,0" Style="{DynamicResource ResourceToolbarButtonStyle}" Click="EditTask_Click" IsEnabled="{Binding IsTaskSelected}"/>
                        <Button Content="删除任务" Width="80" Height="28" Style="{DynamicResource ResourceToolbarButtonStyle}" Click="DeleteTask_Click" IsEnabled="{Binding IsTaskSelected}"/>
                    </StackPanel>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="计划任务面板" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 2. 上半部：现存的计划任务列表 -->
            <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}" Padding="2">
                <ListView x:Name="TasksListView" ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask, Mode=TwoWay}"
                          Style="{StaticResource AeroListBoxStyle}" ItemContainerStyle="{StaticResource AeroListViewItemStyle}" Foreground="White">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="任务名称" Width="140">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="White"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="关联会话流" Width="130" DisplayMemberBinding="{Binding SessionFlowName}"/>
                            <GridViewColumn Header="触发器条件" Width="180" DisplayMemberBinding="{Binding TriggersDisplayText}"/>
                            <GridViewColumn Header="前置动作" Width="120" DisplayMemberBinding="{Binding PreAction.DisplayText}"/>
                            <GridViewColumn Header="后置动作" Width="120" DisplayMemberBinding="{Binding PostAction.DisplayText}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- 分割线 -->
            <Grid Grid.Row="2" VerticalAlignment="Center">
                <Separator Background="#20FFFFFF"/>
            </Grid>

            <!-- 3. 下半部：日历 (左) 与 选中日期的任务清单/详情 (右) -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <!-- 日历面板 -->
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="16"/>
                    <!-- 任务详情 -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- A. 左侧：晶莹剔透日历面板 -->
                <Border Grid.Column="0" Style="{StaticResource SectionBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 月份切换栏 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 星期头 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 日历日期网格 (6x7) -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 月份切换 -->
                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Button Content="&lt;" HorizontalAlignment="Left" Width="36" Height="26" Style="{DynamicResource ResourceToolbarButtonStyle}" Click="PrevMonth_Click"/>
                            <TextBlock Text="{Binding CurrentMonthYearText}" Foreground="White" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <Button Content="&gt;" HorizontalAlignment="Right" Width="36" Height="26" Style="{DynamicResource ResourceToolbarButtonStyle}" Click="NextMonth_Click"/>
                        </Grid>

                        <!-- 星期头 -->
                        <Grid Grid.Row="1" Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="日" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="一" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="二" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="三" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="四" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="五" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="六" Foreground="#80FFFFFF" FontSize="11" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- 日期网格 -->
                        <Grid x:Name="CalendarDayGrid" Grid.Row="2" ShowGridLines="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                        </Grid>
                    </Grid>
                </Border>

                <!-- B. 右侧：选中日期的任务清单/详情 -->
                <Border Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <TextBlock Text="{Binding SelectedDateText, StringFormat='{}{0} 活跃任务'}" Foreground="White" FontSize="13" FontWeight="Bold"/>
                            <TextBlock Text="点击日历日期可以切换查看不同日期的激活任务详情。" FontSize="10" Foreground="#80FFFFFF"/>
                        </StackPanel>

                        <!-- 任务详情卡片或列表 -->
                        <Grid Grid.Row="1">
                            <!-- 空数据占位 -->
                            <TextBlock Text="该日期没有被激活的计划任务。" Foreground="#60FFFFFF" FontSize="12" FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Visibility="{Binding NoTasksPlaceholderVisibility}"/>

                            <!-- 有数据时的展示 -->
                            <ListBox ItemsSource="{Binding SelectedDateTasks}"
                                     Style="{StaticResource AeroListBoxStyle}"
                                     ItemContainerStyle="{StaticResource AeroListBoxItemStyle}"
                                     Visibility="{Binding TasksListVisibility}"
                                     HorizontalContentAlignment="Stretch"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="2,4">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <!-- 第一行：标题 -->
                                            <Grid Grid.Row="0" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="13" FontWeight="Bold"/>
                                            </Grid>

                                            <!-- 第二行：关联流与提示词 -->
                                            <StackPanel Grid.Row="1" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding SessionFlowName, StringFormat='关联会话流：{0}'}" Foreground="#B0FFFFFF" FontSize="11"/>
                                                <TextBlock Text="{Binding Prompt, StringFormat='任务提示词：{0}'}" Foreground="#80FFFFFF" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- 第三行：胶囊标签组 -->
                                            <WrapPanel Grid.Row="2">
                                                <!-- 触发条件胶囊 -->
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding TriggersDisplayText, StringFormat='触发：{0}'}" Foreground="#FFA2D6FF"/>
                                                </Border>
                                                <!-- 前置动作胶囊 -->
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding PreAction.DisplayText, StringFormat='前置：{0}'}" Foreground="#FFA2D6FF"/>
                                                </Border>
                                                <!-- 后置动作胶囊 -->
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center" FontSize="11" Text="{Binding PostAction.DisplayText, StringFormat='后置：{0}'}" Foreground="#FFA2D6FF"/>
                                                </Border>
                                            </WrapPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
