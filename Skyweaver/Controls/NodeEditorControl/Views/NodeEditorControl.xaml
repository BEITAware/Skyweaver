<UserControl x:Class="Skyweaver.Controls.NodeEditorControl.Views.NodeEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.NodeEditorControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:NodeEditorControlViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="450"
             d:DesignWidth="800"
             Focusable="True">
    <Grid>
        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#1F3449">
            <Grid Width="{Binding Surface.CanvasWidth}"
                  Height="{Binding Surface.CanvasHeight}">
                <Grid.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding Surface.Scale}"
                                        ScaleY="{Binding Surface.Scale}"/>
                        <TranslateTransform X="{Binding Surface.OffsetX}"
                                            Y="{Binding Surface.OffsetY}"/>
                    </TransformGroup>
                </Grid.RenderTransform>

                <Grid.Background>
                    <DrawingBrush TileMode="Tile"
                                  Viewport="0,0,1,4"
                                  ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>
                                <GeometryDrawing>
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,0,1,1"/>
                                    </GeometryDrawing.Geometry>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#1F3449"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                                <GeometryDrawing>
                                    <GeometryDrawing.Geometry>
                                        <RectangleGeometry Rect="0,1,1,1"/>
                                    </GeometryDrawing.Geometry>
                                    <GeometryDrawing.Brush>
                                        <SolidColorBrush Color="#010303"/>
                                    </GeometryDrawing.Brush>
                                </GeometryDrawing>
                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Grid.Background>

                <Canvas Width="{Binding Surface.CanvasWidth}"
                        Height="{Binding Surface.CanvasHeight}"
                        Panel.ZIndex="1"
                        Background="Transparent"
                        IsHitTestVisible="False"/>

                <Canvas Width="{Binding Surface.CanvasWidth}"
                        Height="{Binding Surface.CanvasHeight}"
                        Panel.ZIndex="2"
                        Background="Transparent"/>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
