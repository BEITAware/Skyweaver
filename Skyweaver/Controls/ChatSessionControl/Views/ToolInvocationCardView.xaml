<UserControl x:Class="Skyweaver.Controls.ChatSessionControl.Views.ToolInvocationCardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:toolModels="clr-namespace:Skyweaver.Services.SkyweaverTools"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="180"
             d:DesignWidth="420">
    <UserControl.Resources>
        <LinearGradientBrush x:Key="ToolInvocationCardBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#72354954" Offset="0"/>
            <GradientStop Color="#60324451" Offset="0.38"/>
            <GradientStop Color="#4A20303C" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ToolInvocationCardTopSheenBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#54FFFFFF" Offset="0"/>
            <GradientStop Color="#18FFFFFF" Offset="0.45"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ToolInvocationCardBottomGlowBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0019D2FF" Offset="0"/>
            <GradientStop Color="#1223C8E7" Offset="0.42"/>
            <GradientStop Color="#3838C4D8" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ToolInvocationFieldIdleBrush"
                             StartPoint="0.438,5.527"
                             EndPoint="0.438,-4.527">
            <GradientStop Color="#91007BFF" Offset="0.143"/>
            <GradientStop Color="#00FFFFFF" Offset="0.503"/>
            <GradientStop Color="#C30099FF" Offset="0.792"/>
        </LinearGradientBrush>

        <Style x:Key="ToolInvocationFieldBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="{StaticResource ToolInvocationFieldIdleBrush}"/>
            <Setter Property="BorderBrush" Value="#660D1320"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="ToolInvocationStreamingBadgeBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
            <Setter Property="BorderBrush" Value="#55A9FFF7"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Border CornerRadius="4"
            Background="{StaticResource ToolInvocationCardBackgroundBrush}"
            BorderBrush="#365F7E8E"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <Border Height="40"
                    Margin="1"
                    VerticalAlignment="Top"
                    CornerRadius="3,3,2,2"
                    Background="{StaticResource ToolInvocationCardTopSheenBrush}"
                    IsHitTestVisible="False"
                    Opacity="0.74"/>
            <Border Height="18"
                    Margin="1"
                    VerticalAlignment="Bottom"
                    CornerRadius="0,0,3,3"
                    Background="{StaticResource ToolInvocationCardBottomGlowBrush}"
                    IsHitTestVisible="False"
                    Opacity="0.88"/>
            <StackPanel Margin="12">
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="32"
                            Height="32"
                            Margin="0,0,8,0"
                            Background="{DynamicResource ButtonIdleBrush}"
                            BorderBrush="#0036D9D1"
                            BorderThickness="1"
                            CornerRadius="5"
                            VerticalAlignment="Top">
                        <Image Source="{Binding IconPath}"
                               Stretch="Uniform"
                               Margin="4"/>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{Binding State.ToolName}"
                                   FontFamily="{DynamicResource AeroFontFamily}"
                                   FontSize="{DynamicResource AeroLargeFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="#FFF5FAFF"
                                   TextWrapping="Wrap"/>
                        <TextBlock Margin="0,2,0,0"
                                   Text="{Binding Description}"
                                   FontFamily="{DynamicResource AeroFontFamily}"
                                   FontSize="{DynamicResource AeroFontSize}"
                                   Foreground="#FFD6E8FF"
                                   TextWrapping="Wrap"/>
                        <TextBlock Margin="0,4,0,0"
                                   FontFamily="{DynamicResource AeroFontFamily}"
                                   FontSize="{DynamicResource AeroSmallFontSize}"
                                   Foreground="#FFE2FFF8">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Receiving parameters"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.IsInvocationClosed}" Value="True">
                                            <Setter Property="Text" Value="Parameters received, waiting for tool result"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding State.HasToolResult}" Value="True">
                                            <Setter Property="Text" Value="Tool result received"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>

                <ItemsControl ItemsSource="{Binding Fields}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFields}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ToolInvocationFieldBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Top"
                                               FontFamily="{DynamicResource AeroFontFamily}"
                                               FontSize="{DynamicResource AeroFontSize}"
                                               Foreground="#FFE7F3FF"
                                               TextWrapping="Wrap"
                                               Text="{Binding Label}"/>

                                    <Grid Grid.Column="1">
                                        <TextBlock Text="{Binding Parameter.Value}"
                                                   FontFamily="Consolas, Microsoft YaHei UI"
                                                   FontSize="12"
                                                   Foreground="#FFF7FBFF"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Parameter.HasValue}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text="{Binding EmptyValueText}"
                                                   FontFamily="{DynamicResource AeroFontFamily}"
                                                   FontSize="{DynamicResource AeroFontSize}"
                                                   Foreground="#CCEAF7FF"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Parameter.HasValue}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <Border Grid.Column="2">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource ToolInvocationStreamingBadgeBorderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Parameter.IsStreaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Streaming"
                                                   FontFamily="{DynamicResource AeroFontFamily}"
                                                   FontSize="{DynamicResource AeroSmallFontSize}"
                                                   Foreground="#FFF5FAFF"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl ItemsSource="{Binding State.Parameters}">
                    <ItemsControl.Style>
                        <Style TargetType="ItemsControl">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasFields}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ItemsControl.Style>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ToolInvocationFieldBorderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Top"
                                               FontFamily="{DynamicResource AeroFontFamily}"
                                               FontSize="{DynamicResource AeroFontSize}"
                                               Foreground="#FFE7F3FF"
                                               TextWrapping="Wrap"
                                               Text="{Binding Name}"/>

                                    <Grid Grid.Column="1">
                                        <TextBlock Text="{Binding Value}"
                                                   FontFamily="Consolas, Microsoft YaHei UI"
                                                   FontSize="12"
                                                   Foreground="#FFF7FBFF"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasValue}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Text="Waiting for parameter..."
                                                   FontFamily="{DynamicResource AeroFontFamily}"
                                                   FontSize="{DynamicResource AeroFontSize}"
                                                   Foreground="#CCEAF7FF"
                                                   FontStyle="Italic"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasValue}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>

                                    <Border Grid.Column="2">
                                        <Border.Style>
                                            <Style TargetType="Border" BasedOn="{StaticResource ToolInvocationStreamingBadgeBorderStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Streaming"
                                                   FontFamily="{DynamicResource AeroFontFamily}"
                                                   FontSize="{DynamicResource AeroSmallFontSize}"
                                                   Foreground="#FFF5FAFF"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Margin="0,8,0,0"
                        Padding="10,8"
                        Background="#1A08131A"
                        BorderBrush="#4438C4D8"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State.HasToolProgress}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{Binding State.ToolProgressPhase}"
                                           FontFamily="{DynamicResource AeroFontFamily}"
                                           FontSize="{DynamicResource AeroSmallFontSize}"
                                           FontWeight="SemiBold"
                                           Foreground="#FFD6E8FF">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding State.ToolProgressPhase}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Margin="0,2,0,0"
                                           Text="{Binding State.ToolProgressStatusText}"
                                           FontFamily="{DynamicResource AeroFontFamily}"
                                           FontSize="{DynamicResource AeroFontSize}"
                                           Foreground="#FFEAFDFF"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       Text="{Binding State.ToolProgressCountText}"
                                       FontFamily="Consolas, Microsoft YaHei UI"
                                       FontSize="12"
                                       Foreground="#FFE2FFF8"
                                       VerticalAlignment="Top">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding State.HasToolProgressCount}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <ProgressBar Margin="0,8,0,0"
                                     Height="6"
                                     Minimum="0"
                                     Maximum="100"
                                     Value="{Binding State.ToolProgressValue, Mode=OneWay}"
                                     IsIndeterminate="{Binding State.IsToolProgressIndeterminate, Mode=OneWay}"/>

                        <ScrollViewer Margin="0,8,0,0"
                                      MaxHeight="96"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.HasToolProgressActiveItems}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                            <ItemsControl ItemsSource="{Binding State.ToolProgressActiveItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,3"
                                                   Text="{Binding}"
                                                   FontFamily="Consolas, Microsoft YaHei UI"
                                                   FontSize="12"
                                                   Foreground="#FFF7FBFF"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Margin="0,8,0,0"
                        Padding="10,8"
                        Background="#1A08131A"
                        BorderBrush="#4438C4D8"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding State.HasToolResult}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Text="Result"
                                   FontFamily="{DynamicResource AeroFontFamily}"
                                   FontSize="{DynamicResource AeroSmallFontSize}"
                                   FontWeight="SemiBold"
                                   Foreground="#FFD6E8FF"/>

                        <ItemsControl Margin="0,8,0,0"
                                      ItemsSource="{Binding State.ToolResultDiffLines}"
                                      ItemTemplate="{StaticResource SkyweaverDiffLineTemplate}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.HasToolResultDiffLines}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                        </ItemsControl>

                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding State.ToolResultContent}"
                                   Foreground="#FFEAFDFF"
                                   FontFamily="Consolas, Microsoft YaHei UI"
                                   FontSize="13"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding State.HasToolResultText}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
