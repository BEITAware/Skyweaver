<UserControl x:Class="Skyweaver.Controls.ChatSessionControl.Views.ChatSessionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Skyweaver.Controls.ChatSessionControl.Views"
             xmlns:models="clr-namespace:Skyweaver.Controls.ChatSessionControl.Models"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.ChatSessionControl.ViewModels"
             x:Name="Root"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ChatSessionControlViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource AeroScrollBarV2Style}"/>
        <Style TargetType="ScrollViewer" BasedOn="{StaticResource AeroScrollViewerV2Style}"/>

        <DrawingBrush x:Key="ChatSoftGlassSliceBrush" Stretch="Uniform">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 0.160156,0.159668L 1386.16,0.159668L 1386.16,223.646L 0.160156,223.646L 0.160156,0.159668 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="0.32" LineJoin="Round" Brush="#FF000000"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0.10059,1.65236" EndPoint="2.53982,1.65236">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TransformGroup>
                                            <SkewTransform CenterX="0.10059" CenterY="1.65236" AngleX="-59.7491" AngleY="0"/>
                                            <RotateTransform CenterX="0.10059" CenterY="1.65236" Angle="-70.8836"/>
                                        </TransformGroup>
                                    </LinearGradientBrush.RelativeTransform>
                                    <LinearGradientBrush.GradientStops>
                                        <GradientStop Color="#3BFFFFFF" Offset="0"/>
                                        <GradientStop Color="#1DFFFFFF" Offset="0.0766283"/>
                                        <GradientStop Color="#07FFFFFF" Offset="0.109195"/>
                                        <GradientStop Color="#04FFFFFF" Offset="0.298851"/>
                                        <GradientStop Color="#3AFFFFFF" Offset="0.327586"/>
                                        <GradientStop Color="#1AFFFFFF" Offset="0.465517"/>
                                        <GradientStop Color="#14FFFFFF" Offset="0.591954"/>
                                        <GradientStop Color="#05FFFFFF" Offset="0.758621"/>
                                        <GradientStop Color="#44FFFFFF" Offset="1"/>
                                    </LinearGradientBrush.GradientStops>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <RadialGradientBrush x:Key="ChatHeaderButtonIdleBrush"
                             RadiusX="2.152"
                             RadiusY="1.684"
                             Center="0.5,0.993"
                             GradientOrigin="0.5,0.993">
            <GradientStop Color="#26FFFFFF" Offset="0"/>
            <GradientStop Color="#00000004" Offset="0.38"/>
            <GradientStop Color="#00FFFFFF" Offset="0.417"/>
            <GradientStop Color="#56D4FFF9" Offset="0.77"/>
            <GradientStop Color="#4A8CF1E4" Offset="0.892"/>
        </RadialGradientBrush>

        <LinearGradientBrush x:Key="ChatHeaderButtonHoverBrush"
                             StartPoint="0.5,-0.667875"
                             EndPoint="0.5,1.66787">
            <GradientStop Color="#00FFFFFF" Offset="0"/>
            <GradientStop Color="#1AFFFFFF" Offset="0.135436"/>
            <GradientStop Color="#14FFFFFF" Offset="0.487941"/>
            <GradientStop Color="#00000004" Offset="0.517625"/>
            <GradientStop Color="#FF2AAE9A" Offset="0.729128"/>
        </LinearGradientBrush>

        <DrawingBrush x:Key="ChatHeaderButtonPressedBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <EllipseGeometry Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Brush>
                                <RadialGradientBrush RadiusX="0.5"
                                                     RadiusY="0.833333"
                                                     Center="0.5,0.5"
                                                     GradientOrigin="0.5,0.5">
                                    <GradientStop Color="#FF76F1E4" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="0.662338"/>
                                    <RadialGradientBrush.RelativeTransform>
                                        <RotateTransform CenterX="0.5" CenterY="0.5" Angle="-90"/>
                                    </RadialGradientBrush.RelativeTransform>
                                </RadialGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,1"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0.5,-0.667873" EndPoint="0.5,1.66787">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#1AFFFFFF" Offset="0.135436"/>
                                    <GradientStop Color="#14FFFFFF" Offset="0.487941"/>
                                    <GradientStop Color="#00000004" Offset="0.517625"/>
                                    <GradientStop Color="#FF29E1C8" Offset="0.717996"/>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="ChatHeaderButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Foreground" Value="#FFF4FFFD"/>
            <Setter Property="Background" Value="{StaticResource ChatHeaderButtonIdleBrush}"/>
            <Setter Property="BorderBrush" Value="#FF000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Arial"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter x:Name="contentPresenter"
                                              Focusable="False"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        TargetName="border"
                                        Value="{StaticResource ChatHeaderButtonHoverBrush}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="#552FFFF2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background"
                                        TargetName="border"
                                        Value="{StaticResource ChatHeaderButtonPressedBrush}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="#6634FFF0"/>
                                <Setter Property="Opacity" TargetName="border" Value="0.96"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="0.97"
                                                             Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.97"
                                                             Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.0"
                                                             Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.0"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" TargetName="border" Value="0.45"/>
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatMessageContextMenuItemStyle"
               TargetType="MenuItem"
               BasedOn="{StaticResource AnimatedMenuItemStyle}">
            <Setter Property="MinWidth" Value="360"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuNameTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF5FEFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuDescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="Width" Value="248"/>
            <Setter Property="Foreground" Value="#B9E8FAFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#55283A4D"/>
            <Setter Property="BorderBrush" Value="#8896FCFF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuIconTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFF4FEFF"/>
        </Style>

        <ContextMenu x:Key="ChatMessageContextMenu"
                     x:Shared="False"
                     Style="{DynamicResource AnimatedContextMenuStyle}"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.RemoveMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <Border Style="{StaticResource ChatMessageContextMenuIconBadgeStyle}"
                            Background="#66321418"
                            BorderBrush="#99FFB1B1">
                        <TextBlock Text="DEL"
                                   Style="{StaticResource ChatMessageContextMenuIconTextStyle}"
                                   Foreground="#FFFFD4D4"/>
                    </Border>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="删除" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="删除这条消息，不可恢复，不再进入代理的上下文。"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <Border Style="{StaticResource ChatMessageContextMenuIconBadgeStyle}">
                        <TextBlock Text="CPY" Style="{StaticResource ChatMessageContextMenuIconTextStyle}"/>
                    </Border>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="复制" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="复制当前消息，包含 Markdown 格式与工具调用。"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.CopyMessageAsMarkdownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <Border Style="{StaticResource ChatMessageContextMenuIconBadgeStyle}"
                            Background="#55342452"
                            BorderBrush="#9989C6FF">
                        <TextBlock Text="MD"
                                   Style="{StaticResource ChatMessageContextMenuIconTextStyle}"
                                   Foreground="#FFE7DDFF"/>
                    </Border>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="复制为 Markdown" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="复制当前消息，移除工具调用。"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.CopyMessageAsPlainTextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <Border Style="{StaticResource ChatMessageContextMenuIconBadgeStyle}"
                            Background="#55322E12"
                            BorderBrush="#99FFD982">
                        <TextBlock Text="TXT"
                                   Style="{StaticResource ChatMessageContextMenuIconTextStyle}"
                                   Foreground="#FFFFE7BF"/>
                    </Border>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="复制为纯文本" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="复制当前消息，移除 Markdown 格式和工具调用。"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.EditMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <Border Style="{StaticResource ChatMessageContextMenuIconBadgeStyle}"
                            Background="#55212F21"
                            BorderBrush="#998FE9B9">
                        <TextBlock Text="EDT"
                                   Style="{StaticResource ChatMessageContextMenuIconTextStyle}"
                                   Foreground="#FFD6FFE5"/>
                    </Border>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="编辑" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="编辑此消息。"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="ChatHeaderCapsuleBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#332EC5C0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ChatHeaderStatusCapsuleBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ChatHeaderCapsuleBorderStyle}">
            <Setter Property="BorderBrush" Value="#44F3C96B"/>
        </Style>

        <Style x:Key="ChatHeaderCapsuleTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ChatHeaderStatusCapsuleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ChatHeaderCapsuleTextStyle}">
            <Setter Property="Foreground" Value="#FFF3E4AE"/>
        </Style>

        <LinearGradientBrush x:Key="ChatUserBubbleBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B36693B0" Offset="0"/>
            <GradientStop Color="#A63A6F8C" Offset="0.34"/>
            <GradientStop Color="#C1234966" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ChatAssistantBubbleBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B06A94AF" Offset="0"/>
            <GradientStop Color="#A040718F" Offset="0.34"/>
            <GradientStop Color="#BC203E58" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ChatBubbleTopSheenBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#66FFFFFF" Offset="0"/>
            <GradientStop Color="#22FFFFFF" Offset="0.48"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ChatBubbleBottomGlowBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0028B4FF" Offset="0"/>
            <GradientStop Color="#143BBBE8" Offset="0.42"/>
            <GradientStop Color="#4D43D8F3" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ChatMessageBubbleBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#6687CAE3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="ChatComposerTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource DefaultTextBoxStyle}">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <LinearGradientBrush x:Name="backgroundBrush" StartPoint="0.438,5.527" EndPoint="0.438,-4.527">
                                    <GradientStop x:Name="gradientStop1" Color="#91007BFF" Offset="0.143"/>
                                    <GradientStop x:Name="gradientStop2" Color="#00FFFFFF" Offset="0.503"/>
                                    <GradientStop x:Name="gradientStop3" Color="#C30099FF" Offset="0.792"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          Padding="{TemplateBinding Padding}"
                                          Style="{DynamicResource AeroScrollViewerStyle}"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource AccentColor}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="gradientStop1"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#AF00C7FF"
                                                            Duration="0:0:0.08"
                                                            EasingFunction="{StaticResource BackEaseOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop2"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#00FFFFFF"
                                                            Duration="0:0:0.08"
                                                            EasingFunction="{StaticResource ExpoEaseOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop3"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FF00ECFF"
                                                            Duration="0:0:0.08"
                                                            EasingFunction="{StaticResource BackEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop1"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.414"
                                                             Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource ExpoEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop2"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.495"
                                                             Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource ExpoEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop3"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.692"
                                                             Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource ExpoEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="gradientStop1"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#91007BFF"
                                                            Duration="0:0:0.12"
                                                            EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop2"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#00FFFFFF"
                                                            Duration="0:0:0.12"
                                                            EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop3"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#C30099FF"
                                                            Duration="0:0:0.12"
                                                            EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop1"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.143"
                                                             Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop2"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.503"
                                                             Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop3"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.792"
                                                             Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatComposerImageRemoveButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#99000000"/>
            <Setter Property="BorderBrush" Value="#66FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatMessageListItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <EventSetter Event="PreviewMouseRightButtonDown" Handler="MessageListItem_PreviewMouseRightButtonDown"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TextMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           Foreground="#FFBDEBFF"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           TextWrapping="Wrap"
                           Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"/>
                <local:MarkdownContentControl MarkdownText="{Binding Content}"
                                              Foreground="White"
                                              FontSize="14"
                                              FontFamily="Segoe UI, Microsoft YaHei UI"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="CodeMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Border Background="#24000000"
                    BorderBrush="#4496FCFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,8" LastChildFill="False">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#FFBDEBFF"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <Border DockPanel.Dock="Right"
                                Background="#22000000"
                                BorderBrush="#3388D7E8"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6,2"
                                Visibility="{Binding Language, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding Language}" Foreground="#FF9CDCFE" FontSize="11"/>
                        </Border>
                    </DockPanel>
                    <TextBlock Text="{Binding Content}"
                               Foreground="#FF9CDCFE"
                               FontFamily="Consolas"
                               FontSize="13"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StatusMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Border Background="#241C7488"
                    BorderBrush="#5584E7F4"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,8">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               Foreground="#FFBDEBFF"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"
                               TextWrapping="Wrap"
                               Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Content}"
                               Foreground="#FFE7FBFF"
                               TextWrapping="Wrap"
                               FontSize="13"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PlaceholderMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Border Background="#15000000"
                    BorderBrush="#5596FCFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               Foreground="#FFBDEBFF"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"
                               TextWrapping="Wrap"
                               Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding Content}"
                               Foreground="#CCFFFFFF"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               FontSize="13"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ToolCallMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <StackPanel>
                <ContentControl Content="{Binding ToolPresentationView}"
                                HorizontalContentAlignment="Stretch"
                                VerticalContentAlignment="Top">
                    <ContentControl.Style>
                        <Style TargetType="ContentControl">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToolPresentationView}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ContentControl.Style>
                </ContentControl>
                <TextBlock Text="{Binding Content}"
                           Foreground="#FFFFF2CF"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           FontSize="13"
                           Margin="0,8,0,0">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToolPresentationView}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Margin="0,6,0,0"
                           Foreground="#CCFFFFFF"
                           FontSize="11"
                           Text="等待工具执行回填。"
                           Visibility="{Binding IsStreaming, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ToolOutputMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Border Background="#20162B34"
                    BorderBrush="#55A8F0FF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6" LastChildFill="False">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#FFBDEBFF"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <Border DockPanel.Dock="Right"
                                Background="#22000000"
                                BorderBrush="#3388D7E8"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6,2">
                            <TextBlock Text="{Binding BadgeText}" Foreground="#FF9CDCFE" FontSize="11"/>
                        </Border>
                    </DockPanel>
                    <ItemsControl ItemsSource="{Binding ToolOutputDiffLines}"
                                  ItemTemplate="{StaticResource SkyweaverDiffLineTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasToolOutputDiffLines}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                    </ItemsControl>
                    <TextBlock Text="{Binding Content}"
                               Foreground="#FFEAFDFF"
                               TextWrapping="Wrap"
                               FontFamily="Consolas"
                               FontSize="13">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasToolOutputDiffLines}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

        <HierarchicalDataTemplate x:Key="StructuredXmlNodeTemplate"
                                  DataType="{x:Type models:ChatStructuredXmlNodeModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding DisplayText}"
                       Foreground="White"
                       FontSize="12"/>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="StructuredXmlMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Border Background="#18191F32"
                    BorderBrush="#55B0A7FF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10">
                <StackPanel>
                    <DockPanel Margin="0,0,0,6" LastChildFill="False">
                        <TextBlock Text="{Binding Title}"
                                   Foreground="#FFBDEBFF"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding Title, Converter={StaticResource NullToVisibilityConverter}}"/>
                        <Border DockPanel.Dock="Right"
                                Background="#22000000"
                                BorderBrush="#33B0A7FF"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="6,2">
                            <TextBlock Text="{Binding BadgeText}" Foreground="#FFB0A7FF" FontSize="11"/>
                        </Border>
                    </DockPanel>
                    <TreeView ItemsSource="{Binding StructuredXmlNodes}"
                              ItemTemplate="{StaticResource StructuredXmlNodeTemplate}"
                              Background="Transparent"
                              BorderThickness="0"
                              Foreground="White"/>
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding Content}"
                               Foreground="#B8FFFFFF"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasStructuredXmlNodes}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ImageMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Grid Width="156" Height="156" HorizontalAlignment="Left">
                <Border Background="{StaticResource ChatSoftGlassSliceBrush}"
                        BorderBrush="#5596FCFF"
                        BorderThickness="1"/>
                <Image Source="{Binding ResourcePath}"
                       Width="140"
                       Height="140"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ReasoningMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Grid>
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                          Background="#1414232C"
                          BorderBrush="#4476D7EE"
                          BorderThickness="1"
                          Padding="0">
                    <Expander.Style>
                        <Style TargetType="Expander">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCollapsible}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Expander.Style>
                    <Expander.Header>
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="#FFD5F5FF"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Margin="10,0,0,0"
                                       Text="{Binding BadgeText}"
                                       Foreground="#99FFFFFF"
                                       FontSize="11"/>
                        </DockPanel>
                    </Expander.Header>
                    <TextBlock Text="{Binding Content}"
                               Margin="10,8,10,10"
                               Foreground="#DDEDFBFF"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Expander>

                <Border Background="#1414232C"
                        BorderBrush="#4476D7EE"
                        BorderThickness="1"
                        Padding="10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCollapsible}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <DockPanel LastChildFill="False"
                                   Margin="0,0,0,6">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="#FFD5F5FF"
                                       FontWeight="SemiBold"
                                       FontSize="12"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Margin="10,0,0,0"
                                       Text="{Binding BadgeText}"
                                       Foreground="#99FFFFFF"
                                       FontSize="11"/>
                        </DockPanel>
                        <TextBlock Text="{Binding Content}"
                                   Foreground="#DDEDFBFF"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

        <local:ChatMessagePartTemplateSelector x:Key="ChatMessagePartTemplateSelector"
                                               TextTemplate="{StaticResource TextMessagePartTemplate}"
                                               CodeTemplate="{StaticResource CodeMessagePartTemplate}"
                                               StatusTemplate="{StaticResource StatusMessagePartTemplate}"
                                               PlaceholderTemplate="{StaticResource PlaceholderMessagePartTemplate}"
                                               ToolCallTemplate="{StaticResource ToolCallMessagePartTemplate}"
                                               ToolOutputTemplate="{StaticResource ToolOutputMessagePartTemplate}"
                                               StructuredXmlTemplate="{StaticResource StructuredXmlMessagePartTemplate}"
                                               ImageTemplate="{StaticResource ImageMessagePartTemplate}"
                                               ReasoningTemplate="{StaticResource ReasoningMessagePartTemplate}"/>

        <DataTemplate x:Key="BubbleMessageContentTemplate" DataType="{x:Type models:ChatMessageModel}">
            <StackPanel>
                <DockPanel Margin="0,0,0,8" LastChildFill="False">
                    <TextBlock Text="{Binding DisplayName}"
                               Foreground="#FFBDEBFF"
                               FontWeight="SemiBold"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding TimestampText}"
                               Foreground="#99FFFFFF"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <ItemsControl ItemsSource="{Binding Parts}"
                              ItemTemplateSelector="{StaticResource ChatMessagePartTemplateSelector}">
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,0,8"/>
                            <Setter Property="Visibility" Value="{Binding IsUserVisible, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                </ItemsControl>
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="UserMessageTemplate" DataType="{x:Type models:ChatMessageModel}">
            <Grid Margin="0,0,0,18"
                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  ContextMenu="{StaticResource ChatMessageContextMenu}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        HorizontalAlignment="Right"
                        MaxWidth="620"
                        Margin="70,0,10,0"
                        Style="{StaticResource ChatMessageBubbleBorderStyle}"
                        Background="{StaticResource ChatUserBubbleBackgroundBrush}">
                    <Grid>
                        <Border Height="34"
                                Margin="1"
                                VerticalAlignment="Top"
                                CornerRadius="9,9,6,6"
                                Background="{StaticResource ChatBubbleTopSheenBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.72"/>
                        <Border Height="18"
                                Margin="1"
                                VerticalAlignment="Bottom"
                                CornerRadius="0,0,9,9"
                                Background="{StaticResource ChatBubbleBottomGlowBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.92"/>
                        <ContentControl Margin="15,12"
                                        Content="{Binding}"
                                        ContentTemplate="{StaticResource BubbleMessageContentTemplate}"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Width="50" Height="50" VerticalAlignment="Top">
                    <Rectangle Fill="{DynamicResource ChatAvatarBackgroundGlassBrush}" RadiusX="25" RadiusY="25"/>
                    <Border CornerRadius="25" Margin="5" Background="#22FFFFFF">
                        <Image Source="{Binding AvatarPath}" Stretch="Uniform" Margin="5"/>
                    </Border>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AssistantMessageTemplate" DataType="{x:Type models:ChatMessageModel}">
            <Grid Margin="0,0,0,18"
                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                  ContextMenu="{StaticResource ChatMessageContextMenu}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="50" Height="50" VerticalAlignment="Top">
                    <Rectangle Fill="{DynamicResource ChatAvatarBackgroundGlassBrush}" RadiusX="25" RadiusY="25"/>
                    <Border CornerRadius="25" Margin="5" Background="#22FFFFFF">
                        <Image Source="{Binding AvatarPath}" Stretch="Uniform" Margin="5"/>
                    </Border>
                </Grid>

                <Border Grid.Column="1"
                        HorizontalAlignment="Left"
                        MaxWidth="620"
                        Margin="10,0,70,0"
                        Style="{StaticResource ChatMessageBubbleBorderStyle}"
                        Background="{StaticResource ChatAssistantBubbleBackgroundBrush}">
                    <Grid>
                        <Border Height="34"
                                Margin="1"
                                VerticalAlignment="Top"
                                CornerRadius="9,9,6,6"
                                Background="{StaticResource ChatBubbleTopSheenBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.68"/>
                        <Border Height="18"
                                Margin="1"
                                VerticalAlignment="Bottom"
                                CornerRadius="0,0,9,9"
                                Background="{StaticResource ChatBubbleBottomGlowBrush}"
                                IsHitTestVisible="False"
                                Opacity="0.86"/>
                        <ContentControl Margin="15,12"
                                        Content="{Binding}"
                                        ContentTemplate="{StaticResource BubbleMessageContentTemplate}"/>
                    </Grid>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SystemMessageTemplate" DataType="{x:Type models:ChatMessageModel}">
            <Border Margin="90,0,90,18"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ContextMenu="{StaticResource ChatMessageContextMenu}"
                    Padding="14,12"
                    CornerRadius="10"
                    Background="#33111824"
                    BorderBrush="#5596FCFF"
                    BorderThickness="1">
                <ContentControl Content="{Binding}" ContentTemplate="{StaticResource BubbleMessageContentTemplate}"/>
            </Border>
        </DataTemplate>

        <local:ChatMessageTemplateSelector x:Key="ChatMessageTemplateSelector"
                                           UserTemplate="{StaticResource UserMessageTemplate}"
                                           AssistantTemplate="{StaticResource AssistantMessageTemplate}"
                                           SystemTemplate="{StaticResource SystemMessageTemplate}"/>

        <!-- 工具栏样式 -->
        <LinearGradientBrush x:Key="MediaBarGlassBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#40FFFFFF" Offset="0"/>
            <GradientStop Color="#10FFFFFF" Offset="0.45"/>
            <GradientStop Color="#00FFFFFF" Offset="0.45"/>
            <GradientStop Color="#05FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <RadialGradientBrush x:Key="ToolButtonHoverBackgroundBrush" RadiusX="1.64234" RadiusY="2.22972" Center="0.5,1.47445" GradientOrigin="0.5,1.47445">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#CB4C87AF" Offset="0.295559"/>
                <GradientStop Color="#CD162D41" Offset="0.607963"/>
                <GradientStop Color="#CD3A576E" Offset="0.638591"/>
                <GradientStop Color="#CD6E869C" Offset="0.911179"/>
            </RadialGradientBrush.GradientStops>
            <RadialGradientBrush.RelativeTransform>
                <RotateTransform CenterX="0.5" CenterY="1.47445" Angle="90"/>
            </RadialGradientBrush.RelativeTransform>
        </RadialGradientBrush>
        <SolidColorBrush x:Key="ToolButtonHoverBorderBrush" Color="#67BBDDF2"/>

        <RadialGradientBrush x:Key="ToolButtonPressedBackgroundBrush" RadiusX="1.64234" RadiusY="2.22972" Center="0.5,1.47445" GradientOrigin="0.5,1.47445">
            <RadialGradientBrush.GradientStops>
                <GradientStop Color="#CC2C577F" Offset="0.295559"/>
                <GradientStop Color="#CC061D31" Offset="0.607963"/>
                <GradientStop Color="#CC1A374E" Offset="0.638591"/>
                <GradientStop Color="#CC4E667C" Offset="0.911179"/>
            </RadialGradientBrush.GradientStops>
            <RadialGradientBrush.RelativeTransform>
                <RotateTransform CenterX="0.5" CenterY="1.47445" Angle="90"/>
            </RadialGradientBrush.RelativeTransform>
        </RadialGradientBrush>
        <SolidColorBrush x:Key="ToolButtonPressedBorderBrush" Color="#99001020"/>

        <Style x:Key="MediaToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="{TemplateBinding Background}">
                            <Border x:Name="HoverBorder" Opacity="0" CornerRadius="4" BorderThickness="2" Background="{StaticResource ToolButtonHoverBackgroundBrush}" BorderBrush="{StaticResource ToolButtonHoverBorderBrush}"/>
                            <Border x:Name="PressedBorder" Opacity="0" CornerRadius="4" BorderThickness="2" Background="{StaticResource ToolButtonPressedBackgroundBrush}" BorderBrush="{StaticResource ToolButtonPressedBorderBrush}"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PressedBorder" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Style="{DynamicResource WorkAreaStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Rectangle Grid.RowSpan="3"
                       Stretch="Fill"
                       IsHitTestVisible="False">
                <Rectangle.Fill>
                    <SolidColorBrush Color="White"/>
                </Rectangle.Fill>
                <Rectangle.Effect>
                    <local:ChatRibbonBackgroundEffect Time="{Binding RibbonTime, ElementName=Root}"
                                                      AspectRatio="{Binding RibbonAspectRatio, ElementName=Root}"/>
                </Rectangle.Effect>
            </Rectangle>

            <Rectangle Grid.RowSpan="3"
                       Fill="{DynamicResource ChatBackgroundBrush}"
                       IsHitTestVisible="False"/>

            <Border Grid.Row="0" Style="{DynamicResource ChatSessionHeaderBorderStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <WrapPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding SessionTitle}"
                                   Foreground="#FF96FCFF"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Margin="0,0,12,6"/>
                        <Border Style="{StaticResource ChatHeaderCapsuleBorderStyle}"
                                Visibility="{Binding SessionSubtitle, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding SessionSubtitle}"
                                       Style="{StaticResource ChatHeaderCapsuleTextStyle}"/>
                        </Border>
                        <Border Style="{StaticResource ChatHeaderCapsuleBorderStyle}">
                            <TextBlock Text="{Binding Messages.Count, StringFormat=当前消息 {0} 条}"
                                       Style="{StaticResource ChatHeaderCapsuleTextStyle}"/>
                        </Border>
                        <Border Style="{StaticResource ChatHeaderCapsuleBorderStyle}"
                                ToolTip="{Binding SessionFlowValidationSummary}">
                            <TextBlock Text="{Binding BoundSessionFlowName, StringFormat=会话流：{0}}"
                                       Style="{StaticResource ChatHeaderCapsuleTextStyle}"/>
                        </Border>
                        <Border Style="{StaticResource ChatHeaderStatusCapsuleBorderStyle}">
                            <TextBlock Text="{Binding ExecutionStatusText}"
                                       Style="{StaticResource ChatHeaderStatusCapsuleTextStyle}"/>
                        </Border>
                    </WrapPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                        <Button Style="{StaticResource ChatHeaderButtonStyle}" Content="取消执行" Command="{Binding CancelExecutionCommand}"/>
                        <Button Style="{StaticResource ChatHeaderButtonStyle}" Content="删除选中" Command="{Binding RemoveSelectedMessageCommand}"/>
                        <Button Style="{StaticResource ChatHeaderButtonStyle}" Content="清空" Command="{Binding ClearMessagesCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="10,10,10,8">
                <Border Background="#18000000"
                        BorderBrush="#3396FCFF"
                        BorderThickness="1"
                        CornerRadius="2"/>

                <ListBox x:Name="MessagesList"
                         ItemsSource="{Binding Messages}"
                         SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
                         ItemTemplateSelector="{StaticResource ChatMessageTemplateSelector}"
                         ItemContainerStyle="{StaticResource ChatMessageListItemStyle}"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="12"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="这里还没有消息，可以先在下方输入一条用户消息，然后发送并让会话流开始执行。"
                           Margin="26"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#AAFFFFFF"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Visibility="{Binding IsEmpty, Converter={StaticResource BooleanToVisibilityConverter}}"/>
            </Grid>

            <Border Grid.Row="2"
                    Margin="10,0,10,10"
                    Padding="12"
                    Background="{DynamicResource ChatSessionHeaderBackgroundBrush}"
                    BorderBrush="#3396FCFF"
                    BorderThickness="1"
                    CornerRadius="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding ComposerHintText}"
                                   Foreground="#99FFFFFF"
                                   FontSize="11"
                                   Margin="0,0,0,8"/>
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding PendingComposerImages}"
                                      Margin="0,0,0,8"
                                      Visibility="{Binding HasPendingComposerImages, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:ChatComposerAttachmentModel}">
                                    <Grid Width="88" Height="88" Margin="0,0,8,0">
                                        <Border Background="{StaticResource ChatSoftGlassSliceBrush}"
                                                BorderBrush="#5596FCFF"
                                                BorderThickness="1"/>
                                        <Image x:Name="AttachmentPreview"
                                               Source="{Binding PreviewSourcePath}"
                                               Width="68"
                                               Height="68"
                                               Stretch="Uniform"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                        <StackPanel x:Name="AttachmentLabel"
                                                    Width="72"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding KindLabel}"
                                                       HorizontalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FF96FCFF"/>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Margin="0,6,0,0"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       FontSize="10"
                                                       Foreground="#E6FFFFFF"/>
                                        </StackPanel>
                                        <Button HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Style="{StaticResource ChatComposerImageRemoveButtonStyle}"
                                                Content="X"
                                                Command="{Binding DataContext.RemoveComposerImageCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsImage}" Value="True">
                                            <Setter TargetName="AttachmentPreview" Property="Visibility" Value="Visible"/>
                                            <Setter TargetName="AttachmentLabel" Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- 顶部工具栏 -->
                        <Border Grid.Row="2" Background="{StaticResource MediaBarGlassBrush}" BorderBrush="#80FFFFFF" BorderThickness="1" Margin="0,0,0,8" CornerRadius="3" Padding="10,5">
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding AddImageCommand}" Style="{StaticResource MediaToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Skyweaver;component/Resources/image.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="添加图片" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                                <Button Command="{Binding AddClipboardCommand}" Style="{StaticResource MediaToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Skyweaver;component/Resources/imagealt.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="添加剪贴板" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>

                                <Rectangle Width="1" Height="20" Fill="#33FFFFFF" Margin="5,0"/>

                                <Button Command="{Binding AddAudioCommand}" Style="{StaticResource MediaToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Skyweaver;component/Resources/RawImage.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="语音" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>

                                <Rectangle Width="1" Height="20" Fill="#33FFFFFF" Margin="5,0"/>

                                <Button Style="{StaticResource MediaToolbarButtonStyle}">
                                    <StackPanel Orientation="Horizontal">
                                        <Image Source="pack://application:,,,/Skyweaver;component/Resources/imgpp.png" Width="20" Height="20" Margin="0,0,5,0"/>
                                        <TextBlock Text="添加文件" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="128"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="ComposerTextBox"
                                     Style="{StaticResource ChatComposerTextBoxStyle}"
                                     Text="{Binding DraftMessageText, UpdateSourceTrigger=PropertyChanged}"
                                     Height="82"
                                     Padding="10"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Disabled"
                                     Background="#14000000"
                                     Foreground="White"
                                     BorderBrush="#5596FCFF"
                                     BorderThickness="1"
                                      DataObject.Pasting="ComposerTextBox_Pasting"
                                      PreviewKeyDown="ComposerTextBox_PreviewKeyDown"/>

                            <Button Grid.Column="1"
                                    Margin="10,0,0,0"
                                    Style="{DynamicResource ChatSessionSendButtonStyle}"
                                    Content="{Binding ComposerPrimaryButtonText}"
                                    Command="{Binding ComposerPrimaryCommand}"
                                    Tag="{Binding IsComposerPrimaryButtonLatched}"/>

                            <Button Grid.Column="1"
                                    Visibility="Collapsed"
                                    Margin="10,0,0,0"
                                    Style="{StaticResource ChatHeaderButtonStyle}"
                                    Content="取消执行"
                                    Command="{Binding CancelExecutionCommand}"/>

                            <Button Grid.Column="1"
                                    Visibility="Collapsed"
                                    Margin="10,0,0,0"
                                    Style="{DynamicResource ChatSessionSendButtonStyle}"
                                    Content="发送"
                                    Command="{Binding SendMessageCommand}"
                                    />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
