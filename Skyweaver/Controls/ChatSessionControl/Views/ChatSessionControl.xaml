                        <TextBlock Text="{Binding Content}"
                                   Foreground="#DDEDFBFF"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>

