        <RadialGradientBrush x:Key="MediaResourceCardBackgroundBrush"
                             RadiusX="1.01282"
                             RadiusY="0.917797"
                             Center="0.499999,0.977749"
                             GradientOrigin="0.499999,0.977749">
            <GradientStop Color="#C5C9CACA" Offset="0"/>
            <GradientStop Color="#34445E7C" Offset="0.988506"/>
            <RadialGradientBrush.RelativeTransform>
                <TransformGroup>
                    <SkewTransform CenterX="0.499999" CenterY="0.977749" AngleX="5.23486" AngleY="0"/>
                    <RotateTransform CenterX="0.499999" CenterY="0.977749" Angle="70.494"/>
