            <LinearGradientBrush.RelativeTransform>
                <TransformGroup>
                    <SkewTransform CenterX="0.0274601" CenterY="0.229455" AngleX="6.38202" AngleY="0"/>
                    <RotateTransform CenterX="0.0274601" CenterY="0.229455" Angle="32.3018"/>
                </TransformGroup>
            </LinearGradientBrush.RelativeTransform>
            <LinearGradientBrush.GradientStops>
                <GradientStop Color="#00FFFFFF" Offset="0"/>
                <GradientStop Color="#2CFFFFFF" Offset="0.254789"/>
                <GradientStop Color="#00FFFFFF" Offset="0.513412"/>
                <GradientStop Color="#39FFFFFF" Offset="0.701149"/>
                <GradientStop Color="#00FFFFFF" Offset="0.720307"/>
                <GradientStop Color="#33FFFFFF" Offset="0.856322"/>
                <GradientStop Color="#03FFFFFF" Offset="0.89272"/>
                <GradientStop Color="#00FFFFFF" Offset="0.988506"/>
            </LinearGradientBrush.GradientStops>
        </LinearGradientBrush>

        <DataTemplate x:Key="MediaResourceMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Border MinWidth="260"
                    MaxWidth="520"
                    HorizontalAlignment="Left"
                    Background="{StaticResource MediaResourceCardBackgroundBrush}"
                    BorderBrush="#6793F2FF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="12">
                <Grid>
                    <!-- 水印图 -->
                    <Image Source="pack://application:,,,/Skyweaver;component/Resources/DocumentCardBackgroundSheen.png"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Top"
                           Opacity="0.2"
                           Stretch="None"
                           IsHitTestVisible="False">
                        <Image.RenderTransform>
                            <MatrixTransform Matrix="0.478556,-0.138427,0.138427,0.478556,-0.000640869,70.8747"/>
                        </Image.RenderTransform>
                    </Image>

                    <!-- 顶部微光高光 -->
                    <Border Background="{StaticResource MediaResourceCardTopSheenBrush}"
                            CornerRadius="7"
                            IsHitTestVisible="False"/>

                    <!-- 对角线反射高光 -->
                    <Border Background="{StaticResource MediaResourceCardHighlightBrush}"
                            Opacity="0.95"
                            CornerRadius="7"
                            IsHitTestVisible="False"/>

                    <Grid Margin="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="46"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 图标区域 -->
                        <Grid Width="36" Height="42" VerticalAlignment="Top">
                            <!-- 如果有特定的 Image 图标，则显示 Image -->
                            <Image Source="{Binding Converter={StaticResource MediaResourceIconConverter}}"
                                   Width="36"
                                   Height="42"
                                   Stretch="Uniform"
                                   x:Name="IconImage"/>
                            
                            <!-- 备用图标（以防 Converter 返回 null 或者其它） -->
                            <Border x:Name="FallbackIconBorder"
                                    Width="36"
                                    Height="42"
                                    CornerRadius="4"
                                    Background="#EEFAFDFF"
                                    BorderBrush="#AA182433"
                                    BorderThickness="1"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Path Data="M 25,0 L 36,11 L 25,11 Z"
                                          Fill="#FFC8E7F0"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Top"/>
                                    <TextBlock Text="{Binding BadgeText}"
                                               Margin="3,14,3,0"
                                               TextAlignment="Center"
                                               Foreground="#FF152635"
                                               FontSize="8"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Column="1">
                            <DockPanel LastChildFill="True">
                                <Border DockPanel.Dock="Right"
                                        Background="#22000000"
                                        BorderBrush="#55E7FBFF"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Padding="6,2"
                                        Margin="8,0,0,0">
                                    <TextBlock Text="{Binding ProgressPhase}"
                                               Foreground="#FFEAFDFF"
                                               FontSize="10"
                                               FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProgress}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="{Binding Title}"
                                           Foreground="#FFF6FEFF"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>

                            <TextBlock Text="{Binding ResourcePath}"
                                       Margin="0,4,0,0"
                                       Foreground="#DCEAF9FF"
                                       FontSize="11"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>

                            <StackPanel Margin="0,9,0,0">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasProgress}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <Grid>
                                    <TextBlock Text="{Binding ProgressStatusText}"
                                               Foreground="#FFF8FEFF"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,0,58,0"/>
                                    <TextBlock Text="{Binding ProgressCountText}"
                                               HorizontalAlignment="Right"
                                               Foreground="#B8FFFFFF"
                                               FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasProgressCount}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <ProgressBar Margin="0,6,0,0"
                                             Height="5"
                                             Minimum="0"
                                             Maximum="1"
                                             Value="{Binding ProgressValue, Mode=OneWay}"
                                             IsIndeterminate="{Binding IsProgressIndeterminate, Mode=OneWay}"/>
                                <ItemsControl ItemsSource="{Binding ProgressActiveItems}" Margin="0,5,0,0">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasProgressActiveItems}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}"
                                                       Foreground="#B8FFFFFF"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding ElementName=IconImage, Path=Source}" Value="{x:Null}">
                    <Setter TargetName="FallbackIconBorder" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="IconImage" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ReasoningMessagePartTemplate" DataType="{x:Type models:ChatMessagePartModel}">
            <Grid>
                <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
