<UserControl x:Class="Skyweaver.Controls.ChatSessionControl.Views.ChatSessionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Skyweaver.Controls.ChatSessionControl.Views"
             xmlns:models="clr-namespace:Skyweaver.Controls.ChatSessionControl.Models"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.ChatSessionControl.ViewModels"
             x:Name="Root"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ChatSessionControlViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="600"
             d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="ScrollBar" BasedOn="{StaticResource AeroScrollBarV2Style}"/>
        <Style TargetType="ScrollViewer" BasedOn="{StaticResource AeroScrollViewerV2Style}"/>

        <DrawingBrush x:Key="ChatSoftGlassSliceBrush" Stretch="Uniform">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 0.160156,0.159668L 1386.16,0.159668L 1386.16,223.646L 0.160156,223.646L 0.160156,0.159668 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="0.32" LineJoin="Round" Brush="#FF000000"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0.10059,1.65236" EndPoint="2.53982,1.65236">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TransformGroup>
                                            <SkewTransform CenterX="0.10059" CenterY="1.65236" AngleX="-59.7491" AngleY="0"/>
                                            <RotateTransform CenterX="0.10059" CenterY="1.65236" Angle="-70.8836"/>
                                        </TransformGroup>
                                    </LinearGradientBrush.RelativeTransform>
                                    <LinearGradientBrush.GradientStops>
                                        <GradientStop Color="#3BFFFFFF" Offset="0"/>
                                        <GradientStop Color="#1DFFFFFF" Offset="0.0766283"/>
                                        <GradientStop Color="#07FFFFFF" Offset="0.109195"/>
                                        <GradientStop Color="#04FFFFFF" Offset="0.298851"/>
                                        <GradientStop Color="#3AFFFFFF" Offset="0.327586"/>
                                        <GradientStop Color="#1AFFFFFF" Offset="0.465517"/>
                                        <GradientStop Color="#14FFFFFF" Offset="0.591954"/>
                                        <GradientStop Color="#05FFFFFF" Offset="0.758621"/>
                                        <GradientStop Color="#44FFFFFF" Offset="1"/>
                                    </LinearGradientBrush.GradientStops>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <RadialGradientBrush x:Key="ChatHeaderButtonIdleBrush"
                             RadiusX="2.152"
                             RadiusY="1.684"
                             Center="0.5,0.993"
                             GradientOrigin="0.5,0.993">
            <GradientStop Color="#26FFFFFF" Offset="0"/>
            <GradientStop Color="#00000004" Offset="0.38"/>
            <GradientStop Color="#00FFFFFF" Offset="0.417"/>
            <GradientStop Color="#56D4FFF9" Offset="0.77"/>
            <GradientStop Color="#4A8CF1E4" Offset="0.892"/>
        </RadialGradientBrush>

        <LinearGradientBrush x:Key="ChatHeaderButtonHoverBrush"
                             StartPoint="0.5,-0.667875"
                             EndPoint="0.5,1.66787">
            <GradientStop Color="#00FFFFFF" Offset="0"/>
            <GradientStop Color="#1AFFFFFF" Offset="0.135436"/>
            <GradientStop Color="#14FFFFFF" Offset="0.487941"/>
            <GradientStop Color="#00000004" Offset="0.517625"/>
            <GradientStop Color="#FF2AAE9A" Offset="0.729128"/>
        </LinearGradientBrush>

        <DrawingBrush x:Key="ChatHeaderButtonPressedBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <EllipseGeometry Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Brush>
                                <RadialGradientBrush RadiusX="0.5"
                                                     RadiusY="0.833333"
                                                     Center="0.5,0.5"
                                                     GradientOrigin="0.5,0.5">
                                    <GradientStop Color="#FF76F1E4" Offset="0"/>
                                    <GradientStop Color="#00000000" Offset="0.662338"/>
                                    <RadialGradientBrush.RelativeTransform>
                                        <RotateTransform CenterX="0.5" CenterY="0.5" Angle="-90"/>
                                    </RadialGradientBrush.RelativeTransform>
                                </RadialGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <RectangleGeometry Rect="0,0,1,1"/>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0.5,-0.667873" EndPoint="0.5,1.66787">
                                    <GradientStop Color="#00FFFFFF" Offset="0"/>
                                    <GradientStop Color="#1AFFFFFF" Offset="0.135436"/>
                                    <GradientStop Color="#14FFFFFF" Offset="0.487941"/>
                                    <GradientStop Color="#00000004" Offset="0.517625"/>
                                    <GradientStop Color="#FF29E1C8" Offset="0.717996"/>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="ChatHeaderButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="MinWidth" Value="72"/>
            <Setter Property="Foreground" Value="#FFF4FFFD"/>
            <Setter Property="Background" Value="{StaticResource ChatHeaderButtonIdleBrush}"/>
            <Setter Property="BorderBrush" Value="#FF000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, Arial"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1.0" ScaleY="1.0"/>
                            </Border.RenderTransform>
                            <ContentPresenter x:Name="contentPresenter"
                                              Focusable="False"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        TargetName="border"
                                        Value="{StaticResource ChatHeaderButtonHoverBrush}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="#552FFFF2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background"
                                        TargetName="border"
                                        Value="{StaticResource ChatHeaderButtonPressedBrush}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="#6634FFF0"/>
                                <Setter Property="Opacity" TargetName="border" Value="0.96"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="0.97"
                                                             Duration="0:0:0.08"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="0.97"
                                                             Duration="0:0:0.08"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.0"
                                                             Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="border"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.0"
                                                             Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" TargetName="border" Value="0.45"/>
                                <Setter Property="Foreground" Value="#99FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ChatMessageContextMenuItemStyle"
               TargetType="MenuItem"
               BasedOn="{StaticResource AnimatedMenuItemStyle}">
            <Setter Property="MinWidth" Value="360"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuNameTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FFF5FEFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuDescriptionTextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,2,0,0"/>
            <Setter Property="Width" Value="248"/>
            <Setter Property="Foreground" Value="#B9E8FAFF"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#55283A4D"/>
            <Setter Property="BorderBrush" Value="#8896FCFF"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ChatMessageContextMenuIconTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFF4FEFF"/>
        </Style>

        <ContextMenu x:Key="ChatMessageContextMenu"
                     x:Shared="False"
                     Style="{DynamicResource AnimatedContextMenuStyle}"
                     DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.RemoveMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <!-- 大幅增加图标面积但不改变布局宽高，使用 ScaleTransform 缩放图片本身 -->
                    <Image Source="pack://application:,,,/Skyweaver;component/Resources/DeleteMessage.png" Width="24" Height="24" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="1.6" ScaleY="1.6"/>
                        </Image.RenderTransform>
                    </Image>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.Delete}" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.DeleteDescription}"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.CopyMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <!-- 大幅增加图标面积但不改变布局宽高，使用 ScaleTransform 缩放图片本身 -->
                    <Image Source="pack://application:,,,/Skyweaver;component/Resources/JustCopy.png" Width="24" Height="24" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="1.6" ScaleY="1.6"/>
                        </Image.RenderTransform>
                    </Image>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.Copy}" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.CopyDescription}"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.CopyMessageAsMarkdownCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <!-- 大幅增加图标面积但不改变布局宽高，使用 ScaleTransform 缩放图片本身 -->
                    <Image Source="pack://application:,,,/Skyweaver;component/Resources/CopyAsMarkdown.png" Width="24" Height="24" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="1.6" ScaleY="1.6"/>
                        </Image.RenderTransform>
                    </Image>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.CopyMarkdown}" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.CopyMarkdownDescription}"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.CopyMessageAsPlainTextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <!-- 大幅增加图标面积但不改变布局宽高，使用 ScaleTransform 缩放图片本身 -->
                    <Image Source="pack://application:,,,/Skyweaver;component/Resources/CopyAsText.png" Width="24" Height="24" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="1.6" ScaleY="1.6"/>
                        </Image.RenderTransform>
                    </Image>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.CopyPlainText}" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.CopyPlainTextDescription}"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>

            <MenuItem Style="{StaticResource ChatMessageContextMenuItemStyle}"
                      Command="{Binding PlacementTarget.Tag.EditMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <!-- 大幅增加图标面积但不改变布局宽高，使用 ScaleTransform 缩放图片本身 -->
                    <Image Source="pack://application:,,,/Skyweaver;component/Resources/EditDocument.png" Width="24" Height="24" RenderTransformOrigin="0.5,0.5">
                        <Image.RenderTransform>
                            <ScaleTransform ScaleX="1.6" ScaleY="1.6"/>
                        </Image.RenderTransform>
                    </Image>
                </MenuItem.Icon>
                <MenuItem.Header>
                    <StackPanel Margin="0,2">
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.Edit}" Style="{StaticResource ChatMessageContextMenuNameTextStyle}"/>
                        <TextBlock Text="{DynamicResource ChatSessionControl.ContextMenu.EditDescription}"
                                   Style="{StaticResource ChatMessageContextMenuDescriptionTextStyle}"/>
                    </StackPanel>
                </MenuItem.Header>
            </MenuItem>
        </ContextMenu>

        <Style x:Key="ChatHeaderCapsuleBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#332EC5C0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="ChatHeaderStatusCapsuleBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ChatHeaderCapsuleBorderStyle}">
            <Setter Property="BorderBrush" Value="#44F3C96B"/>
        </Style>

        <Style x:Key="ChatHeaderCapsuleTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#CCFFFFFF"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>

        <Style x:Key="ChatHeaderStatusCapsuleTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource ChatHeaderCapsuleTextStyle}">
            <Setter Property="Foreground" Value="#FFF3E4AE"/>
        </Style>

        <Style x:Key="AeroContextWindowToolTipStyle" TargetType="ToolTip">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Placement" Value="Bottom"/>
            <Setter Property="VerticalOffset" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToolTip">
                        <Grid Margin="4">
                            <Border CornerRadius="4" Margin="-2">
                                <Border.Effect>
                                    <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="2" Opacity="0.6"/>
                                </Border.Effect>
                                <Border.Background>
                                    <SolidColorBrush Color="#01000000"/>
                                </Border.Background>
                            </Border>

                            <Border CornerRadius="4">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#F0102030" Offset="0"/>
                                        <GradientStop Color="#F0183050" Offset="0.3"/>
                                        <GradientStop Color="#F0102840" Offset="0.7"/>
                                        <GradientStop Color="#F0081828" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Border CornerRadius="4,4,0,0" Height="20" VerticalAlignment="Top" IsHitTestVisible="False">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#25FFFFFF" Offset="0"/>
                                        <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                                        <GradientStop Color="#00FFFFFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Border CornerRadius="0,0,4,4" Height="30" VerticalAlignment="Bottom" IsHitTestVisible="False">
                                <Border.Background>
                                    <RadialGradientBrush RadiusX="0.8" RadiusY="1.5" Center="0.5,1" GradientOrigin="0.5,1">
                                        <GradientStop Color="#3040A0E0" Offset="0"/>
                                        <GradientStop Color="#0040A0E0" Offset="1"/>
                                    </RadialGradientBrush>
                                </Border.Background>
                            </Border>

                            <Border CornerRadius="4" BorderThickness="1" IsHitTestVisible="False">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#60FFFFFF" Offset="0"/>
                                        <GradientStop Color="#30FFFFFF" Offset="0.3"/>
                                        <GradientStop Color="#20FFFFFF" Offset="0.7"/>
                                        <GradientStop Color="#4080C0E0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                            </Border>

                            <ContentPresenter Margin="12,8" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AeroContextWindowProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="11" Background="Transparent">
                            <Grid>
                                <Border x:Name="PART_Indicator" 
                                        CornerRadius="11" 
                                        HorizontalAlignment="Left" 
                                        Background="{TemplateBinding Foreground}">
                                    <Border.Effect>
                                        <BlurEffect Radius="2"/>
                                    </Border.Effect>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <LinearGradientBrush x:Key="ChatUserBubbleBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B36693B0" Offset="0"/>
            <GradientStop Color="#A63A6F8C" Offset="0.34"/>
            <GradientStop Color="#C1234966" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ChatAssistantBubbleBackgroundBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#B06A94AF" Offset="0"/>
            <GradientStop Color="#A040718F" Offset="0.34"/>
            <GradientStop Color="#BC203E58" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ChatBubbleTopSheenBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#66FFFFFF" Offset="0"/>
            <GradientStop Color="#22FFFFFF" Offset="0.48"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ChatBubbleBottomGlowBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0028B4FF" Offset="0"/>
            <GradientStop Color="#143BBBE8" Offset="0.42"/>
            <GradientStop Color="#4D43D8F3" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="ChatMessageBubbleBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#6687CAE3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="ChatComposerTextBoxStyle"
               TargetType="{x:Type TextBox}"
               BasedOn="{StaticResource DefaultTextBoxStyle}">
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBox}">
                        <Border x:Name="border"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <LinearGradientBrush x:Name="backgroundBrush" StartPoint="0.438,5.527" EndPoint="0.438,-4.527">
                                    <GradientStop x:Name="gradientStop1" Color="#91007BFF" Offset="0.143"/>
                                    <GradientStop x:Name="gradientStop2" Color="#00FFFFFF" Offset="0.503"/>
                                    <GradientStop x:Name="gradientStop3" Color="#C30099FF" Offset="0.792"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          Padding="{TemplateBinding Padding}"
                                          Style="{DynamicResource AeroScrollViewerStyle}"
                                          HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                                          VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource AccentColor}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="gradientStop1"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#AF00C7FF"
                                                            Duration="0:0:0.08"
                                                            EasingFunction="{StaticResource BackEaseOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop2"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#00FFFFFF"
                                                            Duration="0:0:0.08"
                                                            EasingFunction="{StaticResource ExpoEaseOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop3"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#FF00ECFF"
                                                            Duration="0:0:0.08"
                                                            EasingFunction="{StaticResource BackEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop1"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.414"
                                                             Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource ExpoEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop2"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.495"
                                                             Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource ExpoEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop3"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.692"
                                                             Duration="0:0:0.1"
                                                             EasingFunction="{StaticResource ExpoEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="gradientStop1"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#91007BFF"
                                                            Duration="0:0:0.12"
                                                            EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop2"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#00FFFFFF"
                                                            Duration="0:0:0.12"
                                                            EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <ColorAnimation Storyboard.TargetName="gradientStop3"
                                                            Storyboard.TargetProperty="Color"
                                                            To="#C30099FF"
                                                            Duration="0:0:0.12"
                                                            EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop1"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.143"
                                                             Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop2"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.503"
                                                             Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="gradientStop3"
                                                             Storyboard.TargetProperty="Offset"
                                                             To="0.792"
                                                             Duration="0:0:0.15"
                                                             EasingFunction="{StaticResource QuinticEaseInOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

