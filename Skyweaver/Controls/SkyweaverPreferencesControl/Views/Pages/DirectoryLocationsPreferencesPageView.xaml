<UserControl x:Class="Skyweaver.Controls.SkyweaverPreferencesControl.Views.Pages.DirectoryLocationsPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.SkyweaverPreferencesControl.ViewModels.Pages"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DirectoryLocationsPreferencesPageViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="680"
             d:DesignWidth="860">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Skyweaver;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFF4FAFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PreferenceValueStyle" TargetType="TextBlock" BasedOn="{StaticResource PreferenceMetaStyle}">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,16,20">
            <TextBlock Text="目录位置"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="聊天会话目录"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding ChatSessionsDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="0"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="浏览..."
                        Command="{Binding BrowseChatSessionsDirectoryCommand}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="设定聊天会话 ChatSessions 保存的位置。默认在用户文件夹/Skyweaver/ChatSessions 之下。"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="配置文件目录"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding ConfigurationFilesDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="4"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="浏览..."
                        Command="{Binding BrowseConfigurationDirectoryCommand}"/>
                <TextBlock Grid.Row="6"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="设定配置文件 Configuration 保存的位置。Directories.xml 始终保留在用户文件夹/Skyweaver/Configuration 中。"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Text="调试文件目录"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="8"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding DebugDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="8"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="浏览..."
                        Command="{Binding BrowseDebugDirectoryCommand}"/>
                <TextBlock Grid.Row="10"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="设定调试目录 Debug 保存的位置。默认在用户文件夹/Skyweaver/Debug 之下。"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="12"
                           Grid.Column="0"
                           Text="会话流目录"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="12"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding SessionFlowsDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="12"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="浏览..."
                        Command="{Binding BrowseSessionFlowsDirectoryCommand}"/>
                <TextBlock Grid.Row="14"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="设定会话流节点图保存的位置。默认在用户文件夹/Skyweaver/Nodegraphs 之下。"
                           Style="{StaticResource PreferenceMetaStyle}"/>
            </Grid>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="配置状态"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="目录配置文件"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding DirectoriesConfigurationFilePath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="默认根目录"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding DefaultApplicationDirectoryPath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="最近状态"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource PreferenceValueStyle}"/>
            </Grid>

            <StackPanel Margin="0,16,0,0"
                        Orientation="Horizontal">
                <Button MinWidth="160"
                        Content="打开目录配置位置"
                        Command="{Binding OpenDirectoriesConfigurationDirectoryCommand}"/>
            </StackPanel>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="说明"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <TextBlock Margin="0,12,0,0"
                       Text="1. Directories.xml 固定写入用户文件夹/Skyweaver/Configuration，不受“配置文件目录”设置影响。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="2. 目录设置保存时会确保目标目录存在；已有文件不会自动迁移。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="3. 已经打开的会话或会话流会继续使用自身记录的文件路径，新建和后续加载会使用此页设置。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
