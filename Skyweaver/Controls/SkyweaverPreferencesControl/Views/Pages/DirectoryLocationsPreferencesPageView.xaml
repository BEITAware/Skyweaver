<UserControl x:Class="Skyweaver.Controls.SkyweaverPreferencesControl.Views.Pages.DirectoryLocationsPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.SkyweaverPreferencesControl.ViewModels.Pages"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DirectoryLocationsPreferencesPageViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="680"
             d:DesignWidth="860">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Skyweaver;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFF4FAFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PreferenceValueStyle" TargetType="TextBlock" BasedOn="{StaticResource PreferenceMetaStyle}">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,16,20">
            <TextBlock Text="{DynamicResource Directories.Page.Title}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{DynamicResource Directories.ChatSessions.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding ChatSessionsDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="0"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="{DynamicResource Common.BrowseEllipsis}"
                        Command="{Binding BrowseChatSessionsDirectoryCommand}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="{DynamicResource Directories.ChatSessions.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="{DynamicResource Directories.ConfigurationFiles.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding ConfigurationFilesDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="4"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="{DynamicResource Common.BrowseEllipsis}"
                        Command="{Binding BrowseConfigurationDirectoryCommand}"/>
                <TextBlock Grid.Row="6"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="{DynamicResource Directories.ConfigurationFiles.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="8"
                           Grid.Column="0"
                           Text="{DynamicResource Directories.Debug.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="8"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding DebugDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="8"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="{DynamicResource Common.BrowseEllipsis}"
                        Command="{Binding BrowseDebugDirectoryCommand}"/>
                <TextBlock Grid.Row="10"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="{DynamicResource Directories.Debug.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="12"
                           Grid.Column="0"
                           Text="{DynamicResource Directories.SessionFlows.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="12"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding SessionFlowsDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="12"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="{DynamicResource Common.BrowseEllipsis}"
                        Command="{Binding BrowseSessionFlowsDirectoryCommand}"/>
                <TextBlock Grid.Row="14"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="{DynamicResource Directories.SessionFlows.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="16"
                           Grid.Column="0"
                           Text="{DynamicResource Directories.AerialCity.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="16"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding AerialCityDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="16"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="{DynamicResource Common.BrowseEllipsis}"
                        Command="{Binding BrowseAerialCityDirectoryCommand}"/>
                <TextBlock Grid.Row="18"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="{DynamicResource Directories.AerialCity.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>
            </Grid>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="{DynamicResource Common.ConfigurationStatus}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{DynamicResource Directories.ConfigurationFile.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding DirectoriesConfigurationFilePath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="{DynamicResource Directories.DefaultRoot.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding DefaultApplicationDirectoryPath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="{DynamicResource Common.RecentStatus}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource PreferenceValueStyle}"/>
            </Grid>

            <StackPanel Margin="0,16,0,0"
                        Orientation="Horizontal">
                <Button MinWidth="160"
                        Content="{DynamicResource Directories.OpenConfigurationLocation}"
                        Command="{Binding OpenDirectoriesConfigurationDirectoryCommand}"/>
            </StackPanel>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="{DynamicResource Common.Instructions}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <TextBlock Margin="0,12,0,0"
                       Text="{DynamicResource Directories.Instruction.1}"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{DynamicResource Directories.Instruction.2}"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="{DynamicResource Directories.Instruction.3}"
                       Style="{StaticResource PreferenceMetaStyle}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
