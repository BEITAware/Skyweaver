<UserControl x:Class="Skyweaver.Controls.SkyweaverPreferencesControl.Views.Pages.ContextCompressionPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.ContextManagementConfigurationControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:ContextCompressionPreferencesPageViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="720"
             d:DesignWidth="900">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Skyweaver;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFF4FAFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PreferenceValueStyle" TargetType="TextBlock" BasedOn="{StaticResource PreferenceMetaStyle}">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,16,20">
            <TextBlock Text="压缩"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="MinCompaction"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <CheckBox Grid.Row="0"
                          Grid.Column="1"
                          IsChecked="{Binding MinCompactionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Content="上下文接近上限时，后台压缩过时工具调用。"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding MinCompactionBehaviorText}"
                           Style="{StaticResource PreferenceMetaStyle}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="MaxCompaction"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <StackPanel Grid.Row="4"
                            Grid.Column="1">
                    <CheckBox IsChecked="{Binding MaxCompactionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="启用 MaxCompaction"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="上下文窗口达到上限且 MinCompaction 无法工作时，使用全量的压缩方法压缩会话上下文。"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </StackPanel>

                <TextBlock Grid.Row="6"
                           Grid.Column="0"
                           Text="LifeCycle"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <StackPanel Grid.Row="6"
                            Grid.Column="1">
                    <CheckBox IsChecked="{Binding LifeCycleEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="启用 LifeCycle"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="特定工具调用结果将获得生命周期限制。在一定会话轮数后，这些工具调用结果会在上下文中被自动失效落盘。代理可以取回这些工具调用结果。一旦取回，LifeCycle 对此失效。"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </StackPanel>

                <Grid Grid.Row="8"
                      Grid.ColumnSpan="2">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LifeCycleEnabled}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="LifeCycle 比率"
                               Style="{StaticResource PreferenceLabelStyle}"/>
                    <Grid Grid.Row="0"
                          Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="64"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Minimum="10"
                                Maximum="500"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                HorizontalAlignment="Stretch"
                                Value="{Binding LifeCycleRatioPercent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Column="1"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Text="{Binding LifeCycleRatioDisplayText}"
                                   Style="{StaticResource PreferenceValueStyle}"/>
                    </Grid>

                    <TextBlock Grid.Row="2"
                               Grid.Column="1"
                               Text="调整 LifeCycle 实际运作时的生命周期长度。结果向上取整。"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </Grid>

                <TextBlock Grid.Row="10"
                           Grid.Column="0"
                           Text="RNN 优化"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <StackPanel Grid.Row="10"
                            Grid.Column="1">
                    <CheckBox IsChecked="{Binding RnnOptimizedCompactionEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              Content="启用循环神经网络优化的压缩"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="仅限于 RWKV、Manba 等 RNN 语言模型启用。如果启用，上下文限制会被移除，更重要的结果和内容会被移动到更新的位置，以保证它们时刻对线性注意力产生更大影响。需开启外推以获得无限上下文。"
                               Style="{StaticResource PreferenceMetaStyle}"/>
                </StackPanel>
            </Grid>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="配置状态"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="配置文件"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding ConfigurationFilePath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="最近状态"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource PreferenceValueStyle}"/>
            </Grid>

            <StackPanel Margin="0,16,0,0"
                        Orientation="Horizontal">
                <Button MinWidth="132"
                        Content="打开配置目录"
                        Command="{Binding OpenConfigurationDirectoryCommand}"/>
            </StackPanel>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="说明"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <TextBlock Margin="0,12,0,0"
                       Text="1. 此页设置会立即写入当前配置文件目录中的 ContextManagement.xml。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="2. 除 MinCompaction 外，当前选项只负责持久化配置，运行时行为尚未接入。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
