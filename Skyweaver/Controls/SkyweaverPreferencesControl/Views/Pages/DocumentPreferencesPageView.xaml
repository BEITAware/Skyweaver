<UserControl x:Class="Skyweaver.Controls.SkyweaverPreferencesControl.Views.Pages.DocumentPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.SkyweaverPreferencesControl.ViewModels.Pages"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:DocumentPreferencesPageViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="640"
             d:DesignWidth="860">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Skyweaver;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFF4FAFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PreferenceValueStyle" TargetType="TextBlock" BasedOn="{StaticResource PreferenceMetaStyle}">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,16,20">
            <!-- 标题和说明 -->
            <TextBlock Text="{Binding Title}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>
            <TextBlock Margin="0,4,0,12"
                       Text="{Binding Description}"
                       Style="{StaticResource PreferenceMetaStyle}"/>

            <!-- 启用文档字符识别 -->
            <Grid Margin="0,12,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{DynamicResource Multimodal.Document.EnableOcr.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <CheckBox Grid.Row="0" Grid.Column="1"
                          Content="{DynamicResource Multimodal.Document.EnableOcr.Content}"
                          IsChecked="{Binding EnableDocumentCharacterRecognition, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{DynamicResource Multimodal.Document.EnableOcr.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>
            </Grid>

            <!-- 硬件方案 -->
            <Grid Margin="0,4,0,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{DynamicResource Multimodal.Document.HardwareSolution.Label}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding HardwareSolutions}"
                          SelectedItem="{Binding HardwareSolution, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{DynamicResource Multimodal.Document.HardwareSolution.Hint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>
            </Grid>

            <!-- 底部分隔线 -->
            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <!-- 配置文件状态 -->
            <TextBlock Margin="0,18,0,0"
                       Text="{DynamicResource Common.ConfigurationStatus}"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{DynamicResource Common.ConfigurationFile}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding ConfigurationFilePath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="{DynamicResource Common.RecentStatus}"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource PreferenceValueStyle}"/>
            </Grid>

            <!-- 操作按钮 -->
            <StackPanel Margin="0,16,0,0"
                        Orientation="Horizontal">
                <Button MinWidth="132"
                        Content="{DynamicResource Common.OpenConfigurationDirectory}"
                        Command="{Binding OpenConfigurationDirectoryCommand}"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
