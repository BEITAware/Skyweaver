<UserControl x:Class="Skyweaver.Controls.SkyweaverPreferencesControl.Views.Pages.LateralFileSystemPreferencesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.LateralFileSystemConfigurationControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:LateralFileSystemConfigurationControlViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="640"
             d:DesignWidth="860">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Skyweaver;component/Resources/Controls/CascadePreferenceImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="PreferenceSectionTitleStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FF61D1F0"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="PreferenceLabelStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#FFF4FAFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="12.5"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
            </Style>

            <Style x:Key="PreferenceMetaStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#B9DBEEFF"/>
                <Setter Property="FontFamily" Value="{DynamicResource AeroFontFamily}"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="PreferenceValueStyle" TargetType="TextBlock" BasedOn="{StaticResource PreferenceMetaStyle}">
                <Setter Property="Foreground" Value="#EAF8FFFF"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="16,10,16,20">
            <TextBlock Text="基础配置"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="启用侧向文件系统"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <CheckBox Grid.Row="0"
                          Grid.Column="1"
                          Grid.ColumnSpan="2"
                          IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Content="允许创建、维护和激活侧向文件系统虚拟化根。"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="工作根目录"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         Margin="0,0,10,0"
                         Text="{Binding WorkingRootDirectory, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"/>
                <Button Grid.Row="2"
                        Grid.Column="2"
                        MinWidth="96"
                        Content="浏览..."
                        Command="{Binding BrowseWorkingRootDirectoryCommand}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding WorkingRootDirectoryHint}"
                           Style="{StaticResource PreferenceMetaStyle}"/>
            </Grid>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="环境状态"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <Grid Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="虚拟化后端"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding BackendAvailabilityText}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="配置文件"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Text="{Binding ConfigurationFilePath}"
                           Style="{StaticResource PreferenceValueStyle}"/>

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="最近状态"
                           Style="{StaticResource PreferenceLabelStyle}"/>
                <TextBlock Grid.Row="4"
                           Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource PreferenceValueStyle}"/>
            </Grid>

            <StackPanel Margin="0,16,0,0"
                        Orientation="Horizontal">
                <Button MinWidth="132"
                        Content="打开配置目录"
                        Command="{Binding OpenConfigurationDirectoryCommand}"/>
            </StackPanel>

            <Border Margin="0,18,0,0"
                    Height="1"
                    Background="#30FFFFFF"/>

            <TextBlock Margin="0,18,0,0"
                       Text="约束说明"
                       Style="{StaticResource PreferenceSectionTitleStyle}"/>

            <TextBlock Margin="0,12,0,0"
                       Text="1. 所有虚拟化根都必须位于工作根目录之下。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="2. LateralFileSystemTree.xml 不在配置阶段创建，只会在创建首个侧向文件系统节点时由后端自动生成。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
            <TextBlock Margin="0,6,0,0"
                       Text="3. 此页中的启用状态和工作根目录会在变更后立即写入配置文件。"
                       Style="{StaticResource PreferenceMetaStyle}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
