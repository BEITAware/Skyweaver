<UserControl x:Class="Skyweaver.Controls.SkyweaverPreferencesControl.Views.SkyweaverPreferencesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:Skyweaver.Controls.SkyweaverPreferencesControl.Views"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.SkyweaverPreferencesControl.ViewModels"
             x:Name="Root"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:SkyweaverPreferencesControlViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="720"
             d:DesignWidth="1180">
    <Grid>
        <Rectangle Stretch="Fill"
                   IsHitTestVisible="False">
            <Rectangle.Fill>
                <SolidColorBrush Color="White"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <local:PreferencesBlueRippleBackgroundEffect Time="{Binding BackgroundTime, ElementName=Root}"
                                                             AspectRatio="{Binding BackgroundAspectRatio, ElementName=Root}"/>
            </Rectangle.Effect>
        </Rectangle>

        <Rectangle Fill="#16001024"
                   IsHitTestVisible="False"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="10,20,0,20"
                    Style="{StaticResource PreferencesSidebarShellBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Border Background="{StaticResource PreferencesSidebarTopBackgroundBrush}"
                                BorderBrush="{StaticResource PreferencesSidebarTopBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="5,5,0,0"/>
                        <Border Background="{StaticResource PreferencesSidebarTopHighlightBrush}"
                                CornerRadius="5,5,0,0"/>
                        <Border Background="{StaticResource PreferencesSidebarTopBottomGlowBrush}"
                                CornerRadius="5,5,0,0"/>

                        <TextBlock Margin="12,0,12,0"
                                   Text="Preferences"
                                   Style="{StaticResource PreferencesSidebarTitleTextStyle}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  Margin="5,5,5,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Groups}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type viewModels:PreferenceGroupViewModel}">
                                    <Expander Header="{Binding DisplayName}"
                                              IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                              Style="{StaticResource PreferencesSidebarExpanderStyle}">
                                        <ItemsControl ItemsSource="{Binding Pages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type viewModels:SelectablePreferencePageViewModel}">
                                                    <Button Tag="{Binding IsSelected}"
                                                            Style="{StaticResource PreferencesSidebarItemButtonStyle}"
                                                            Command="{Binding DataContext.SelectPageCommand, RelativeSource={RelativeSource AncestorType=local:SkyweaverPreferencesControl}}"
                                                            CommandParameter="{Binding}">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding DisplayName}"
                                                                       Foreground="White"
                                                                       FontSize="13"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Margin="0,4,0,0"
                                                                       Text="{Binding Description}"
                                                                       Foreground="#BFDDEEFF"
                                                                       FontSize="10.5"
                                                                       TextWrapping="Wrap"/>
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Grid Grid.Row="2"
                          Height="16">
                        <Border Background="#15000000"
                                BorderBrush="#30FFFFFF"
                                BorderThickness="0,1,0,0"/>
                        <TextBlock HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="#50FFFFFF"
                                   FontSize="10"
                                   Text=". . . . ."/>
                    </Grid>

                    <StackPanel Grid.Row="3"
                                Margin="5,3,5,8">
                        <Button IsEnabled="False"
                                Command="{Binding ReservedPrimaryActionCommand}"
                                Style="{StaticResource PreferencesBottomNavButtonStyle}">
                            <Button.Content>
                                <TextBlock Text="Apply Changes (Pending)"/>
                            </Button.Content>
                            <Button.Tag>
                                <Ellipse Width="14"
                                         Height="14"
                                         Fill="#6090D0"/>
                            </Button.Tag>
                        </Button>
                        <Button IsEnabled="False"
                                Command="{Binding ReservedSecondaryActionCommand}"
                                Style="{StaticResource PreferencesBottomNavButtonStyle}">
                            <Button.Content>
                                <TextBlock Text="Export Layout (Pending)"/>
                            </Button.Content>
                            <Button.Tag>
                                <Rectangle Width="12"
                                           Height="10"
                                           Fill="#7090B0"/>
                            </Button.Tag>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="10,20,20,20"
                    Style="{StaticResource PreferencesContentShellBorderStyle}">
                <Grid>
                    <Border Background="{StaticResource PreferencesContentBackgroundBrush}"
                            Opacity="0.26"
                            IsHitTestVisible="False"/>

                    <Grid Margin="20">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0"
                                    Visibility="{Binding CurrentPageName, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="{Binding CurrentPageName}"
                                       Style="{StaticResource PreferencesContentTitleTextStyle}"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding CurrentPageDescription}"
                                       TextWrapping="Wrap"
                                       Style="{StaticResource PreferencesContentSubtitleTextStyle}"/>
                        </StackPanel>

                        <ContentControl Grid.Row="1"
                                        Margin="0,20,0,0"
                                        Content="{Binding CurrentView}"
                                        Visibility="{Binding CurrentView, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <Grid Grid.Row="0"
                              Grid.RowSpan="2"
                              Visibility="{Binding CurrentView, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=invert}">
                            <StackPanel MaxWidth="500"
                                        VerticalAlignment="Center"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           TextAlignment="Center"
                                           Style="{StaticResource PreferencesWelcomeTitleTextStyle}"/>
                                <TextBlock Margin="0,12,0,0"
                                           Text="{Binding Description}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource PreferencesWelcomeBodyTextStyle}"/>
                                <TextBlock Margin="0,10,0,0"
                                           Text="{Binding Hint}"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Style="{StaticResource PreferencesWelcomeHintTextStyle}"/>

                                <TextBlock Margin="0,24,0,8"
                                           HorizontalAlignment="Center"
                                           Text="Registered Groups"
                                           Style="{StaticResource PreferencesWelcomeCaptionTextStyle}"/>

                                <ItemsControl ItemsSource="{Binding Groups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Margin="0,2,0,2"
                                                       HorizontalAlignment="Center"
                                                       Text="{Binding DisplayName}"
                                                       Style="{StaticResource PreferencesWelcomeGroupTextStyle}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
