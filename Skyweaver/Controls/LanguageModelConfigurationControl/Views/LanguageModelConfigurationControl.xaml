<UserControl x:Class="Skyweaver.Controls.LanguageModelConfigurationControl.Views.LanguageModelConfigurationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Skyweaver.Controls.LanguageModelConfigurationControl.Models"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.LanguageModelConfigurationControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:LanguageModelConfigurationControlViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="900"
             d:DesignWidth="1100">
    <UserControl.Resources>
        <Style x:Key="ConfigurationListViewStyle"
               TargetType="ListView"
               BasedOn="{StaticResource AeroListViewStyle}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <Style x:Key="ConfigurationListViewItemStyle"
               TargetType="ListViewItem"
               BasedOn="{StaticResource AeroListViewItemStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid>
                            <Border x:Name="HoverOverlay"
                                    Background="{StaticResource MenuItemHoverBrush}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <Border x:Name="SelectedOverlay"
                                    Background="{StaticResource MenuItemClickedBrush}"
                                    Opacity="0"
                                    IsHitTestVisible="False"/>
                            <ContentPresenter/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" TargetName="HoverOverlay" Value="0.2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Opacity" TargetName="SelectedOverlay" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCardBorderStyle"
               TargetType="Border"
               BasedOn="{StaticResource ChatSessionHeaderBorderStyle}">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>

        <Style x:Key="CapsuleBorderStyle"
               TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="MinWidth" Value="58"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="0,0,6,6"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <DataTemplate x:Key="LanguageModelEditorTemplate"
                      DataType="{x:Type models:LanguageModelDefinition}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0"
                      Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,12,0">
                        <TextBlock Text="显示名称" FontWeight="SemiBold"/>
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding DisplayName, UpdateSourceTrigger=LostFocus}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,12,0">
                        <TextBlock Text="接口类型" FontWeight="SemiBold"/>
                        <ComboBox Margin="0,6,0,0"
                                  ItemsSource="{Binding DataContext.AvailableInterfaceTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                  SelectedItem="{Binding InterfaceType, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="上下文窗口 Token" FontWeight="SemiBold"/>
                        <TextBox Margin="0,6,0,0"
                                 Text="{Binding ContextWindowTokens, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </Grid>

                <TextBlock Grid.Row="1"
                           Text="{Binding DataContext.InterfaceSettingsSectionTitle, RelativeSource={RelativeSource AncestorType=UserControl}}"
                           FontWeight="SemiBold"
                           FontSize="13"/>

                <ContentControl Grid.Row="2"
                                Margin="0,10,0,0"
                                Content="{Binding InterfaceSettings}"/>

                <Grid Grid.Row="3"
                      Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Width="96"
                            Height="32"
                            Command="{Binding TestCommand}"
                            Content="测试模型"/>

                    <Button Grid.Column="2"
                            Width="96"
                            Height="32"
                            Command="{Binding CancelTestCommand}"
                            Content="中止测试"/>

                    <TextBox Grid.Column="4"
                              MinHeight="72"
                              Padding="8,6"
                              AcceptsReturn="True"
                              VerticalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             IsReadOnly="True"
                             Text="{Binding TestResponse, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type models:MeaiLanguageModelSettings}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                    <TextBlock Text="模型 ID" FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding ModelId, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,12,12">
                    <TextBlock Text="API Key" FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding ApiKey, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                    <TextBlock Text="Base URL" FontWeight="SemiBold"/>
                    <TextBox Margin="0,6,0,0"
                             Text="{Binding BaseUrl, UpdateSourceTrigger=LostFocus}"/>
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,12,12">
                    <CheckBox IsChecked="{Binding UseTemperature, UpdateSourceTrigger=PropertyChanged}"
                              Content="传入 Temperature"/>
                    <TextBox Margin="0,6,0,0"
                             IsEnabled="{Binding UseTemperature}"
                             Text="{Binding Temperature, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,0,12">
                    <CheckBox IsChecked="{Binding UseTopP, UpdateSourceTrigger=PropertyChanged}"
                              Content="传入 Top_P"/>
                    <TextBox Margin="0,6,0,0"
                             IsEnabled="{Binding UseTopP}"
                             Text="{Binding TopP, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,0,12,12">
                    <CheckBox IsChecked="{Binding UseMaxOutputTokens, UpdateSourceTrigger=PropertyChanged}"
                              Content="限制输出 Token"/>
                    <TextBox Margin="0,6,0,0"
                             IsEnabled="{Binding UseMaxOutputTokens}"
                             Text="{Binding MaxOutputTokens, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                    <CheckBox IsChecked="{Binding UsePresencePenalty, UpdateSourceTrigger=PropertyChanged}"
                              Content="传入 PresencePenalty"/>
                    <TextBox Margin="0,6,0,0"
                             IsEnabled="{Binding UsePresencePenalty}"
                             Text="{Binding PresencePenalty, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.Column="1"
                            Margin="0,0,12,12">
                    <CheckBox IsChecked="{Binding UseFrequencyPenalty, UpdateSourceTrigger=PropertyChanged}"
                              Content="传入 FrequencyPenalty"/>
                    <TextBox Margin="0,6,0,0"
                             IsEnabled="{Binding UseFrequencyPenalty}"
                             Text="{Binding FrequencyPenalty, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Grid.Column="0"
                            Margin="0,0,12,12">
                    <CheckBox IsChecked="{Binding UseSeed, UpdateSourceTrigger=PropertyChanged}"
                              Content="固定 Seed"/>
                    <TextBox Margin="0,6,0,0"
                             IsEnabled="{Binding UseSeed}"
                             Text="{Binding Seed, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

                <StackPanel Grid.Row="4"
                            Grid.Column="1"
                            Margin="0,0,12,12">
                    <CheckBox IsChecked="{Binding UseReasoningEffort, UpdateSourceTrigger=PropertyChanged}"
                              Content="思考强度"/>
                    <ComboBox Margin="0,6,0,0"
                              IsEnabled="{Binding UseReasoningEffort}"
                              ItemsSource="{Binding SupportedReasoningEfforts}"
                              SelectedItem="{Binding ReasoningEffort, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>

            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource DocumentTabBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,16">
                    <TextBlock Text="{Binding Title}"
                               Style="{StaticResource AeroTextBlockStyle}"
                               FontSize="16"
                               FontWeight="SemiBold"/>
                    <TextBlock Margin="0,6,0,0"
                               Text="{Binding Description}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Grid Grid.Row="1"
                      Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <DockPanel Grid.Column="0"
                               Margin="0,0,12,0">
                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,10"
                                   Text="语言模型列表"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <Grid DockPanel.Dock="Top"
                              Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Command="{Binding AddLanguageModelCommand}"
                                    Content="新增语言模型"/>
                            <Button Grid.Column="2"
                                    Command="{Binding DuplicateLanguageModelCommand}"
                                    Content="复制所选模型"/>
                            <Button Grid.Column="4"
                                    Command="{Binding RemoveLanguageModelCommand}"
                                    Content="删除所选模型"/>
                        </Grid>

                        <Border CornerRadius="2"
                                BorderThickness="1"
                                Padding="4"
                                SnapsToDevicePixels="True">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.10059,1.65236"
                                                     EndPoint="2.53982,1.65236"
                                                     Opacity="0.5">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TransformGroup>
                                            <SkewTransform CenterX="0.10059"
                                                           CenterY="1.65236"
                                                           AngleX="-59.7491"
                                                           AngleY="0"/>
                                            <RotateTransform CenterX="0.10059"
                                                             CenterY="1.65236"
                                                             Angle="-70.8836"/>
                                        </TransformGroup>
                                    </LinearGradientBrush.RelativeTransform>
                                    <GradientStop Color="#3BFFFFFF" Offset="0"/>
                                    <GradientStop Color="#1DFFFFFF" Offset="0.0766283"/>
                                    <GradientStop Color="#07FFFFFF" Offset="0.109195"/>
                                    <GradientStop Color="#04FFFFFF" Offset="0.298851"/>
                                    <GradientStop Color="#3AFFFFFF" Offset="0.327586"/>
                                    <GradientStop Color="#1AFFFFFF" Offset="0.465517"/>
                                    <GradientStop Color="#14FFFFFF" Offset="0.591954"/>
                                    <GradientStop Color="#05FFFFFF" Offset="0.758621"/>
                                    <GradientStop Color="#44FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#40000000"/>
                            </Border.BorderBrush>
                            <ListView ItemsSource="{Binding LanguageModels}"
                                      SelectedItem="{Binding SelectedLanguageModel}"
                                      Style="{StaticResource ConfigurationListViewStyle}"
                                      ItemContainerStyle="{StaticResource ConfigurationListViewItemStyle}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource GlassCardBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                <WrapPanel Margin="0,10,0,0">
                                                    <Border Style="{StaticResource CapsuleBorderStyle}">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Text="{Binding SummaryModelId, StringFormat=模型 ID: {0}}"/>
                                                    </Border>
                                                    <Border Style="{StaticResource CapsuleBorderStyle}">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Text="{Binding InterfaceType, StringFormat=接口: {0}}"/>
                                                    </Border>
                                                    <Border Style="{StaticResource CapsuleBorderStyle}">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Text="{Binding ContextWindowText, StringFormat=上下文: {0}}"/>
                                                    </Border>
                                                    <Border Style="{StaticResource CapsuleBorderStyle}">
                                                        <TextBlock VerticalAlignment="Center"
                                                                   FontSize="11"
                                                                   Text="{Binding ConfigurationStatusText, StringFormat=状态: {0}}"/>
                                                    </Border>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Border>
                    </DockPanel>

                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Margin="0,0,0,10"
                                   Text="语言模型配置"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>

                        <Border Grid.Row="1"
                                Style="{StaticResource GlassCardBorderStyle}">
                            <Grid>
                                <ContentControl Content="{Binding SelectedLanguageModel}"
                                                ContentTemplate="{StaticResource LanguageModelEditorTemplate}"/>
                                <TextBlock Text="从左侧选择一个语言模型后，在这里统一编辑它的配置。"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedLanguageModel}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <GroupBox Grid.Row="2"
                          Header="功能层级列表">
                    <DockPanel Margin="10">
                        <StackPanel DockPanel.Dock="Top"
                                    Orientation="Horizontal"
                                    Margin="0,0,0,10">
                            <Button Width="120"
                                    Command="{Binding AddCapabilityLayerCommand}"
                                    Content="新增功能层级"/>
                            <Button Width="120"
                                    Margin="8,0,0,0"
                                    Command="{Binding RemoveCapabilityLayerCommand}"
                                    Content="删除所选层级"/>
                        </StackPanel>

                        <TextBlock DockPanel.Dock="Top"
                                   Margin="0,0,0,10"
                                   Text="{Binding ContextCompressionValidationText}"
                                   TextWrapping="Wrap"/>

                        <ListView ItemsSource="{Binding CapabilityLayers}"
                                  SelectedItem="{Binding SelectedCapabilityLayer}"
                                  Style="{StaticResource ConfigurationListViewStyle}"
                                  ItemContainerStyle="{StaticResource ConfigurationListViewItemStyle}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource GlassCardBorderStyle}">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,0,0,8">
                                                <TextBlock Width="72"
                                                           VerticalAlignment="Center"
                                                           Text="层级名称"
                                                           FontWeight="SemiBold"/>
                                                <TextBox MinWidth="240"
                                                         IsEnabled="{Binding CanRename}"
                                                         Text="{Binding Name, UpdateSourceTrigger=LostFocus}"/>
                                                <Border Margin="10,0,0,0"
                                                        Padding="8,2"
                                                        CornerRadius="10"
                                                        Background="#22000000"
                                                        BorderBrush="#4496FCFF"
                                                        BorderThickness="1"
                                                        Visibility="{Binding IsBuiltIn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="内置" FontSize="11"/>
                                                </Border>
                                                <Button Width="140"
                                                        Margin="10,0,0,0"
                                                        Command="{Binding DataContext.AddCapabilityLayerEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Content="添加语言模型"/>
                                            </StackPanel>

                                            <TextBlock Margin="0,0,0,8"
                                                       Text="{Binding ManagementHint}"
                                                       TextWrapping="Wrap"/>

                                            <ListView ItemsSource="{Binding LanguageModels}"
                                                      Style="{StaticResource ConfigurationListViewStyle}"
                                                      ItemContainerStyle="{StaticResource ConfigurationListViewItemStyle}">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Style="{StaticResource GlassCardBorderStyle}">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <ComboBox Grid.Column="0"
                                                                          ItemsSource="{Binding DataContext.LanguageModels, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                          DisplayMemberPath="DisplayName"
                                                                          SelectedValuePath="Key"
                                                                          SelectedValue="{Binding LanguageModelKey, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <Button Grid.Column="1"
                                                                        Width="60"
                                                                        Margin="8,0,0,0"
                                                                        Command="{Binding DataContext.MoveCapabilityLayerEntryUpCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="上移"/>
                                                                <Button Grid.Column="2"
                                                                        Width="60"
                                                                        Margin="8,0,0,0"
                                                                        Command="{Binding DataContext.MoveCapabilityLayerEntryDownCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="下移"/>
                                                                <Button Grid.Column="3"
                                                                        Width="60"
                                                                        Margin="8,0,0,0"
                                                                        Command="{Binding DataContext.RemoveCapabilityLayerEntryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="删除"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </DockPanel>
                </GroupBox>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
