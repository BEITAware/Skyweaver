<UserControl x:Class="Skyweaver.Controls.WorkflowEditorControl.Views.WorkflowEditorControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="clr-namespace:Skyweaver.Controls.WorkflowEditorControl.Models"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.WorkflowEditorControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:WorkflowEditorControlViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="620"
             d:DesignWidth="920"
             Focusable="True"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display">
    <UserControl.Resources>
        <ResourceDictionary>
            <LinearGradientBrush x:Key="WorkflowSurfaceBaseBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#FF101A25" Offset="0"/>
                <GradientStop Color="#FF0B1119" Offset="0.52"/>
                <GradientStop Color="#FF081017" Offset="1"/>
            </LinearGradientBrush>

            <DrawingBrush x:Key="WorkflowSurfaceMinorGridBrush"
                          TileMode="Tile"
                          Viewport="0,0,24,24"
                          ViewportUnits="Absolute"
                          Stretch="None">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#162B4760" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="24,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,24"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <DrawingBrush x:Key="WorkflowSurfaceMajorGridBrush"
                          TileMode="Tile"
                          Viewport="0,0,96,96"
                          ViewportUnits="Absolute"
                          Stretch="None">
                <DrawingBrush.Drawing>
                    <GeometryDrawing>
                        <GeometryDrawing.Pen>
                            <Pen Brush="#2F4A6C88" Thickness="1"/>
                        </GeometryDrawing.Pen>
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <LineGeometry StartPoint="0,0" EndPoint="96,0"/>
                                <LineGeometry StartPoint="0,0" EndPoint="0,96"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingBrush.Drawing>
            </DrawingBrush>

            <RadialGradientBrush x:Key="WorkflowSurfaceGlowBrush"
                                 Center="0.18,0"
                                 GradientOrigin="0.18,0"
                                 RadiusX="1.2"
                                 RadiusY="0.9">
                <GradientStop Color="#2E80B8E3" Offset="0"/>
                <GradientStop Color="#10294764" Offset="0.4"/>
                <GradientStop Color="#00000000" Offset="1"/>
            </RadialGradientBrush>

            <LinearGradientBrush x:Key="WorkflowNodeBodyBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#F3162738" Offset="0"/>
                <GradientStop Color="#ED0D1825" Offset="0.56"/>
                <GradientStop Color="#F3071018" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowNodeHeaderBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#F0738CA4" Offset="0"/>
                <GradientStop Color="#D52E4E6E" Offset="0.62"/>
                <GradientStop Color="#DD162A40" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowNodeFooterBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#FF132030" Offset="0"/>
                <GradientStop Color="#FF0C141E" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowPanelBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#F21A2B3E" Offset="0"/>
                <GradientStop Color="#F10D1722" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="WorkflowPanelHeaderBrush"
                                 StartPoint="0,0"
                                 EndPoint="0,1">
                <GradientStop Color="#E36A8AA9" Offset="0"/>
                <GradientStop Color="#C52F4F6E" Offset="0.66"/>
                <GradientStop Color="#C41B3044" Offset="1"/>
            </LinearGradientBrush>

            <SolidColorBrush x:Key="WorkflowNodeTextBrush" Color="#FFF5FBFF"/>
            <SolidColorBrush x:Key="WorkflowNodeMutedTextBrush" Color="#D8E8F4FF"/>
            <SolidColorBrush x:Key="WorkflowNodeFooterTextBrush" Color="#CCE5F5FF"/>
            <SolidColorBrush x:Key="WorkflowNodeDividerBrush" Color="#35516A82"/>
            <SolidColorBrush x:Key="WorkflowPortGuideBrush" Color="#45698299"/>

            <Style x:Key="WorkflowNodeCardStyle" TargetType="Border">
                <Setter Property="Width" Value="{Binding Width}"/>
                <Setter Property="MinHeight" Value="118"/>
                <Setter Property="Background" Value="{StaticResource WorkflowNodeBodyBrush}"/>
                <Setter Property="BorderBrush" Value="#839EB9CD"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10"
                                          ShadowDepth="2"
                                          Opacity="0.28"
                                          Color="#CC000000"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsInputOutputNode}" Value="True">
                        <Setter Property="BorderBrush" Value="#86A8C4D9"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsAgentNode}" Value="True">
                        <Setter Property="BorderBrush" Value="#8AB7CDE0"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicNode}" Value="True">
                        <Setter Property="BorderBrush" Value="#8CB6CDB0"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicExecutionNode}" Value="True">
                        <Setter Property="BorderBrush" Value="#8CB0C8D9"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsNextLogicExecutionNode}" Value="True">
                        <Setter Property="BorderBrush" Value="#90B8C9B3"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BorderBrush" Value="#FFE6F6FF"/>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect BlurRadius="14"
                                                  ShadowDepth="0"
                                                  Opacity="0.46"
                                                  Color="#B04E82A8"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowNodeSelectionFrameStyle" TargetType="Border">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#00FFFFFF"/>
                <Setter Property="Visibility" Value="Collapsed"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Setter Property="Background" Value="#0E6AA9D3"/>
                        <Setter Property="BorderBrush" Value="#BFE7FBFF"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowNodeAccentBandStyle" TargetType="Border">
                <Setter Property="Height" Value="4"/>
                <Setter Property="VerticalAlignment" Value="Top"/>
                <Setter Property="Background" Value="#FF8FB6D3"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsInputOutputNode}" Value="True">
                        <Setter Property="Background" Value="#FFA8CAE1"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsAgentNode}" Value="True">
                        <Setter Property="Background" Value="#FF9CC5E2"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicNode}" Value="True">
                        <Setter Property="Background" Value="#FFB0CDA3"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicExecutionNode}" Value="True">
                        <Setter Property="Background" Value="#FFA5CBE4"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsNextLogicExecutionNode}" Value="True">
                        <Setter Property="Background" Value="#FFB7D1A8"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="Background" Value="#FFF4FCFF"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowNodeKindBadgeStyle" TargetType="Border">
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#8BB8D4EA"/>
                <Setter Property="Background" Value="#26364C62"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsInputOutputNode}" Value="True">
                        <Setter Property="Background" Value="#28435A72"/>
                        <Setter Property="BorderBrush" Value="#A2CDE8FF"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsAgentNode}" Value="True">
                        <Setter Property="Background" Value="#253A5268"/>
                        <Setter Property="BorderBrush" Value="#92C2E2F9"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicNode}" Value="True">
                        <Setter Property="Background" Value="#27424937"/>
                        <Setter Property="BorderBrush" Value="#9AC7D7A0"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsLogicExecutionNode}" Value="True">
                        <Setter Property="Background" Value="#283F566B"/>
                        <Setter Property="BorderBrush" Value="#98C5E0F3"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsNextLogicExecutionNode}" Value="True">
                        <Setter Property="Background" Value="#29444B38"/>
                        <Setter Property="BorderBrush" Value="#A4C8DCA7"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowNodePortsPanelStyle" TargetType="Border">
                <Setter Property="Background" Value="#1F08131D"/>
                <Setter Property="BorderBrush" Value="#324E677D"/>
                <Setter Property="BorderThickness" Value="0,1,0,1"/>
            </Style>

            <Style x:Key="WorkflowPortAnchorStyle" TargetType="Border">
                <Setter Property="Width" Value="16"/>
                <Setter Property="Height" Value="16"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#FFDDF4FF"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFF7FCFF" Offset="0"/>
                            <GradientStop Color="#FF8CC4E8" Offset="0.45"/>
                            <GradientStop Color="#FF35648C" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsXmlFieldPort}" Value="True">
                        <Setter Property="BorderBrush" Value="#FFF1DFBF"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFFBF2" Offset="0"/>
                                    <GradientStop Color="#FFF2C67F" Offset="0.45"/>
                                    <GradientStop Color="#FFB06F28" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsFlexiblePort}" Value="True">
                        <Setter Property="BorderBrush" Value="#FFE2F8EC"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFF8FFFC" Offset="0"/>
                                    <GradientStop Color="#FFB9E1CF" Offset="0.45"/>
                                    <GradientStop Color="#FF4E886D" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowNaturalPortGlyphStyle" TargetType="Ellipse">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Width" Value="6"/>
                <Setter Property="Height" Value="6"/>
                <Setter Property="Fill" Value="#FFFFFFFF"/>
                <Setter Property="Stroke" Value="#CC6BA9D3"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNaturalLanguagePort}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowXmlPortGlyphStyle" TargetType="Rectangle">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Width" Value="7"/>
                <Setter Property="Height" Value="7"/>
                <Setter Property="Fill" Value="#FFFFFFFF"/>
                <Setter Property="Stroke" Value="#CCB77F37"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsXmlFieldPort}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowSmartPortGlyphStyle" TargetType="Rectangle">
                <Setter Property="Visibility" Value="Collapsed"/>
                <Setter Property="Width" Value="7"/>
                <Setter Property="Height" Value="7"/>
                <Setter Property="Fill" Value="#EAF7FFFC"/>
                <Setter Property="Stroke" Value="#CC5F8E76"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Setter Property="StrokeDashArray" Value="1.5 1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsFlexiblePort}" Value="True">
                        <Setter Property="Visibility" Value="Visible"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowConnectionShadowPathStyle" TargetType="Path">
                <Setter Property="Stroke" Value="#66000000"/>
                <Setter Property="StrokeThickness" Value="5.4"/>
                <Setter Property="StrokeStartLineCap" Value="Square"/>
                <Setter Property="StrokeEndLineCap" Value="Square"/>
                <Setter Property="StrokeLineJoin" Value="Miter"/>
                <Setter Property="Opacity" Value="0.75"/>
            </Style>

            <Style x:Key="WorkflowConnectionBasePathStyle" TargetType="Path">
                <Setter Property="Stroke" Value="#FF8FB8D5"/>
                <Setter Property="StrokeThickness" Value="3.2"/>
                <Setter Property="StrokeStartLineCap" Value="Square"/>
                <Setter Property="StrokeEndLineCap" Value="Square"/>
                <Setter Property="StrokeLineJoin" Value="Miter"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsXmlConnection}" Value="True">
                        <Setter Property="Stroke" Value="#FFD5AE6C"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowConnectionHighlightPathStyle" TargetType="Path">
                <Setter Property="Stroke" Value="#DFF8FDFF"/>
                <Setter Property="StrokeThickness" Value="1.1"/>
                <Setter Property="StrokeStartLineCap" Value="Square"/>
                <Setter Property="StrokeEndLineCap" Value="Square"/>
                <Setter Property="StrokeLineJoin" Value="Miter"/>
                <Setter Property="Opacity" Value="0.88"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsXmlConnection}" Value="True">
                        <Setter Property="Stroke" Value="#FFF7E3BF"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowConnectionMarkerStyle" TargetType="Rectangle">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="Fill" Value="#FF8FB8D5"/>
                <Setter Property="Stroke" Value="#FFF5FCFF"/>
                <Setter Property="StrokeThickness" Value="1"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsXmlConnection}" Value="True">
                        <Setter Property="Fill" Value="#FFD5AE6C"/>
                        <Setter Property="Stroke" Value="#FFFFF7EA"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding PathData}" Value="">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="WorkflowConnectionSourceMarkerStyle"
                   TargetType="Rectangle"
                   BasedOn="{StaticResource WorkflowConnectionMarkerStyle}">
                <Setter Property="Width" Value="6"/>
                <Setter Property="Height" Value="6"/>
            </Style>

            <Style x:Key="WorkflowConnectionTargetMarkerStyle"
                   TargetType="Rectangle"
                   BasedOn="{StaticResource WorkflowConnectionMarkerStyle}">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Height" Value="8"/>
            </Style>

            <Style x:Key="ConfigurationListViewStyle"
                   TargetType="ListView"
                   BasedOn="{StaticResource AeroListViewStyle}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="6"/>
            </Style>

            <Style x:Key="ConfigurationListViewItemStyle"
                   TargetType="ListViewItem"
                   BasedOn="{StaticResource AeroListViewItemStyle}">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Grid>
                                <Border x:Name="HoverOverlay"
                                        Background="{StaticResource MenuItemHoverBrush}"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <Border x:Name="SelectedOverlay"
                                        Background="{StaticResource MenuItemClickedBrush}"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" TargetName="HoverOverlay" Value="0.2"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Opacity" TargetName="SelectedOverlay" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GlassCardBorderStyle"
                   TargetType="Border"
                   BasedOn="{StaticResource ChatSessionHeaderBorderStyle}">
                <Setter Property="Margin" Value="0"/>
                <Setter Property="Padding" Value="12,10"/>
            </Style>

            <Style x:Key="CapsuleBorderStyle"
                   TargetType="Border">
                <Setter Property="Background" Value="{DynamicResource ButtonIdleBrush}"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="MinWidth" Value="58"/>
                <Setter Property="CornerRadius" Value="12"/>
                <Setter Property="Padding" Value="10,0"/>
                <Setter Property="Margin" Value="0,0,6,6"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="6"/>
            <RowDefinition Height="260"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#33000000"
                BorderThickness="0,0,0,1">
            <Grid MinHeight="118">
                <Border Style="{DynamicResource TabContentBorderStyle}"/>
                <Border Background="{DynamicResource RibbonContentCoverMaskBrush}"/>

                <Grid Margin="10,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="310"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,12,0"
                            Padding="12,10"
                            BorderBrush="#2AFFFFFF"
                            BorderThickness="1"
                            CornerRadius="0"
                            Background="#16000000">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Description}"
                                       Margin="0,6,0,0"
                                       Foreground="#D7EDFF"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Hint}"
                                       Margin="0,8,0,0"
                                       Foreground="#A7D8F0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding CurrentNodeGraphName, StringFormat=当前节点图：{0}}"
                                       Margin="0,10,0,0"
                                       Foreground="#DDF6FFFF"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding NodeGraphLibrarySummaryText}"
                                       Margin="0,6,0,0"
                                       Foreground="#A9D9F1"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  CanContentScroll="False">
                        <StackPanel Orientation="Horizontal">
                            <GroupBox Header="&#28155;&#21152;&#33410;&#28857;" Style="{DynamicResource RibbonGroupStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel Width="310"
                                                Margin="0,0,12,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="&#20195;&#29702;&#33410;&#28857;&#26469;&#28304;"
                                                   Margin="2,0,0,4"
                                                   Foreground="#CCF2FFFF"
                                                   FontSize="10"/>
                                        <TextBlock Margin="2,6,0,0"
                                                   Foreground="#DDF6FFFF"
                                                   FontSize="11"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Text="{Binding AvailableAgentSummaryText}"/>
                                        <TextBlock Margin="2,6,0,0"
                                                   Foreground="#A9D9F1"
                                                   FontSize="10"
                                                   TextWrapping="Wrap"
                                                   Text="&#20195;&#29702;&#33410;&#28857;&#20250;&#20174;&#8220;&#20195;&#29702;&#37197;&#32622;&#8221;&#39029;&#38754;&#33258;&#21160;&#35835;&#21462;&#12290;&#23558;&#20809;&#26631;&#24748;&#20572;&#22312;&#8220;&#20195;&#29702;&#33410;&#28857;&#8221;&#19978;&#21363;&#21487;&#23637;&#24320;&#23376;&#33756;&#21333;&#36873;&#25321;&#20855;&#20307;&#20195;&#29702;&#12290;"/>
                                    </StackPanel>

                                    <Button x:Name="AddNodeMenuButton"
                                            Style="{DynamicResource RibbonLargeButtonStyle}"
                                            ToolTip="&#28155;&#21152;&#33410;&#28857;"
                                            Click="AddNodeMenuButton_Click">
                                        <Button.ContextMenu>
                                            <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                                <MenuItem Header="&#20195;&#29702;&#33410;&#28857;"
                                                          ItemsSource="{Binding AvailableAgents}"
                                                          ToolTip="&#24748;&#20572;&#20197;&#36873;&#25321;&#20855;&#20307;&#20195;&#29702;">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="AI"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF2FCFF"/>
                                                    </MenuItem.Icon>
                                                    <MenuItem.ItemContainerStyle>
                                                        <Style TargetType="{x:Type MenuItem}"
                                                               BasedOn="{StaticResource AnimatedMenuItemStyle}">
                                                            <Setter Property="Header"
                                                                    Value="{Binding DisplayText}"/>
                                                            <Setter Property="InputGestureText"
                                                                    Value="{Binding PortTypeSummaryText}"/>
                                                            <Setter Property="ToolTip"
                                                                    Value="{Binding MenuDescription}"/>
                                                            <Setter Property="Command"
                                                                    Value="{Binding DataContext.AddAgentNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                                                            <Setter Property="CommandParameter"
                                                                    Value="{Binding}"/>
                                                        </Style>
                                                    </MenuItem.ItemContainerStyle>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="&#36923;&#36753;&#19982;"
                                                          Command="{Binding AddLogicAndNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="AND"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#36923;&#36753;&#25110;"
                                                          Command="{Binding AddLogicOrNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="OR"
                                                                   FontSize="10"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#36923;&#36753;&#24322;&#25110;"
                                                          Command="{Binding AddLogicXorNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="XOR"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#36923;&#36753;&#38750;"
                                                          Command="{Binding AddLogicNotNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="NOT"
                                                                   FontSize="9"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFF7F7DE"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <Separator/>
                                                <MenuItem Header="&#36923;&#36753;&#25191;&#34892;"
                                                          Command="{Binding AddLogicExecutionNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="RUN"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFE9FDFF"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                                <MenuItem Header="&#20165;&#19979;&#19968;&#20010;&#36923;&#36753;&#25191;&#34892;"
                                                          Command="{Binding AddNextLogicExecutionNodeCommand}">
                                                    <MenuItem.Icon>
                                                        <TextBlock Text="N+1"
                                                                   FontSize="8"
                                                                   FontWeight="Bold"
                                                                   Foreground="#FFE9FDEB"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </Button.ContextMenu>

                                        <StackPanel>
                                            <Image Source="pack://application:,,,/Resources/add_node.png"
                                                   Width="32"
                                                   Height="32"
                                                   Margin="0,2,0,2"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   UseLayoutRounding="True"/>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center">
                                                <TextBlock Text="&#28155;&#21152;&#33410;&#28857;"
                                                           FontSize="10"/>
                                                <TextBlock Text=" &#x25BE;"
                                                           FontSize="8"
                                                           Margin="2,0,0,0"
                                                           VerticalAlignment="Bottom"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="&#32534;&#36753;" Style="{DynamicResource RibbonGroupStyle}">
                                <StackPanel Orientation="Horizontal">
                                    <Button Style="{DynamicResource RibbonLargeButtonStyle}"
                                            ToolTip="&#21024;&#38500;&#24403;&#21069;&#36873;&#20013;&#33410;&#28857;"
                                            Command="{Binding DeleteSelectedNodeCommand}">
                                        <StackPanel>
                                            <Image Source="pack://application:,,,/Resources/delete_node.png"
                                                   Width="32"
                                                   Height="32"
                                                   Margin="0,2,0,2"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   UseLayoutRounding="True"/>
                                            <TextBlock Text="&#21024;&#38500;&#33410;&#28857;"
                                                       HorizontalAlignment="Center"
                                                       FontSize="10"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{DynamicResource RibbonLargeButtonStyle}"
                                            ToolTip="&#20445;&#23384;&#20250;&#35805;&#27969;"
                                            Command="{Binding SaveCommand}">
                                        <StackPanel>
                                            <Image Source="pack://application:,,,/Resources/save.png"
                                                   Width="32"
                                                   Height="32"
                                                   Margin="0,2,0,2"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   UseLayoutRounding="True"/>
                                            <TextBlock Text="&#20445;&#23384;"
                                                       HorizontalAlignment="Center"
                                                       FontSize="10"/>
                                        </StackPanel>
                                    </Button>

                                    <Button Style="{DynamicResource RibbonLargeButtonStyle}"
                                            ToolTip="&#25171;&#24320;&#37197;&#32622;&#30446;&#24405;"
                                            Command="{Binding OpenConfigurationDirectoryCommand}">
                                        <StackPanel>
                                            <Image Source="pack://application:,,,/Resources/WorkFolder.png"
                                                   Width="32"
                                                   Height="32"
                                                   Margin="0,2,0,2"
                                                   RenderOptions.BitmapScalingMode="HighQuality"
                                                   UseLayoutRounding="True"/>
                                            <TextBlock Text="&#25171;&#24320;&#30446;&#24405;"
                                                       HorizontalAlignment="Center"
                                                       FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#18000000"
                BorderBrush="#33000000"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#36830;&#25509;&#29366;&#24577;"
                               Margin="0,0,10,0"
                               Foreground="#88FFFFFF"/>
                    <TextBlock Text="{Binding PendingConnectionText}"
                               Foreground="#D7F3FF"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="#FFE9FFD0"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="8,8,8,0"
                BorderBrush="#5B89AAC1"
                BorderThickness="1"
                Background="#18000000">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="Both"
                          CanContentScroll="False">
                <Grid x:Name="EditorSurface"
                      Width="{Binding CanvasWidth}"
                      Height="{Binding CanvasHeight}"
                      MouseLeftButtonDown="SurfaceBackground_MouseLeftButtonDown">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding SurfaceScale}"
                                        ScaleY="{Binding SurfaceScale}"/>
                    </Grid.LayoutTransform>

                    <Grid Panel.ZIndex="0"
                          IsHitTestVisible="False">
                        <Border Background="{StaticResource WorkflowSurfaceBaseBrush}"/>
                        <Border Background="{StaticResource WorkflowSurfaceGlowBrush}"
                                Opacity="0.9"/>
                        <Border Background="{StaticResource WorkflowSurfaceMinorGridBrush}"
                                Opacity="0.95"/>
                        <Border Background="{StaticResource WorkflowSurfaceMajorGridBrush}"
                                Opacity="0.95"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Connections}"
                                  IsHitTestVisible="False"
                                  Panel.ZIndex="1">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SessionFlowConnectionModel}">
                                <Canvas Width="{Binding ElementName=EditorSurface, Path=ActualWidth}"
                                        Height="{Binding ElementName=EditorSurface, Path=ActualHeight}">
                                    <Path Data="{Binding PathData}"
                                          Style="{StaticResource WorkflowConnectionShadowPathStyle}"/>
                                    <Path Data="{Binding PathData}"
                                          Style="{StaticResource WorkflowConnectionBasePathStyle}"/>
                                    <Path Data="{Binding PathData}"
                                          Style="{StaticResource WorkflowConnectionHighlightPathStyle}"/>

                                    <Rectangle Style="{StaticResource WorkflowConnectionSourceMarkerStyle}"
                                               Canvas.Left="{Binding SourceX}"
                                               Canvas.Top="{Binding SourceY}">
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform X="-3"
                                                                Y="-3"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>

                                    <Rectangle Style="{StaticResource WorkflowConnectionTargetMarkerStyle}"
                                               Canvas.Left="{Binding TargetX}"
                                               Canvas.Top="{Binding TargetY}">
                                        <Rectangle.RenderTransform>
                                            <TranslateTransform X="-4"
                                                                Y="-4"/>
                                        </Rectangle.RenderTransform>
                                    </Rectangle>
                                </Canvas>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ItemsControl ItemsSource="{Binding Nodes}"
                                  Panel.ZIndex="2">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}"/>
                                <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SessionFlowNodeModel}">
                                <Border Style="{StaticResource WorkflowNodeCardStyle}"
                                        MouseLeftButtonDown="NodeCard_MouseLeftButtonDown"
                                        MouseLeftButtonUp="NodeCard_MouseLeftButtonUp"
                                        MouseMove="NodeCard_MouseMove">
                                    <Grid ClipToBounds="False">
                                        <Border Margin="1"
                                                Panel.ZIndex="1"
                                                Style="{StaticResource WorkflowNodeSelectionFrameStyle}"
                                                IsHitTestVisible="False"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="44"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <Border Grid.Row="0"
                                                    Background="{StaticResource WorkflowNodeHeaderBrush}"
                                                    BorderBrush="#2E4A6178"
                                                    BorderThickness="0,0,0,1">
                                                <Grid>
                                                    <Border Style="{StaticResource WorkflowNodeAccentBandStyle}"/>
                                                    <Border Height="1"
                                                            Margin="0,4,0,0"
                                                            VerticalAlignment="Top"
                                                            Background="#A0FFFFFF"/>

                                                    <DockPanel Margin="12,8,12,8">
                                                        <Border DockPanel.Dock="Right"
                                                                Margin="10,0,0,0"
                                                                VerticalAlignment="Center"
                                                                Style="{StaticResource WorkflowNodeKindBadgeStyle}">
                                                            <TextBlock Text="{Binding NodeKindDisplayText}"
                                                                       Foreground="{StaticResource WorkflowNodeMutedTextBrush}"
                                                                       FontFamily="{DynamicResource AeroFontFamily}"
                                                                       FontSize="{DynamicResource AeroSmallFontSize}"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>

                                                        <TextBlock Text="{Binding Title}"
                                                                   Foreground="{StaticResource WorkflowNodeTextBrush}"
                                                                   FontFamily="{DynamicResource AeroFontFamily}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   VerticalAlignment="Center"/>
                                                    </DockPanel>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="1"
                                                    Style="{StaticResource WorkflowNodePortsPanelStyle}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="12"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Rectangle Grid.Column="1"
                                                               Width="1"
                                                               Margin="0,8"
                                                               HorizontalAlignment="Center"
                                                               Fill="{StaticResource WorkflowNodeDividerBrush}"/>

                                                    <ItemsControl Grid.Column="0"
                                                                  ItemsSource="{Binding InputPorts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type models:SessionFlowPortModel}">
                                                                <DockPanel Height="24"
                                                                           LastChildFill="True">
                                                                    <Border DockPanel.Dock="Left"
                                                                            Margin="-8,0,0,0"
                                                                            VerticalAlignment="Center"
                                                                            Cursor="Hand"
                                                                            ToolTip="{Binding PortTypeDisplayText}"
                                                                            Style="{StaticResource WorkflowPortAnchorStyle}"
                                                                            MouseLeftButtonDown="PortAnchor_MouseLeftButtonDown">
                                                                        <Grid>
                                                                            <Ellipse HorizontalAlignment="Center"
                                                                                     VerticalAlignment="Center"
                                                                                     Style="{StaticResource WorkflowNaturalPortGlyphStyle}"/>
                                                                            <Rectangle HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       RenderTransformOrigin="0.5,0.5"
                                                                                       Style="{StaticResource WorkflowXmlPortGlyphStyle}">
                                                                                <Rectangle.RenderTransform>
                                                                                    <RotateTransform Angle="45"/>
                                                                                </Rectangle.RenderTransform>
                                                                            </Rectangle>
                                                                            <Rectangle HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Style="{StaticResource WorkflowSmartPortGlyphStyle}"/>
                                                                        </Grid>
                                                                    </Border>

                                                                    <Rectangle DockPanel.Dock="Left"
                                                                               Width="10"
                                                                               Height="1"
                                                                               VerticalAlignment="Center"
                                                                               Fill="{StaticResource WorkflowPortGuideBrush}"/>

                                                                    <TextBlock Margin="6,0,0,0"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding Name}"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Foreground="{StaticResource WorkflowNodeTextBrush}"
                                                                               FontFamily="{DynamicResource AeroFontFamily}"
                                                                               FontSize="11"/>
                                                                </DockPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>

                                                    <ItemsControl Grid.Column="2"
                                                                  ItemsSource="{Binding OutputPorts}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate DataType="{x:Type models:SessionFlowPortModel}">
                                                                <DockPanel Height="24"
                                                                           LastChildFill="True">
                                                                    <Border DockPanel.Dock="Right"
                                                                            Margin="0,0,-8,0"
                                                                            VerticalAlignment="Center"
                                                                            Cursor="Hand"
                                                                            ToolTip="{Binding PortTypeDisplayText}"
                                                                            Style="{StaticResource WorkflowPortAnchorStyle}"
                                                                            MouseLeftButtonDown="PortAnchor_MouseLeftButtonDown">
                                                                        <Grid>
                                                                            <Ellipse HorizontalAlignment="Center"
                                                                                     VerticalAlignment="Center"
                                                                                     Style="{StaticResource WorkflowNaturalPortGlyphStyle}"/>
                                                                            <Rectangle HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       RenderTransformOrigin="0.5,0.5"
                                                                                       Style="{StaticResource WorkflowXmlPortGlyphStyle}">
                                                                                <Rectangle.RenderTransform>
                                                                                    <RotateTransform Angle="45"/>
                                                                                </Rectangle.RenderTransform>
                                                                            </Rectangle>
                                                                            <Rectangle HorizontalAlignment="Center"
                                                                                       VerticalAlignment="Center"
                                                                                       Style="{StaticResource WorkflowSmartPortGlyphStyle}"/>
                                                                        </Grid>
                                                                    </Border>

                                                                    <Rectangle DockPanel.Dock="Right"
                                                                               Width="10"
                                                                               Height="1"
                                                                               VerticalAlignment="Center"
                                                                               Fill="{StaticResource WorkflowPortGuideBrush}"/>

                                                                    <TextBlock Margin="0,0,6,0"
                                                                               VerticalAlignment="Center"
                                                                               Text="{Binding Name}"
                                                                               TextAlignment="Right"
                                                                               TextTrimming="CharacterEllipsis"
                                                                               Foreground="{StaticResource WorkflowNodeTextBrush}"
                                                                               FontFamily="{DynamicResource AeroFontFamily}"
                                                                               FontSize="11"/>
                                                                </DockPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Grid>
                                            </Border>

                                            <Border Grid.Row="2"
                                                    Background="{StaticResource WorkflowNodeFooterBrush}"
                                                    BorderBrush="#2E4A6178"
                                                    BorderThickness="0,1,0,0"
                                                    Padding="10,5">
                                                <TextBlock Text="{Binding PortSummaryText}"
                                                           Foreground="{StaticResource WorkflowNodeFooterTextBrush}"
                                                           FontFamily="{DynamicResource AeroFontFamily}"
                                                           FontSize="{DynamicResource AeroSmallFontSize}"/>
                                            </Border>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Panel.ZIndex="8"
                            Width="330"
                            Margin="{Binding InspectorMargin}"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Visibility="{Binding IsInspectorVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                            BorderBrush="#739AB8CD"
                            BorderThickness="1"
                            Background="{StaticResource WorkflowPanelBrush}">
                        <Grid>
                            <Border Height="1"
                                    VerticalAlignment="Top"
                                    Background="#55FFFFFF"
                                    IsHitTestVisible="False"/>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0"
                                        Background="{StaticResource WorkflowPanelHeaderBrush}"
                                        BorderBrush="#324A6378"
                                        BorderThickness="0,0,0,1"
                                        Padding="8,6">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right"
                                                Style="{DynamicResource SmallWindowButtonStyle}"
                                                Content="&#x00D7;"
                                                Command="{Binding ClearSelectionCommand}"/>
                                        <TextBlock Text="{Binding InspectorTitle}"
                                                   Foreground="{StaticResource WorkflowNodeTextBrush}"
                                                   FontFamily="{DynamicResource AeroFontFamily}"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <StackPanel Grid.Row="1"
                                            Margin="10">
                                    <TextBlock Text="{Binding SelectedNodeKindHint}"
                                               TextWrapping="Wrap"
                                               Foreground="#D8EFFBFF"/>

                                    <StackPanel Margin="0,10,0,0"
                                                Visibility="{Binding IsSelectedNodeAgent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <CheckBox Content="&#26159;&#21542;&#20026;&#38544;&#34255;&#20195;&#29702;"
                                                  IsChecked="{Binding SelectedNode.IsHiddenAgent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Margin="0,10,0,0"
                                                Visibility="{Binding IsSelectedNodeLogicExecution, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Text="&#26032;&#22686;&#36879;&#20256;&#36755;&#20837;"
                                                   Foreground="#D8EFFBFF"/>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,6,0,0">
                                            <Button Style="{DynamicResource RibbonButtonStyle}"
                                                    Padding="8,3"
                                                    Margin="0,0,6,0"
                                                    Command="{Binding AddExecutionNaturalLanguageInputCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="10"
                                                             Height="10"
                                                             Margin="0,0,6,0"
                                                             VerticalAlignment="Center"
                                                             Stroke="#FFF2FCFF"
                                                             StrokeThickness="1">
                                                        <Ellipse.Fill>
                                                            <RadialGradientBrush MappingMode="RelativeToBoundingBox"
                                                                                 Center="0.35,0.35"
                                                                                 GradientOrigin="0.35,0.35">
                                                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#FF7EE3FF" Offset="0.36"/>
                                                                <GradientStop Color="#FF22BFE9" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Ellipse.Fill>
                                                    </Ellipse>
                                                    <TextBlock Text="&#33258;&#28982;&#35821;&#35328;"/>
                                                </StackPanel>
                                            </Button>

                                            <Button Style="{DynamicResource RibbonButtonStyle}"
                                                    Padding="8,3"
                                                    Command="{Binding AddExecutionXmlInputCommand}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Rectangle Width="10"
                                                               Height="10"
                                                               Margin="0,0,6,0"
                                                               VerticalAlignment="Center"
                                                               Stroke="#FFFFF3D8"
                                                               StrokeThickness="1"
                                                               RenderTransformOrigin="0.5,0.5">
                                                        <Rectangle.Fill>
                                                            <RadialGradientBrush MappingMode="RelativeToBoundingBox"
                                                                                 Center="0.35,0.35"
                                                                                 GradientOrigin="0.35,0.35">
                                                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                                <GradientStop Color="#FFF3D28D" Offset="0.34"/>
                                                                <GradientStop Color="#FFBE8731" Offset="1"/>
                                                            </RadialGradientBrush>
                                                        </Rectangle.Fill>
                                                        <Rectangle.RenderTransform>
                                                            <RotateTransform Angle="45"/>
                                                        </Rectangle.RenderTransform>
                                                    </Rectangle>
                                                    <TextBlock Text="XML&#23383;&#27573;"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Margin="0,12,0,0"
                                               Foreground="#B3E5F6FF"
                                               TextWrapping="Wrap"
                                               Text="{Binding PersistenceFilePath}"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Row="3"
                      Height="6"
                      HorizontalAlignment="Stretch"
                      Style="{DynamicResource AeroHorizontalSplitterStyle}"/>

        <Border Grid.Row="4"
                Margin="8,0,8,8"
                BorderBrush="#5B89AAC1"
                BorderThickness="1"
                Background="{DynamicResource DocumentTabBackgroundBrush}">
            <Grid Margin="14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Margin="0,0,0,12">
                    <TextBlock Text="节点图库"
                               FontSize="14"
                               FontWeight="SemiBold"/>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#D7EDFF"
                               Text="{Binding NodeGraphLibrarySummaryText}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <WrapPanel Grid.Row="1"
                           Margin="0,0,0,12">
                    <Button Width="102"
                            Margin="0,0,8,8"
                            Command="{Binding CreateNodeGraphCommand}"
                            Content="新建"/>
                    <Button Width="102"
                            Margin="0,0,8,8"
                            Command="{Binding OpenSelectedNodeGraphCommand}"
                            Content="打开"/>
                    <Button Width="102"
                            Margin="0,0,8,8"
                            Command="{Binding SaveCommand}"
                            Content="保存"/>
                    <Button Width="102"
                            Margin="0,0,8,8"
                            Command="{Binding RenameSelectedNodeGraphCommand}"
                            Content="重命名"/>
                    <Button Width="102"
                            Margin="0,0,8,8"
                            Command="{Binding DeleteSelectedNodeGraphCommand}"
                            Content="删除"/>
                    <Button Width="102"
                            Margin="0,0,8,8"
                            Command="{Binding RefreshNodeGraphLibraryCommand}"
                            Content="刷新"/>
                </WrapPanel>

                <Border Grid.Row="2"
                        CornerRadius="2"
                        BorderThickness="1"
                        Padding="4"
                        SnapsToDevicePixels="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.10059,1.65236"
                                             EndPoint="2.53982,1.65236"
                                             Opacity="0.5">
                            <LinearGradientBrush.RelativeTransform>
                                <TransformGroup>
                                    <SkewTransform CenterX="0.10059"
                                                   CenterY="1.65236"
                                                   AngleX="-59.7491"
                                                   AngleY="0"/>
                                    <RotateTransform CenterX="0.10059"
                                                     CenterY="1.65236"
                                                     Angle="-70.8836"/>
                                </TransformGroup>
                            </LinearGradientBrush.RelativeTransform>
                            <GradientStop Color="#3BFFFFFF" Offset="0"/>
                            <GradientStop Color="#1DFFFFFF" Offset="0.0766283"/>
                            <GradientStop Color="#07FFFFFF" Offset="0.109195"/>
                            <GradientStop Color="#04FFFFFF" Offset="0.298851"/>
                            <GradientStop Color="#3AFFFFFF" Offset="0.327586"/>
                            <GradientStop Color="#1AFFFFFF" Offset="0.465517"/>
                            <GradientStop Color="#14FFFFFF" Offset="0.591954"/>
                            <GradientStop Color="#05FFFFFF" Offset="0.758621"/>
                            <GradientStop Color="#44FFFFFF" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#40000000"/>
                    </Border.BorderBrush>

                    <ListView x:Name="NodeGraphListView"
                              ItemsSource="{Binding NodeGraphs}"
                              SelectedItem="{Binding SelectedNodeGraph}"
                              MouseDoubleClick="NodeGraphListView_MouseDoubleClick"
                              Style="{StaticResource ConfigurationListViewStyle}"
                              ItemContainerStyle="{StaticResource ConfigurationListViewItemStyle}">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:SessionFlowGraphListItemModel}">
                                <Border Style="{StaticResource GlassCardBorderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="44"
                                                Height="44"
                                                Margin="0,2,10,2"
                                                Background="#12000000"
                                                BorderBrush="#40FFFFFF"
                                                BorderThickness="1"
                                                CornerRadius="10">
                                            <Image Width="28"
                                                   Height="28"
                                                   Source="pack://application:,,,/Resources/Nodegraph.png"
                                                   Stretch="Uniform"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="{Binding Name}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           TextWrapping="Wrap"/>
                                                <Border DockPanel.Dock="Right"
                                                        Margin="8,0,0,0"
                                                        Padding="6,2"
                                                        Background="#33000000"
                                                        BorderBrush="#55FFFFFF"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Visibility="{Binding IsCurrent, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock FontSize="10"
                                                               Foreground="#FFF3FCFF"
                                                               Text="当前打开"/>
                                                </Border>
                                            </DockPanel>

                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#D9FFFFFF"
                                                       Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="#B5DDEFFF"
                                                       Text="{Binding FilePath}"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <WrapPanel Margin="0,8,0,0">
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Text="{Binding GraphSummaryText}"/>
                                                </Border>
                                                <Border Style="{StaticResource CapsuleBorderStyle}">
                                                    <TextBlock VerticalAlignment="Center"
                                                               FontSize="11"
                                                               Text="{Binding ModifiedText}"/>
                                                </Border>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <Border Grid.Row="3"
                        Margin="0,12,0,0"
                        Style="{StaticResource GlassCardBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Foreground="#D9FFFFFF"
                                       Text="节点图库目录"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#D9FFFFFF"
                                       Text="{Binding ConfigurationDirectoryPath}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="#FFD3F6FF"
                                       Text="当前节点图文件"
                                       FontWeight="SemiBold"/>
                            <TextBlock Margin="0,4,0,0"
                                       Foreground="#FFD3F6FF"
                                       Text="{Binding PersistenceFilePath}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="132"
                                Margin="12,0,0,0"
                                Command="{Binding OpenConfigurationDirectoryCommand}"
                                Content="打开节点图库"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
