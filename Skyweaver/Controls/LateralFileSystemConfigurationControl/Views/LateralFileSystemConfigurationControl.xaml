<UserControl x:Class="Skyweaver.Controls.LateralFileSystemConfigurationControl.Views.LateralFileSystemConfigurationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Skyweaver.Controls.LateralFileSystemConfigurationControl.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModels:LateralFileSystemConfigurationControlViewModel, IsDesignTimeCreatable=True}"
             d:DesignHeight="420"
             d:DesignWidth="640">
    <Grid Background="{DynamicResource AeroWorkAreaBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="18">
            <StackPanel>
                <Border Style="{DynamicResource AeroParameterPanelHeaderStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Title}"
                                   Style="{DynamicResource AeroParameterPanelHeaderTextStyle}"/>
                        <TextBlock Text="{Binding Description}"
                                   Style="{DynamicResource AeroParameterPanelDescriptionTextStyle}"/>
                        <TextBlock Text="{Binding Hint}"
                                   Style="{DynamicResource AeroParameterPanelDescriptionTextStyle}"/>
                    </StackPanel>
                </Border>

                <GroupBox Header="基础配置"
                          Style="{DynamicResource AeroGroupBoxStyle}"
                          Margin="0,16,0,0">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="启用侧向文件系统"/>
                        <CheckBox Grid.Row="0"
                                  Grid.Column="1"
                                  IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                  VerticalAlignment="Center"
                                  Content="允许加载和维护侧向文件系统虚拟化根"/>

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   VerticalAlignment="Center"
                                   Text="工作根目录"/>
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Margin="0,0,10,0"
                                 Padding="6,4"
                                 Text="{Binding WorkingRootDirectory, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                 VerticalContentAlignment="Center"/>
                        <Button Grid.Row="2"
                                Grid.Column="2"
                                MinWidth="96"
                                Padding="12,5"
                                Style="{DynamicResource AeroButtonStyle}"
                                Content="浏览..."
                                Command="{Binding BrowseWorkingRootDirectoryCommand}"/>

                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Foreground="{DynamicResource AeroForegroundBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding WorkingRootDirectoryHint}"/>

                        <Border Grid.Row="6"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Padding="10,8"
                                BorderBrush="{DynamicResource AeroBorderBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource WindowBackgroundBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Text="配置文件位置"/>
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Text="{Binding ConfigurationFilePath}"/>
                            </Grid>
                        </Border>

                        <StackPanel Grid.Row="8"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal">
                            <Button MinWidth="132"
                                    Padding="12,5"
                                    Style="{DynamicResource AeroButtonStyle}"
                                    Content="打开配置目录"
                                    Command="{Binding OpenConfigurationDirectoryCommand}"/>
                            <TextBlock Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="约束说明"
                          Style="{DynamicResource AeroGroupBoxStyle}"
                          Margin="0,16,0,0">
                    <StackPanel Margin="6">
                        <TextBlock TextWrapping="Wrap"
                                   Text="1. 所有虚拟化根都必须位于工作根目录之下。"/>
                        <TextBlock Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Text="2. LateralFileSystemTree.xml 不在配置阶段创建，只在建立首个侧向文件系统虚拟文件夹时由后端自动创建。"/>
                        <TextBlock Margin="0,6,0,0"
                                   TextWrapping="Wrap"
                                   Text="3. 页面中的两项配置在变更后会立即写入用户目录下的 XML。"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
