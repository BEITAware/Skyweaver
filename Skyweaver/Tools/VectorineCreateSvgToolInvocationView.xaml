                        </GeometryDrawing>
                        <GeometryDrawing Geometry="F1 M 4,1L 1180.48,1C 1182.14,1 1183.48,2.34326 1183.48,4.00012L 1183.48,814.089C 1183.48,815.745 1182.14,817.089 1180.48,817.089L 4,817.089C 2.34314,817.089 1,815.745 1,814.089L 1,4.00012C 1,2.34326 2.34314,1 4,1 Z ">
                            <GeometryDrawing.Brush>
                                <RadialGradientBrush RadiusX="1.18083" RadiusY="0.766859" Center="0.499999,0.0498997" GradientOrigin="0.499999,0.0498997">
                                    <RadialGradientBrush.GradientStops>
                                        <GradientStop Color="#2AFFFFFF" Offset="0"/>
                                        <GradientStop Color="#14FFFFFF" Offset="0.247126"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.461686"/>
                                    </RadialGradientBrush.GradientStops>
                                    <RadialGradientBrush.RelativeTransform>
