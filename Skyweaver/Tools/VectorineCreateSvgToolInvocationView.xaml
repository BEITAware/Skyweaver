                        <GeometryDrawing Geometry="F1 M 4,1L 1180.48,1C 1182.14,1 1183.48,2.34326 1183.48,4.00012L 1183.48,814.089C 1183.48,815.745 1182.14,817.089 1180.48,817.089L 4,817.089C 2.34314,817.089 1,815.745 1,814.089L 1,4.00012C 1,2.34326 2.34314,1 4,1 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="2" LineJoin="Round">
                                    <Pen.Brush>
                                        <RadialGradientBrush RadiusX="2.14746" RadiusY="0.676245" Center="0.499999,0.499998" GradientOrigin="0.499999,0.499998">
                                            <RadialGradientBrush.GradientStops>
                                                <GradientStop Color="#67FFFFFF" Offset="0"/>
                                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                                            </RadialGradientBrush.GradientStops>
                                            <RadialGradientBrush.RelativeTransform>
                                                <TransformGroup>
                                                    <SkewTransform CenterX="0.499999" CenterY="0.499998" AngleX="7.47052" AngleY="0"/>
                                                    <RotateTransform CenterX="0.499999" CenterY="0.499998" Angle="48.7353"/>
                                                </TransformGroup>
                                            </RadialGradientBrush.RelativeTransform>
                                        </RadialGradientBrush>
