                                    <RadialGradientBrush.GradientStops>
                                        <GradientStop Color="#4DC9CACA" Offset="0"/>
                                        <GradientStop Color="#0E445E7C" Offset="0.988506"/>
                                    </RadialGradientBrush.GradientStops>
                                    <RadialGradientBrush.RelativeTransform>
                                        <TransformGroup>
                                            <SkewTransform CenterX="0.5" CenterY="0.97775" AngleX="5.23488" AngleY="0"/>
