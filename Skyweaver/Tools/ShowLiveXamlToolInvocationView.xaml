<UserControl x:Class="Skyweaver.Tools.ShowLiveXamlToolInvocationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border Background="#1B152434"
            BorderBrush="#5598E8FF"
            BorderThickness="1"
            CornerRadius="10"
            Padding="12">
        <StackPanel>
            <DockPanel LastChildFill="False">
                <TextBlock Text="LiveXAML Preview"
                           Foreground="#FFF0FBFF"
                           FontWeight="SemiBold"
                           FontSize="13"/>
                <TextBlock DockPanel.Dock="Right"
                           Margin="10,0,0,0"
                           Text="{Binding StatusText}"
                           Foreground="#FFB9E7FF"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </DockPanel>

            <TextBlock Margin="0,6,0,0"
                       Text="{Binding FilePathText}"
                       Foreground="#FFD7F7FF"
                       FontFamily="Consolas"
                       FontSize="12"
                       TextWrapping="Wrap"/>

            <TextBlock Margin="0,4,0,0"
                       Text="{Binding HintText}"
                       Foreground="#CCFFFFFF"
                       FontSize="11"
                       TextWrapping="Wrap"/>

            <Border Margin="0,10,0,0"
                    Padding="10"
                    Background="#22FFFFFF"
                    BorderBrush="#3347C8FF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding HasDiagnostics, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ScrollViewer MaxHeight="170"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding DiagnosticsText}"
                               Foreground="#FFFFE4D9"
                               FontFamily="Consolas"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <Border Margin="0,10,0,0"
                    Padding="12"
                    Background="#12F7FBFF"
                    BorderBrush="#447FDFFF"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <ScrollViewer MaxHeight="480"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Visibility="{Binding HasPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ContentControl Content="{Binding PreviewElement}"/>
                    </ScrollViewer>

                    <TextBlock Text="No preview yet."
                               Foreground="#CCFFFFFF"
                               FontStyle="Italic"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding HasPreview}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
