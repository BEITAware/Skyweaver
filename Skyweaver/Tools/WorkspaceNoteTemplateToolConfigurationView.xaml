<UserControl x:Class="Skyweaver.Tools.WorkspaceNoteTemplateToolConfigurationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             MinHeight="260">
    <UserControl.Resources>
        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="#11000000"/>
            <Setter Property="BorderBrush" Value="#33FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Padding="14"
                CornerRadius="16"
                BorderBrush="#40FFFFFF"
                BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1A6FA9FF" Offset="0"/>
                    <GradientStop Color="#0BFFFFFF" Offset="0.45"/>
                    <GradientStop Color="#1528E5B0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="Workspace Note Template 配置"/>
                <TextBlock Margin="0,6,0,0"
                           Text="这个面板完全由工具自己提供。这里演示了预设选择、默认标签和输出模板结构如何一起影响运行时工具定义。"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="模板预设"/>
                        <ComboBox Margin="0,10,0,0"
                                  ItemsSource="{Binding Presets}"
                                  SelectedItem="{Binding SelectedPreset}"
                                  DisplayMemberPath="DisplayName"/>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#FFD3F6FF"
                                   Text="{Binding PresetDescription}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <CheckBox Content="在模板里包含 Workspace / Session 上下文"
                                  IsChecked="{Binding IncludeContextMetadata}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#99FFFFFF"
                                   Text="关闭后，工具生成结果仍可用，但不会自动把当前工作区路径和会话名写进模板。"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="默认标签"/>
                        <TextBox Margin="0,10,0,0"
                                 Text="{Binding DefaultTagsText, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="#FFD3F6FF"
                                   Text="{Binding DefaultTagsHint}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock FontSize="13"
                                   FontWeight="SemiBold"
                                   Text="摘要占位行数"/>
                        <ComboBox Margin="0,10,0,0"
                                  ItemsSource="{Binding SummaryBulletCountOptions}"
                                  SelectedItem="{Binding SelectedSummaryBulletCount}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="2"
                    Padding="14"
                    CornerRadius="14"
                    Background="#12000000"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="13"
                               FontWeight="SemiBold"
                               Text="实时预览"/>
                    <TextBlock Margin="0,10,0,0"
                               FontFamily="Consolas"
                               Text="{Binding PreviewText}"
                               TextWrapping="Wrap"/>
                    <TextBlock Margin="0,14,0,0"
                               Foreground="#99FFFFFF"
                               Text="提示：这里的变化会被宿主持久化，并在工具实际执行时通过上下文重新读取。"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
