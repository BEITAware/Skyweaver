<Window x:Class="Skyweaver.Windows.ShellChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:Skyweaver.Controls.ShellChatSessionControl.Views"
        mc:Ignorable="d"
        Title="{DynamicResource ShellChat.Window.Title}"
        Height="560"
        Width="800"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        Opacity="0"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleX" From="0.75" To="1" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.65"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootScale" Storyboard.TargetProperty="ScaleY" From="0.75" To="1" Duration="0:0:0.55">
                        <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.65"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootTranslate" Storyboard.TargetProperty="Y" From="60" To="0" Duration="0:0:0.45">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Window.Resources>
        <!-- 降低不透明度的深蓝紫渐变背景底色 -->
        <LinearGradientBrush x:Key="ShellWindowBackgroundBrush" StartPoint="0.2,0" EndPoint="0.8,1">
            <GradientStop Color="#38080D1A" Offset="0"/>
            <GradientStop Color="#22101530" Offset="0.5"/>
            <GradientStop Color="#3204060F" Offset="1"/>
        </LinearGradientBrush>

        <!-- 复用并增强已有设计资源的毛玻璃反射笔刷 -->
        <DrawingBrush x:Key="WindowSoftGlassSliceBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 0.160156,0.159668L 1386.16,0.159668L 1386.16,223.646L 0.160156,223.646L 0.160156,0.159668 Z ">
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0.1,1.6" EndPoint="2.5,1.6">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TransformGroup>
                                            <SkewTransform AngleX="-60" CenterX="0.1" CenterY="1.6"/>
                                            <RotateTransform Angle="-70" CenterX="0.1" CenterY="1.6"/>
                                        </TransformGroup>
                                    </LinearGradientBrush.RelativeTransform>
                                    <LinearGradientBrush.GradientStops>
                                        <GradientStop Color="#1AFFFFFF" Offset="0"/>
                                        <GradientStop Color="#0DFFFFFF" Offset="0.1"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.3"/>
                                        <GradientStop Color="#1CFFFFFF" Offset="0.33"/>
                                        <GradientStop Color="#08FFFFFF" Offset="0.6"/>
                                        <GradientStop Color="#20FFFFFF" Offset="1"/>
                                    </LinearGradientBrush.GradientStops>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="16" RenderTransformOrigin="0.9,0.9">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="RootScale" ScaleX="0.75" ScaleY="0.75" />
                <TranslateTransform x:Name="RootTranslate" Y="60" />
            </TransformGroup>
        </Grid.RenderTransform>


        <!-- 窗口整体阴影和发光效果 -->
        <Border CornerRadius="16" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect Color="#FF00A8FF" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
        </Border>

        <!-- 主玻璃体边界 -->
        <Border x:Name="MainBorder" 
                CornerRadius="16" 
                BorderThickness="1" 
                Background="{StaticResource ShellWindowBackgroundBrush}">
            <Border.BorderBrush>
                <!-- 亮色发光玻璃边缘描边 -->
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#80FFFFFF" Offset="0"/>
                    <GradientStop Color="#25FFFFFF" Offset="0.2"/>
                    <GradientStop Color="#15FFFFFF" Offset="0.8"/>
                    <GradientStop Color="#4580D0FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.BorderBrush>

            <Grid x:Name="BackgroundChrome"
                  ClipToBounds="True"
                  SizeChanged="BackgroundChrome_SizeChanged">
                <!-- 1. Aero 极光霓虹模糊圈 (右上) -->
                <Ellipse Width="350" Height="280" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-120,-80,0" Fill="#222B5BC2">
                    <Ellipse.Effect>
                        <BlurEffect Radius="90"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- 2. Aero 极光霓虹模糊圈 (左下) -->
                <Ellipse Width="320" Height="250" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-80,0,0,-100" Fill="#187638B5">
                    <Ellipse.Effect>
                        <BlurEffect Radius="80"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- 3. 玻璃对角线反光斜切面（高科技质感，使用圆角 Border 以防溢出） -->
                <Border CornerRadius="15" Background="{StaticResource WindowSoftGlassSliceBrush}" IsHitTestVisible="False" Opacity="0.5" Margin="1"/>

                <!-- 4. 全息网格杂点叠加遮罩（使用圆角 Border 以防溢出） -->
                <Border CornerRadius="15" Opacity="0.25" IsHitTestVisible="False" Margin="1">
                    <Border.Background>
                        <VisualBrush TileMode="Tile" Viewport="0,0,5,5" ViewportUnits="Absolute">
                            <VisualBrush.Visual>
                                <Canvas Width="5" Height="5" Background="Transparent">
                                    <Ellipse Width="1" Height="1" Fill="#20FFFFFF" Canvas.Left="0" Canvas.Top="0"/>
                                    <Ellipse Width="1" Height="1" Fill="#20FFFFFF" Canvas.Left="2.5" Canvas.Top="2.5"/>
                                </Canvas>
                            </VisualBrush.Visual>
                        </VisualBrush>
                    </Border.Background>
                </Border>

                <!-- 6. 主内容区域：嵌入 Shell 聊天会话控件 -->
                <Grid Margin="0,0,0,0">
                    <shell:ShellChatSessionControl x:Name="ChatControl"/>
                </Grid>
            </Grid>
        </Border>

        <!-- 大尺寸超椭圆头像，突破主玻璃窗口边界 -->
        <Border Width="84" Height="84" 
                HorizontalAlignment="Left" VerticalAlignment="Top" 
                Margin="-12,-12,0,0" 
                Background="#20101530"
                CornerRadius="28"
                BorderBrush="#60FFFFFF" BorderThickness="1.5"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <RotateTransform Angle="-30"/>
            </Border.RenderTransform>
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="4" Opacity="0.6"/>
            </Border.Effect>
            <Border CornerRadius="26" Margin="3" ClipToBounds="True" Background="#60000000">
                <Image Source="{Binding DataContext.ActiveAgentAvatarPath, ElementName=ChatControl}"
                       Stretch="UniformToFill"/>
            </Border>
        </Border>
    </Grid>
</Window>
