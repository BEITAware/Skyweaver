<Window x:Class="Skyweaver.Windows.AssistantBallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shapes="clr-namespace:System.Windows.Shapes;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="语音智能助手" 
        Height="380" 
        Width="640"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- 毛玻璃反射笔刷 -->
        <DrawingBrush x:Key="WindowSoftGlassSliceBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 0.160156,0.159668L 1386.16,0.159668L 1386.16,223.646L 0.160156,223.646L 0.160156,0.159668 Z ">
                            <GeometryDrawing.Brush>
                                <LinearGradientBrush StartPoint="0.1,1.6" EndPoint="2.5,1.6">
                                    <LinearGradientBrush.RelativeTransform>
                                        <TransformGroup>
                                            <SkewTransform AngleX="-60" CenterX="0.1" CenterY="1.6"/>
                                            <RotateTransform Angle="-70" CenterX="0.1" CenterY="1.6"/>
                                        </TransformGroup>
                                    </LinearGradientBrush.RelativeTransform>
                                    <LinearGradientBrush.GradientStops>
                                        <GradientStop Color="#15FFFFFF" Offset="0"/>
                                        <GradientStop Color="#0AFFFFFF" Offset="0.1"/>
                                        <GradientStop Color="#00FFFFFF" Offset="0.3"/>
                                        <GradientStop Color="#15FFFFFF" Offset="0.33"/>
                                        <GradientStop Color="#05FFFFFF" Offset="0.6"/>
                                        <GradientStop Color="#18FFFFFF" Offset="1"/>
                                    </LinearGradientBrush.GradientStops>
                                </LinearGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="20">
        <!-- 窗口外围发光阴影 -->
        <Border CornerRadius="20" Background="Transparent">
            <Border.Effect>
                <DropShadowEffect Color="#FF00A8FF" BlurRadius="18" ShadowDepth="0" Opacity="0.25"/>
            </Border.Effect>
        </Border>

        <!-- Aero 极光霓虹模糊背景装饰 -->
        <Grid ClipToBounds="True">
            <Grid.OpacityMask>
                <VisualBrush>
                    <VisualBrush.Visual>
                        <Path Data="F1 M 83.2957,81.7759L 543.665,81.7759C 561.89,81.7759 576.665,96.5505 576.665,114.776L 576.665,282.071C 576.665,300.297 561.89,315.071 543.665,315.071L 83.2957,315.071C 65.0703,315.071 50.2957,300.297 50.2957,282.071L 50.2957,114.776C 50.2957,96.5505 65.0703,81.7759 83.2957,81.7759 Z" Fill="Black"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Grid.OpacityMask>
        </Grid>

        <!-- 布局容器 -->
        <Canvas Width="578" Height="316" HorizontalAlignment="Center" VerticalAlignment="Center">

            <!-- ================= BACKGROUND LAYER ================= -->
            <!-- 1. 草稿主圆角背景 -->
            <Path Data="F1 M 83.2957,81.7759L 543.665,81.7759C 561.89,81.7759 576.665,96.5505 576.665,114.776L 576.665,282.071C 576.665,300.297 561.89,315.071 543.665,315.071L 83.2957,315.071C 65.0703,315.071 50.2957,300.297 50.2957,282.071L 50.2957,114.776C 50.2957,96.5505 65.0703,81.7759 83.2957,81.7759 Z ">
                <Path.Stroke>
                    <SolidColorBrush Color="#6793F2FF" />
                </Path.Stroke>
                <Path.Fill>
                    <RadialGradientBrush RadiusX="1.01282" RadiusY="0.917797" Center="0.499999,0.977751" GradientOrigin="0.499999,0.977751">
                        <RadialGradientBrush.GradientStops>
                            <GradientStop Color="#C5C9CACA" Offset="0"/>
                            <GradientStop Color="#34445E7C" Offset="0.988506"/>
                        </RadialGradientBrush.GradientStops>
                        <RadialGradientBrush.RelativeTransform>
                            <TransformGroup>
                                <SkewTransform CenterX="0.499999" CenterY="0.977751" AngleX="5.23483" AngleY="0"/>
                                <RotateTransform CenterX="0.499999" CenterY="0.977751" Angle="70.4939"/>
                            </TransformGroup>
                        </RadialGradientBrush.RelativeTransform>
                    </RadialGradientBrush>
                </Path.Fill>
            </Path>

            <!-- 2. 草稿线性渐变高光 -->
            <Path Data="F1 M 83.2957,81.7759L 543.665,81.7759C 561.89,81.7759 576.665,96.5505 576.665,114.776L 576.665,282.071C 576.665,300.297 561.89,315.071 543.665,315.071L 83.2957,315.071C 65.0703,315.071 50.2957,300.297 50.2957,282.071L 50.2957,114.776C 50.2957,96.5505 65.0703,81.7759 83.2957,81.7759 Z ">
                <Path.Stroke>
                    <SolidColorBrush Color="#6793F2FF"/>
                </Path.Stroke>
                <Path.Fill>
                    <LinearGradientBrush StartPoint="0.0274605,0.229456" EndPoint="1.2125,0.229456">
                        <LinearGradientBrush.RelativeTransform>
                            <TransformGroup>
                                <SkewTransform CenterX="0.0274605" CenterY="0.229456" AngleX="6.3821" AngleY="0"/>
                                <RotateTransform CenterX="0.0274605" CenterY="0.229456" Angle="32.3018"/>
                            </TransformGroup>
                        </LinearGradientBrush.RelativeTransform>
                        <LinearGradientBrush.GradientStops>
                            <GradientStop Color="#00FFFFFF" Offset="0"/>
                            <GradientStop Color="#2CFFFFFF" Offset="0.254789"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.513412"/>
                            <GradientStop Color="#39FFFFFF" Offset="0.701149"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.720307"/>
                            <GradientStop Color="#33FFFFFF" Offset="0.856322"/>
                            <GradientStop Color="#03FFFFFF" Offset="0.89272"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.988506"/>
                        </LinearGradientBrush.GradientStops>
                    </LinearGradientBrush>
                </Path.Fill>
            </Path>

            <!-- 3. 草稿径向渐变顶部高光 -->
            <Path Data="F1 M 83.2959,81.7761L 543.665,81.7761C 561.89,81.7761 576.665,96.5508 576.665,114.776L 576.665,282.071C 576.665,300.296 561.89,315.071 543.665,315.071L 83.2959,315.071C 65.0703,315.071 50.2959,300.296 50.2959,282.071L 50.2959,114.776C 50.2959,96.5508 65.0703,81.7761 83.2959,81.7761 Z ">
                <Path.Fill>
                    <RadialGradientBrush RadiusX="1.18083" RadiusY="0.76686" Center="0.5,0.0499008" GradientOrigin="0.5,0.0499008">
                        <RadialGradientBrush.GradientStops>
                            <GradientStop Color="#66FFFFFF" Offset="0"/>
                            <GradientStop Color="#24FFFFFF" Offset="0.247126"/>
                            <GradientStop Color="#00FFFFFF" Offset="0.421456"/>
                        </RadialGradientBrush.GradientStops>
                    </RadialGradientBrush>
                </Path.Fill>
            </Path>

            <!-- 附加的半透明 Aero 玻璃反光条 -->
            <Path Data="F1 M 83.2957,81.7759L 543.665,81.7759C 561.89,81.7759 576.665,96.5505 576.665,114.776L 576.665,282.071C 576.665,300.297 561.89,315.071 543.665,315.071L 83.2957,315.071C 65.0703,315.071 50.2957,300.297 50.2957,282.071L 50.2957,114.776C 50.2957,96.5505 65.0703,81.7759 83.2957,81.7759 Z "
                  Fill="{StaticResource WindowSoftGlassSliceBrush}"
                  Opacity="0.4"
                  IsHitTestVisible="False"/>


            <!-- ================= VOLUME BAR ================= -->
            <Border Canvas.Left="236" Canvas.Top="96" 
                    Width="33.8" Height="205.2" 
                    CornerRadius="4" 
                    ClipToBounds="True" 
                    Background="#182A0000">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0.5,0.5" EndPoint="1.25,0.5">
                        <LinearGradientBrush.GradientStops>
                            <GradientStop Color="#7FEAF2FE" Offset="0"/>
                            <GradientStop Color="#00B7D7EE" Offset="0.528331"/>
                            <GradientStop Color="#6F91C7E6" Offset="0.816092"/>
                            <GradientStop Color="#7F8CC5E6" Offset="1"/>
                        </LinearGradientBrush.GradientStops>
                    </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.BorderThickness>
                    <Thickness Left="2" Top="2" Right="2" Bottom="2"/>
                </Border.BorderThickness>
                
                <Grid VerticalAlignment="Bottom">
                    <Border x:Name="VolumeFill" 
                            Background="#FFFF0000" 
                            Height="10" 
                            CornerRadius="2"
                            VerticalAlignment="Bottom">
                        <Border.Effect>
                            <DropShadowEffect Color="#FFFF0000" BlurRadius="10" ShadowDepth="0" Opacity="0.95"/>
                        </Border.Effect>
                    </Border>
                </Grid>
            </Border>


            <!-- ================= STATE BOX ================= -->
            <Border x:Name="StateContainer" 
                    Canvas.Left="279" Canvas.Top="96" 
                    Width="273.5" Height="205.4" 
                    CornerRadius="6" 
                    Background="#A5000208" 
                    BorderBrush="#A5343434" 
                    BorderThickness="2"
                    ClipToBounds="True">
                <Grid>
                    <!-- 内阴影效果 -->
                    <Border x:Name="InnerShadowBorder" Margin="-10" BorderThickness="10" CornerRadius="12">
                        <Border.BorderBrush>
                            <SolidColorBrush x:Name="InnerShadowBrush" Color="Black" />
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect x:Name="InnerShadowEffect" Color="Black" BlurRadius="15" ShadowDepth="0" Opacity="0.85"/>
                        </Border.Effect>
                    </Border>

                    <!-- 橘黄色微光内发光装饰圈 -->
                    <Border x:Name="ListeningGlowOverlay" CornerRadius="4" BorderThickness="1" Visibility="Collapsed" Opacity="0">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#DFFF7F00"/>
                        </Border.BorderBrush>
                        <Border.Background>
                            <RadialGradientBrush RadiusX="1.2" RadiusY="1.2" Center="0.5,0.5">
                                <GradientStop Color="#0FFFFF7F" Offset="0" />
                                <GradientStop Color="#05FF7F00" Offset="0.8" />
                                <GradientStop Color="#00FF7F00" Offset="1" />
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="StateTitleText"
                                   Text="运行状态" 
                                   Foreground="#A08C9DBF" 
                                   FontSize="13" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,0,0,10"/>
                        
                        <TextBlock x:Name="StateValueText" 
                                   Text="闲置" 
                                   Foreground="#E5FFFFFF" 
                                   FontSize="22" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect x:Name="StateTextGlow" Color="#FF00A8FF" BlurRadius="8" ShadowDepth="0" Opacity="0.3"/>
                            </TextBlock.Effect>
                        </TextBlock>

                        <TextBlock x:Name="StateTimerText"
                                   Text="" 
                                   Foreground="#A5FF7F00" 
                                   FontSize="11" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- ================= BALL DECORATION (球体直接作为控件在窗口内，修复编译错误) ================= -->
            <Grid x:Name="BallVisualContainer"
                  Canvas.Left="2" Canvas.Top="2" 
                  Width="223.4" Height="223.4"
                  RenderTransformOrigin="0.5,0.5"
                  IsHitTestVisible="False">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="BallScale" ScaleX="1" ScaleY="1"/>
                </Grid.RenderTransform>

                <!-- 1. 球体底圆和描边 -->
                <Path Data="F1 M 113.703,2C 175.396,2 225.407,52.0112 225.407,113.703C 225.407,175.396 175.396,225.407 113.703,225.407C 52.0115,225.407 2,175.396 2,113.703C 2,52.0112 52.0115,2 113.703,2 Z "
                      StrokeThickness="4" StrokeLineJoin="Round">
                    <Path.Stroke>
                        <LinearGradientBrush StartPoint="0.499999,0.00194104" EndPoint="0.499999,0.996118">
                            <LinearGradientBrush.GradientStops>
                                <GradientStop Color="#7FEAF2FE" Offset="0"/>
                                <GradientStop Color="#00B7D7EE" Offset="0.528331"/>
                                <GradientStop Color="#6F91C7E6" Offset="0.816092"/>
                                <GradientStop Color="#7F8CC5E6" Offset="1"/>
                            </LinearGradientBrush.GradientStops>
                        </LinearGradientBrush>
                    </Path.Stroke>
                    <Path.Fill>
                        <RadialGradientBrush RadiusX="1.01198" RadiusY="1.33702" Center="0.499999,-0.00697648" GradientOrigin="0.499999,-0.00697648">
                            <RadialGradientBrush.GradientStops>
                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                <GradientStop Color="#FFD1D6E2" Offset="0.101533"/>
                                <GradientStop Color="#FF344B6A" Offset="0.444444"/>
                                <GradientStop Color="#FF0D1C42" Offset="0.544061"/>
                                <GradientStop Color="#FF2B688C" Offset="1"/>
                            </RadialGradientBrush.GradientStops>
                            <RadialGradientBrush.RelativeTransform>
                                <TransformGroup>
                                    <RotateTransform CenterX="0.499999" CenterY="-0.00697648" Angle="90"/>
                                </TransformGroup>
                            </RadialGradientBrush.RelativeTransform>
                        </RadialGradientBrush>
                    </Path.Fill>
                </Path>

                <!-- 2. 蓝色下半球发光渐变 -->
                <Path Data="F1 M 113.703,2C 175.396,2 225.407,52.0112 225.407,113.703C 225.407,175.396 175.396,225.407 113.703,225.407C 52.0115,225.407 2,175.396 2,113.703C 2,52.0112 52.0115,2 113.703,2 Z ">
                    <Path.Fill>
                        <RadialGradientBrush RadiusX="0.729422" RadiusY="0.729421" Center="0.499997,0.969766" GradientOrigin="0.499997,0.969766">
                            <RadialGradientBrush.GradientStops>
                                <GradientStop x:Name="BlueGlowStop" Color="#FF41B8FF" Offset="0"/>
                                <GradientStop Color="#00000000" Offset="1"/>
                            </RadialGradientBrush.GradientStops>
                        </RadialGradientBrush>
                    </Path.Fill>
                </Path>

                <!-- 3. 顶部白色抛光反射高光 -->
                <Path Data="F1 M 113.703,2C 175.396,2 225.407,52.0112 225.407,113.703C 225.407,175.396 175.396,225.407 113.703,225.407C 52.0115,225.407 2,175.396 2,113.703C 2,52.0112 52.0115,2 113.703,2 Z ">
                    <Path.Fill>
                        <RadialGradientBrush RadiusX="0.614249" RadiusY="0.276413" Center="0.499997,-0.104652" GradientOrigin="0.499997,-0.104652">
                            <RadialGradientBrush.GradientStops>
                                <GradientStop Color="#FFFFFFFF" Offset="0.43295"/>
                                <GradientStop Color="#00DFDFDF" Offset="1"/>
                            </RadialGradientBrush.GradientStops>
                        </RadialGradientBrush>
                    </Path.Fill>
                </Path>

                <!-- 呼吸发光特效圈 -->
                <Ellipse x:Name="ListeningBreathRing" 
                         Width="216" Height="216" 
                         HorizontalAlignment="Center" VerticalAlignment="Center" 
                         Stroke="#FFFF7F00" StrokeThickness="3.5" 
                         Opacity="0">
                    <Ellipse.Effect>
                        <BlurEffect Radius="12"/>
                    </Ellipse.Effect>
                </Ellipse>

                <!-- ================= MICROPHONE ICON ================= -->
                <Viewbox Width="52" Height="52" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0">
                    <Grid>
                        <!-- 麦克风图标外发光阴影层 -->
                        <Path Data="M24,4 C19.58,4 16,7.58 16,12 L16,24 C16,28.42 19.58,32 24,32 C28.42,32 32,28.42 32,24 L32,12 C32,7.58 28.42,4 24,4 Z M39,24 C39,32.28 32.28,39 24,39 C15.72,39 9,32.28 9,24 L6,24 C6,33.3 12.8,40.9 22,41.8 L22,46 L26,46 L26,41.8 C35.2,40.9 42,33.3 42,24 L39,24 Z" 
                              Fill="#A000A8FF">
                            <Path.Effect>
                                <DropShadowEffect x:Name="MicGlow" Color="#FF00A8FF" BlurRadius="12" ShadowDepth="0" Opacity="0.9"/>
                            </Path.Effect>
                        </Path>
                        <!-- 麦克风图标实体层 -->
                        <Path Data="M24,4 C19.58,4 16,7.58 16,12 L16,24 C16,28.42 19.58,32 24,32 C28.42,32 32,28.42 32,24 L32,12 C32,7.58 28.42,4 24,4 Z M39,24 C39,32.28 32.28,39 24,39 C15.72,39 9,32.28 9,24 L6,24 C6,33.3 12.8,40.9 22,41.8 L22,46 L26,46 L26,41.8 C35.2,40.9 42,33.3 42,24 L39,24 Z" 
                              Fill="White"/>
                    </Grid>
                </Viewbox>
            </Grid>


            <!-- ================= BALL INTERACTION BUTTON ================= -->
            <!-- 叠加在球体之上的透明交互按钮 -->
            <Button x:Name="BallButton" 
                    Canvas.Left="2" Canvas.Top="2" 
                    Width="223.4" Height="223.4" 
                    Cursor="Hand"
                    Click="BallButton_Click"
                    MouseEnter="BallButton_MouseEnter"
                    MouseLeave="BallButton_MouseLeave"
                    PreviewMouseLeftButtonDown="BallButton_PreviewMouseLeftButtonDown"
                    PreviewMouseLeftButtonUp="BallButton_PreviewMouseLeftButtonUp">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent"/>
                    </ControlTemplate>
                </Button.Template>
            </Button>


            <!-- ================= CLOSE BUTTON ================= -->
            <Button Canvas.Right="12" Canvas.Top="86"
                    Width="16" Height="16"
                    Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"
                    Click="CloseButton_Click"
                    ToolTip="关闭"
                    Opacity="0.45"
                    x:Name="WindowCloseBtn">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Ellipse x:Name="BtnCircle" Fill="#30FFFFFF"/>
                            <Path Data="M4,4 L12,12 M12,4 L4,12" Stroke="White" StrokeThickness="1.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnCircle" Property="Fill" Value="#D0FF4444"/>
                                <Setter Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </Canvas>
    </Grid>
</Window>
