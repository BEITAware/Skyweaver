<Window x:Class="Skyweaver.Windows.StickyNoteRepliesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="回复列表"
        Width="500"
        Height="400"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Icon="/Skyweaver;component/Resources/Skyweaver.ico"
        Background="Transparent"
        AllowsTransparency="False">
    <Window.Resources>
        <!-- Plasma 背景 DrawingBrush 定义 -->
        <DrawingBrush x:Key="PlasmaBackgroundBrush" Stretch="Fill">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <GeometryDrawing Geometry="F1 M 1,0.999878L 400.999,0.999878L 400.999,223L 1,223L 1,0.999878 Z ">
                            <GeometryDrawing.Pen>
                                <Pen Thickness="2" LineJoin="Round" Brush="#FF2A7288"/>
                            </GeometryDrawing.Pen>
                            <GeometryDrawing.Brush>
                                <RadialGradientBrush RadiusX="0.9594" RadiusY="1.23497" Center="0.500009,-0.0053194" GradientOrigin="0.500009,-0.0053194">
                                    <RadialGradientBrush.GradientStops>
                                        <GradientStop Color="#FF306F83" Offset="0"/>
                                        <GradientStop Color="#FF091023" Offset="0.992337"/>
                                    </RadialGradientBrush.GradientStops>
                                </RadialGradientBrush>
                            </GeometryDrawing.Brush>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="AeroListBoxStyle" TargetType="ListBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#35000000"/>
            <Setter Property="BorderBrush" Value="#25FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBox">
                        <Grid>
                            <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"/>
                            <ScrollViewer Margin="6" Focusable="False">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Rectangle Fill="{StaticResource PlasmaBackgroundBrush}"/>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <TextBlock x:Name="TxtTitle" Text="便笺回复" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>

            <!-- 回复列表 -->
            <ListBox x:Name="LstReplies" Grid.Row="1" Style="{StaticResource AeroListBoxStyle}" HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#20FFFFFF" BorderThickness="0,0,0,1" Padding="0,4,0,8" Margin="0,0,0,4">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Creator}" Foreground="#FFA3D8FF" FontWeight="Bold" FontSize="12"/>
                                <TextBlock Grid.Column="2" Text="{Binding DisplayDateTime}" Foreground="#80FFFFFF" FontSize="10" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Grid.ColumnSpan="3" Text="{Binding Content}" Foreground="White" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 确定关闭按钮 -->
            <Button Grid.Row="2" Content="关闭" Width="92" Height="30" Margin="0,12,0,0" HorizontalAlignment="Right" Click="CloseButton_Click" Style="{DynamicResource ResourceToolbarButtonStyle}"/>
        </Grid>
    </Grid>
</Window>
