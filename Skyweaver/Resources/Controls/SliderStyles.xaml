<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════════════════════════ -->
    <!--                                                                                               -->
    <!--                                  Slider 隐式样式                                              -->
    <!--                                                                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════════════════ -->
    <!--                                                                                               -->
    <!--  此样式自动应用于所有 Slider 控件，提供 Aero 风格的滑动条外观。                                  -->
    <!--  设计来源：AeroImplicitStyles.xaml 中的 Slider 隐式样式                                        -->
    <!--                                                                                               -->
    <!--  设计说明：                                                                                    -->
    <!--      ● 轨道背景：半透明深色，带内阴影效果                                                       -->
    <!--      ● 进度填充：蓝色渐变，Aero 风格的发光效果                                                  -->
    <!--      ● 滑块：白色圆角矩形，带阴影和悬停效果                                                     -->
    <!--      ● 支持水平和垂直两种方向                                                                  -->
    <!--                                                                                               -->
    <!-- ═══════════════════════════════════════════════════════════════════════════════════════════ -->

    <!-- Slider 轨道 RepeatButton 样式 (透明，用于点击定位) -->
    <Style x:Key="SliderRepeatButtonTransparent" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Rectangle Fill="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slider Thumb 隐式样式 -->
    <Style TargetType="{x:Type Thumb}" x:Key="SliderThumbStyle">
        <Setter Property="Width" Value="12"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <!-- 外发光 -->
                        <Border x:Name="GlowBorder" CornerRadius="2" Margin="-2" Opacity="0">
                            <Border.Background>
                                <RadialGradientBrush>
                                    <GradientStop Color="#6060B0F0" Offset="0"/>
                                    <GradientStop Color="#0060B0F0" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- 主体 -->
                        <Border x:Name="ThumbBorder" 
                                CornerRadius="2"
                                BorderThickness="1">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                    <GradientStop Color="#FFF0F0F0" Offset="0.4"/>
                                    <GradientStop Color="#FFE0E0E0" Offset="0.5"/>
                                    <GradientStop Color="#FFF5F5F5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#FF909090" Offset="0"/>
                                    <GradientStop Color="#FF707070" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" BlurRadius="3" ShadowDepth="1" Opacity="0.4"/>
                            </Border.Effect>
                        </Border>
                        
                        <!-- 顶部高光 -->
                        <Border CornerRadius="2,2,0,0" Height="8" VerticalAlignment="Top" Margin="1,1,1,0" IsHitTestVisible="False">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#80FFFFFF" Offset="0"/>
                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="GlowBorder" Property="Opacity" Value="0.8"/>
                            <Setter TargetName="ThumbBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFE8F4FF" Offset="0"/>
                                        <GradientStop Color="#FFD0E8FF" Offset="0.4"/>
                                        <GradientStop Color="#FFC0D8F0" Offset="0.5"/>
                                        <GradientStop Color="#FFD8ECFF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                            <Setter TargetName="ThumbBorder" Property="BorderBrush">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FF60A0D0" Offset="0"/>
                                        <GradientStop Color="#FF4080B0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="GlowBorder" Property="Opacity" Value="1"/>
                            <Setter TargetName="ThumbBorder" Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#FFD0E8FF" Offset="0"/>
                                        <GradientStop Color="#FFB0D0F0" Offset="0.4"/>
                                        <GradientStop Color="#FFA0C0E0" Offset="0.5"/>
                                        <GradientStop Color="#FFC0D8F0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Slider 隐式样式 -->
    <Style TargetType="{x:Type Slider}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <!-- 轨道背景 -->
                        <Border x:Name="TrackBackground"
                                Grid.Row="1"
                                Height="6"
                                CornerRadius="3"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#60000000" Offset="0"/>
                                    <GradientStop Color="#40000000" Offset="0.5"/>
                                    <GradientStop Color="#30000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#40000000" Offset="0"/>
                                    <GradientStop Color="#20FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                        </Border>
                        
                        <!-- 进度轨道 -->
                        <Track x:Name="PART_Track" Grid.Row="1">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.DecreaseLarge}" Style="{StaticResource SliderRepeatButtonTransparent}">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="4" CornerRadius="2" VerticalAlignment="Center" Margin="2,0,0,0">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#FF80D0FF" Offset="0"/>
                                                        <GradientStop Color="#FF40A0E0" Offset="0.4"/>
                                                        <GradientStop Color="#FF0080D0" Offset="0.5"/>
                                                        <GradientStop Color="#FF60B0E0" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <!-- 进度条发光效果 -->
                                                <Border CornerRadius="2" Margin="-1">
                                                    <Border.Effect>
                                                        <DropShadowEffect Color="#4080C0FF" BlurRadius="4" ShadowDepth="0" Opacity="0.6"/>
                                                    </Border.Effect>
                                                </Border>
                                            </Border>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="{x:Static Slider.IncreaseLarge}" Style="{StaticResource SliderRepeatButtonTransparent}"/>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource SliderThumbStyle}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    
                    <!-- 垂直方向触发器 -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="TrackBackground" Property="Width" Value="6"/>
                            <Setter TargetName="TrackBackground" Property="Height" Value="Auto"/>
                            <Setter TargetName="TrackBackground" Property="HorizontalAlignment" Value="Center"/>
                            <Setter TargetName="TrackBackground" Property="VerticalAlignment" Value="Stretch"/>
                            <Setter TargetName="PART_Track" Property="Orientation" Value="Vertical"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
