    <system:String x:Key="ChatSession.Page.Title">Chat Session</system:String>
    <system:String x:Key="ChatSession.Page.Description">Configure reasoning presentation in chat sessions.</system:String>
    <system:String x:Key="ChatSession.Page.Hint">Changes are written to PresentationUI.xml immediately.</system:String>
    <system:String x:Key="ChatSession.CollapseReasoning.Label">Collapse Reasoning by Default</system:String>
    <system:String x:Key="ChatSession.CollapseReasoning.Content">New collapsible reasoning blocks are shown collapsed by default.</system:String>
    <system:String x:Key="ChatSession.CollapseReasoning.Hint">Only collapsible reasoning cards are affected; content shown directly in the body is unchanged.</system:String>
    <system:String x:Key="ChatSession.DefaultReasoning.Collapsed">New collapsible reasoning blocks default to collapsed.</system:String>
    <system:String x:Key="ChatSession.DefaultReasoning.Expanded">New collapsible reasoning blocks default to expanded.</system:String>
