    <system:String x:Key="Search.Page.Title">搜索配置</system:String>
    <system:String x:Key="Search.Page.Description">配置搜索引擎 (Brave Search、Tavily、Vertex AI Search) 以供引擎在检索时使用。</system:String>
    <system:String x:Key="Search.Api.Label">搜索 API</system:String>
    <system:String x:Key="Search.Api.Hint">决定系统在检索和信息增强时主要调用哪一个底层的搜索引擎。</system:String>
    <system:String x:Key="Search.Brave.Title">Brave Search 配置</system:String>
    <system:String x:Key="Search.Brave.ApiKey.Label">API 密钥 (ApiKey)</system:String>
    <system:String x:Key="Search.Brave.ApiKey.Hint">访问 Brave 开发者控制台获取，需要已订阅 Search API 服务。</system:String>
    <system:String x:Key="Search.Brave.Country.Label">国家/地区代码</system:String>
    <system:String x:Key="Search.Brave.Country.Hint">国家代码（例如 'US'、'CN'、'JP'），用于指定搜索结果的区域偏好偏置。</system:String>
    <system:String x:Key="Search.Brave.Language.Label">语言代码</system:String>
    <system:String x:Key="Search.Brave.Language.Hint">语言代码（例如 'en'、'zh'、'ja'），用于限定搜索结果的返回语言。</system:String>
    <system:String x:Key="Search.Brave.SafeSearch.Label">安全搜索 (SafeSearch)</system:String>
    <system:String x:Key="Search.Brave.SafeSearch.Hint">过滤敏感或成人网页内容。off：关闭过滤；moderate：适度过滤（默认）；strict：严格过滤。</system:String>
    <system:String x:Key="Search.Brave.Count.Label">结果数量 (Count)</system:String>
    <system:String x:Key="Search.Brave.Count.Hint">每次搜索返回的最大结果记录数。</system:String>
    <system:String x:Key="Search.Brave.Freshness.Label">时间范围 (Freshness)</system:String>
    <system:String x:Key="Search.Brave.Freshness.Hint">根据时间范围限制搜索结果（如过去一天、一周、一月或一年）。</system:String>
    <system:String x:Key="Search.Tavily.Title">Tavily Search 配置</system:String>
    <system:String x:Key="Search.Tavily.ApiKey.Label">API 密钥 (ApiKey)</system:String>
    <system:String x:Key="Search.Tavily.ApiKey.Hint">从 Tavily Console 注册获取，专为大语言模型 RAG 设计的检索 API。</system:String>
    <system:String x:Key="Search.Tavily.SearchDepth.Label">搜索深度</system:String>
    <system:String x:Key="Search.Tavily.SearchDepth.Hint">'basic' 用于快速检索且额度消耗较低，'advanced' 会进行更深入的主题关联提取。</system:String>
    <system:String x:Key="Search.Tavily.IncludeAnswer.Label">包含回答</system:String>
    <system:String x:Key="Search.Tavily.IncludeAnswer.Content">启用摘要回答生成</system:String>
    <system:String x:Key="Search.Tavily.IncludeAnswer.Hint">在搜索结果中包含一段由 Tavily 合成的摘要文本，帮助模型更快理解大意。</system:String>
    <system:String x:Key="Search.Tavily.Topic.Label">搜索类别 (Topic)</system:String>
    <system:String x:Key="Search.Tavily.Topic.Hint">'general' 适用于普通的互联网通用检索，'news' 适用于最近的实时新闻检索。</system:String>
    <system:String x:Key="Search.Tavily.MaxResults.Label">最大结果数 (MaxResults)</system:String>
    <system:String x:Key="Search.Tavily.MaxResults.Hint">搜索引擎最多返回的结果项数量。</system:String>
    <system:String x:Key="Search.Tavily.IncludeImages.Label">包含图片</system:String>
    <system:String x:Key="Search.Tavily.IncludeImages.Content">允许提取相关图片</system:String>
    <system:String x:Key="Search.Tavily.IncludeImages.Hint">是否在搜索结果中包含相关的图片链接。</system:String>
    <system:String x:Key="Search.Tavily.IncludeRawContent.Label">网页正文</system:String>
    <system:String x:Key="Search.Tavily.IncludeRawContent.Content">允许抓取清洗后的整页正文</system:String>
    <system:String x:Key="Search.Tavily.IncludeRawContent.Hint">抓取整个页面，自动去除 HTML 标签以获取纯文本正文（极利于 RAG 深度分析）。</system:String>
