<UserControl x:Class="Skyweaver.PageControls.Tiles.Views.TilesPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:Skyweaver.PageControls.Tiles.Views"
             x:Name="Root"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1100"
             PreviewMouseMove="OnPageViewPreviewMouseMove"
             PreviewMouseLeftButtonUp="OnPageViewPreviewMouseLeftButtonUp">

    <UserControl.Resources>
        <local:SizeToBoolConverter x:Key="SizeToBoolConverter"/>
        <local:TileImageBrushConverter x:Key="TileImageBrushConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>

        <Style x:Key="HeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Light, Microsoft YaHei Light, Arial"/>
            <Setter Property="FontSize" Value="32"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <TextBlock x:Name="TextDisplay"
                                       Text="{TemplateBinding Content}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush x:Name="TextBrush" StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop x:Name="Stop1" Color="#7A8CB0E0" Offset="0"/>
                                        <GradientStop x:Name="Stop2" Color="#4A5A80B0" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Stop1" Storyboard.TargetProperty="Color" To="#B0C2EAEE" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="Stop2" Storyboard.TargetProperty="Color" To="#8090A0D0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="Stop1" Storyboard.TargetProperty="Color" To="#7A8CB0E0" Duration="0:0:0.2"/>
                                            <ColorAnimation Storyboard.TargetName="Stop2" Storyboard.TargetProperty="Color" To="#4A5A80B0" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="Tag" Value="Selected">
                                <Setter TargetName="TextDisplay" Property="FontWeight" Value="Normal"/>
                                <Setter TargetName="TextDisplay" Property="Foreground">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                            <GradientStop Color="#FF90D0FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="TextDisplay" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#FF00D8FF" BlurRadius="15" Opacity="0.85" ShadowDepth="0"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent" PreviewMouseWheel="OnPreviewMouseWheel">
        <Rectangle Stretch="Fill" IsHitTestVisible="False">
            <Rectangle.Fill>
                <SolidColorBrush Color="White"/>
            </Rectangle.Fill>
            <Rectangle.Effect>
                <local:TilesPageBackgroundEffect Time="{Binding BackgroundTime, ElementName=Root}"
                                                 AspectRatio="{Binding BackgroundAspectRatio, ElementName=Root}"/>
            </Rectangle.Effect>
        </Rectangle>

        <Grid Margin="60,30,60,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30" VerticalAlignment="Center">
                <Button x:Name="BtnLiveTiles"
                        Content="Live Tiles"
                        Click="BtnLiveTiles_Click"
                        Style="{StaticResource HeaderButtonStyle}"/>
                <Button x:Name="BtnLiveSession"
                        Content="Live Session"
                        Click="BtnLiveSession_Click"
                        Style="{StaticResource HeaderButtonStyle}"
                        Margin="40,0,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" ClipToBounds="True">
                <Grid x:Name="PageLiveTiles" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </Grid.RenderTransform>

                    <ScrollViewer x:Name="TileScrollViewer"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Focusable="False"
                                  CanContentScroll="True"
                                  PreviewMouseWheel="TileScrollViewer_PreviewMouseWheel"
                                  Margin="10,0,10,0">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </Style>
                        </ScrollViewer.Resources>

                        <ItemsControl x:Name="TileGroupsItemsControl"
                                      ItemsSource="{Binding TileGroups}"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="20,0,20,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBox Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                                 Margin="2,0,0,12"
                                                 Padding="6,0,6,2"
                                                 MinWidth="120"
                                                 FontSize="22"
                                                 FontWeight="Light"
                                                 Foreground="#CCFFFFFF"
                                                 CaretBrush="White"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 FontFamily="Segoe UI Light, Microsoft YaHei Light"/>

                                        <Grid x:Name="GroupGrid"
                                              Grid.Row="1"
                                              Width="792"
                                              Height="528"
                                              ClipToBounds="False">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="132"/>
                                                <RowDefinition Height="132"/>
                                                <RowDefinition Height="132"/>
                                                <RowDefinition Height="132"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="132"/>
                                                <ColumnDefinition Width="132"/>
                                                <ColumnDefinition Width="132"/>
                                                <ColumnDefinition Width="132"/>
                                                <ColumnDefinition Width="132"/>
                                                <ColumnDefinition Width="132"/>
                                            </Grid.ColumnDefinitions>

                                            <ItemsControl Grid.RowSpan="4"
                                                          Grid.ColumnSpan="6"
                                                          ItemsSource="{Binding Tiles}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <Grid>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="132"/>
                                                                <RowDefinition Height="132"/>
                                                                <RowDefinition Height="132"/>
                                                                <RowDefinition Height="132"/>
                                                            </Grid.RowDefinitions>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="132"/>
                                                                <ColumnDefinition Width="132"/>
                                                                <ColumnDefinition Width="132"/>
                                                                <ColumnDefinition Width="132"/>
                                                                <ColumnDefinition Width="132"/>
                                                                <ColumnDefinition Width="132"/>
                                                            </Grid.ColumnDefinitions>
                                                        </Grid>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemContainerStyle>
                                                    <Style TargetType="ContentPresenter">
                                                        <Setter Property="Grid.Row" Value="{Binding Row}"/>
                                                        <Setter Property="Grid.Column" Value="{Binding Column}"/>
                                                        <Setter Property="Grid.RowSpan" Value="{Binding RowSpan}"/>
                                                        <Setter Property="Grid.ColumnSpan" Value="{Binding ColumnSpan}"/>
                                                        <Setter Property="Panel.ZIndex" Value="0"/>
                                                        <EventSetter Event="Loaded" Handler="OnTilePresenterLoaded"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                                <Setter Property="Panel.ZIndex" Value="20"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </ItemsControl.ItemContainerStyle>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Command="{Binding RunCommand}"
                                                                Margin="6"
                                                                Cursor="Hand"
                                                                Background="Transparent"
                                                                BorderThickness="0"
                                                                FocusVisualStyle="{x:Null}"
                                                                PreviewMouseLeftButtonDown="OnTilePreviewMouseLeftButtonDown">
                                                            <Button.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="Run" Command="{Binding RunCommand}"/>
                                                                    <MenuItem Header="Remove tile" Command="{Binding RemoveCommand}"/>
                                                                    <Separator Background="#33FFFFFF"/>
                                                                    <MenuItem Header="Size">
                                                                        <MenuItem Header="Small (1x1)" Command="{Binding SetSizeCommand}" CommandParameter="1x1" IsCheckable="True" IsChecked="{Binding Size, Converter={StaticResource SizeToBoolConverter}, ConverterParameter=1x1}"/>
                                                                        <MenuItem Header="Wide (2x1)" Command="{Binding SetSizeCommand}" CommandParameter="1x2" IsCheckable="True" IsChecked="{Binding Size, Converter={StaticResource SizeToBoolConverter}, ConverterParameter=1x2}"/>
                                                                        <MenuItem Header="Large (2x2)" Command="{Binding SetSizeCommand}" CommandParameter="2x2" IsCheckable="True" IsChecked="{Binding Size, Converter={StaticResource SizeToBoolConverter}, ConverterParameter=2x2}"/>
                                                                    </MenuItem>
                                                                    <MenuItem Header="Custom image..." Command="{Binding CustomImageCommand}" Visibility="{Binding IsLarge, Converter={StaticResource BoolToVisConverter}}"/>
                                                                </ContextMenu>
                                                            </Button.ContextMenu>
                                                            <Button.Template>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Grid x:Name="TileRoot"
                                                                          RenderTransformOrigin="0.5,0.5"
                                                                          CacheMode="BitmapCache">
                                                                        <Grid.RenderTransform>
                                                                            <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                        </Grid.RenderTransform>

                                                                        <Border CornerRadius="4" BorderThickness="1">
                                                                            <Border.BorderBrush>
                                                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                                    <GradientStop Color="#55FFFFFF" Offset="0"/>
                                                                                    <GradientStop Color="#25FFFFFF" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.BorderBrush>
                                                                            <Border.Background>
                                                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                                    <GradientStop Color="#25171718" Offset="0"/>
                                                                                    <GradientStop Color="#15FFFFFF" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.Background>
                                                                        </Border>

                                                                        <Border CornerRadius="4" Opacity="0.75">
                                                                            <Border.Background>
                                                                                <RadialGradientBrush RadiusX="1.27972"
                                                                                                     RadiusY="0.744935"
                                                                                                     Center="0.819209,0.896333"
                                                                                                     GradientOrigin="0.819209,0.896333">
                                                                                    <RadialGradientBrush.GradientStops>
                                                                                        <GradientStop Color="#00171718" Offset="0"/>
                                                                                        <GradientStop Color="#00BBBBBB" Offset="0.88"/>
                                                                                        <GradientStop Color="#20FFFFFF" Offset="1"/>
                                                                                    </RadialGradientBrush.GradientStops>
                                                                                    <RadialGradientBrush.RelativeTransform>
                                                                                        <TransformGroup>
                                                                                            <SkewTransform CenterX="0.819209" CenterY="0.896333" AngleX="-6.516" AngleY="0"/>
                                                                                            <RotateTransform CenterX="0.819209" CenterY="0.896333" Angle="-33.36"/>
                                                                                        </TransformGroup>
                                                                                    </RadialGradientBrush.RelativeTransform>
                                                                                </RadialGradientBrush>
                                                                            </Border.Background>
                                                                        </Border>

                                                                        <Border x:Name="CustomImageBorder"
                                                                                CornerRadius="4"
                                                                                Margin="1"
                                                                                Background="{Binding CustomImageSource, Converter={StaticResource TileImageBrushConverter}}"
                                                                                Visibility="Collapsed"/>

                                                                        <Border x:Name="HoverGlow"
                                                                                BorderThickness="1"
                                                                                CornerRadius="4"
                                                                                Opacity="0"
                                                                                IsHitTestVisible="False">
                                                                            <Border.BorderBrush>
                                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                                    <GradientStop Color="#A0FFFFFF" Offset="0"/>
                                                                                    <GradientStop Color="#40FFFFFF" Offset="0.5"/>
                                                                                    <GradientStop Color="#A0A0C0FF" Offset="1"/>
                                                                                </LinearGradientBrush>
                                                                            </Border.BorderBrush>
                                                                            <Border.Background>
                                                                                <RadialGradientBrush RadiusX="1" RadiusY="1" Center="0.5,0.5" GradientOrigin="0.5,0.5">
                                                                                    <GradientStop Color="#18FFFFFF" Offset="0"/>
                                                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                                                </RadialGradientBrush>
                                                                            </Border.Background>
                                                                        </Border>

                                                                        <Grid Margin="15" IsHitTestVisible="False">
                                                                            <Grid.RowDefinitions>
                                                                                <RowDefinition Height="Auto"/>
                                                                                <RowDefinition Height="*"/>
                                                                                <RowDefinition Height="Auto"/>
                                                                            </Grid.RowDefinitions>

                                                                            <ContentControl Content="{Binding Icon}"
                                                                                            Width="32"
                                                                                            Height="32"
                                                                                            HorizontalAlignment="Left"
                                                                                            VerticalAlignment="Top">
                                                                                <ContentControl.ContentTemplate>
                                                                                    <DataTemplate>
                                                                                        <Path Data="{Binding}"
                                                                                              Fill="#E8F4FF"
                                                                                              Stretch="Uniform"
                                                                                              HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center"/>
                                                                                    </DataTemplate>
                                                                                </ContentControl.ContentTemplate>
                                                                            </ContentControl>

                                                                            <TextBlock Grid.Row="2"
                                                                                       Text="{Binding Name}"
                                                                                       Foreground="#EFEFEF"
                                                                                       FontSize="14"
                                                                                       FontWeight="SemiBold"
                                                                                       FontFamily="Segoe UI, Microsoft YaHei"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       VerticalAlignment="Bottom"
                                                                                       HorizontalAlignment="Left"/>
                                                                        </Grid>
                                                                    </Grid>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Trigger.EnterActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="HoverGlow" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.18"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.03" Duration="0:0:0.15" DecelerationRatio="0.8"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.03" Duration="0:0:0.15" DecelerationRatio="0.8"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </Trigger.EnterActions>
                                                                            <Trigger.ExitActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="HoverGlow" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.15"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.15" AccelerationRatio="0.8"/>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.15" AccelerationRatio="0.8"/>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </Trigger.ExitActions>
                                                                        </Trigger>
                                                                        <Trigger Property="IsPressed" Value="True">
                                                                            <Trigger.EnterActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.975" Duration="0:0:0.09">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.975" Duration="0:0:0.09">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </Trigger.EnterActions>
                                                                            <Trigger.ExitActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.14">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.14">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <CubicEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </Trigger.ExitActions>
                                                                        </Trigger>
                                                                        <DataTrigger Binding="{Binding HasCustomImage}" Value="True">
                                                                            <Setter TargetName="CustomImageBorder" Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                                            <DataTrigger.EnterActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.94" Duration="0:0:0.16">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <QuinticEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.94" Duration="0:0:0.16">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <QuinticEase EasingMode="EaseOut"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.EnterActions>
                                                                            <DataTrigger.ExitActions>
                                                                                <BeginStoryboard>
                                                                                    <Storyboard>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.26">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <BackEase EasingMode="EaseOut" Amplitude="0.12"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                        <DoubleAnimation Storyboard.TargetName="TileRoot" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.26">
                                                                                            <DoubleAnimation.EasingFunction>
                                                                                                <BackEase EasingMode="EaseOut" Amplitude="0.12"/>
                                                                                            </DoubleAnimation.EasingFunction>
                                                                                        </DoubleAnimation>
                                                                                    </Storyboard>
                                                                                </BeginStoryboard>
                                                                            </DataTrigger.ExitActions>
                                                                            <Setter TargetName="TileRoot" Property="Opacity" Value="0.68"/>
                                                                            <Setter TargetName="TileRoot" Property="Effect">
                                                                                <Setter.Value>
                                                                                    <DropShadowEffect Color="#FF00B0FF" BlurRadius="10" Opacity="0.7" ShadowDepth="2"/>
                                                                                </Setter.Value>
                                                                            </Setter>
                                                                        </DataTrigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Button.Template>
                                                        </Button>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <Border Grid.Row="{Binding DropRow}"
                                                    Grid.Column="{Binding DropColumn}"
                                                    Grid.RowSpan="{Binding DropRowSpan}"
                                                    Grid.ColumnSpan="{Binding DropColumnSpan}"
                                                    Margin="6"
                                                    CornerRadius="4"
                                                    BorderBrush="#D8FFFFFF"
                                                    BorderThickness="2"
                                                    Background="#20FFFFFF"
                                                    IsHitTestVisible="False"
                                                    Visibility="{Binding IsDropPreviewVisible, Converter={StaticResource BoolToVisConverter}}"/>
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <Grid x:Name="PageLiveSession" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TranslateTransform X="0" Y="0"/>
                    </Grid.RenderTransform>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Live Session"
                                   FontSize="48"
                                   FontWeight="ExtraLight"
                                   Foreground="#FF00B0FF"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FF00B0FF" BlurRadius="20" Opacity="0.4" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="Real-time interactive session control workspace."
                                   Margin="0,15,0,0"
                                   FontSize="16"
                                   Foreground="#80A0C0D0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
