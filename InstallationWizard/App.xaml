<Application x:Class="InstallationWizard.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 0. 语言资源 -->
                <ResourceDictionary Source="Resources/Strings/Strings.zh-CN.xaml"/>
                
                <!-- 1. 基础颜色和画刷定义 -->
                <ResourceDictionary Source="Styles/AeroColors.xaml"/>
                
                <!-- 2. 显式控件样式 -->
                <ResourceDictionary Source="Styles/AeroControls.xaml"/>
                <ResourceDictionary Source="Styles/AeroScrollBars.xaml"/>
                <ResourceDictionary Source="Styles/WindowStyle.xaml"/>
                
                <!-- 3. 隐式样式 -->
                <ResourceDictionary Source="Styles/AeroImplicitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
